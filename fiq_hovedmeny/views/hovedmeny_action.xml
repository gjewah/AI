<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Klient-handling: OWL-dashbordet -->
    <record id="action_fiq_hovedmeny" model="ir.actions.client">
        <field name="name">Hovedmeny</field>
        <field name="tag">fiq_hovedmeny_dashboard</field>
    </record>

    <!-- Topp-meny som åpner Hovedmeny Total – kun Hovedmeny-brukere -->
    <menuitem id="menu_fiq_hovedmeny_root"
              name="Hovedmeny"
              action="action_fiq_hovedmeny"
              web_icon="fiq_hovedmeny,static/description/icon.png"
              groups="fiq_hovedmeny.group_user"
              sequence="1"/>

    <!-- Ved install OG oppgradering: sett oppstart til Hovedmeny for alle interne brukere -->
    <function model="fiq.hovedmeny.config" name="_action_set_home_all"/>
</odoo>
