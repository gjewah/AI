<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">

    <!-- Multi-company tenant-isolasjon: hver bruker ser kun befaringer i sine
         egne firmaer (company_ids). Globale record rules håndhever isolasjonen på
         DB-nivå — AI/bruker kan ALDRI lekke på tvers av firma. Ett sett per modell. -->

    <record id="fiq_befaring_company_rule" model="ir.rule">
        <field name="name">Befaring: multi-company</field>
        <field name="model_id" ref="model_fiq_befaring"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

    <record id="fiq_befaring_rom_company_rule" model="ir.rule">
        <field name="name">Befaring rom: multi-company</field>
        <field name="model_id" ref="model_fiq_befaring_rom"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

    <record id="fiq_befaring_funn_company_rule" model="ir.rule">
        <field name="name">Befaring funn: multi-company</field>
        <field name="model_id" ref="model_fiq_befaring_funn"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

</odoo>
