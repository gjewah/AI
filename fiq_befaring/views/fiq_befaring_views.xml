<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================================= -->
    <!-- fiq.befaring — befarings-økt (salgsmulighet → romskjema → tilbud → prosjekt) -->
    <!-- ================================================================= -->

    <record id="view_fiq_befaring_list" model="ir.ui.view">
        <field name="name">fiq.befaring.list</field>
        <field name="model">fiq.befaring</field>
        <field name="arch" type="xml">
            <list string="Befaringer">
                <field name="name"/>
                <field name="dato"/>
                <field name="partner_id"/>
                <field name="lead_id" optional="show"/>
                <field name="sale_order_id" optional="hide"/>
                <field name="project_id" optional="show"/>
                <field name="utfort_av_id" optional="show"/>
                <field name="rom_antall"/>
                <field name="funn_antall"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'utkast'"
                       decoration-warning="state == 'pagaar'"
                       decoration-success="state in ('fullfort', 'overfort')"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_fiq_befaring_form" model="ir.ui.view">
        <field name="name">fiq.befaring.form</field>
        <field name="model">fiq.befaring</field>
        <field name="arch" type="xml">
            <form string="Befaring">
                <header>
                    <button name="action_start" type="object" string="Start befaring"
                            class="btn-primary" invisible="state != 'utkast'"/>
                    <button name="action_fullfor" type="object" string="Fullfør"
                            class="btn-primary" invisible="state != 'pagaar'"/>
                    <button name="action_overfor" type="object" string="Overfør til prosjekt"
                            class="btn-primary" invisible="state != 'fullfort' or not project_id"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="utkast,pagaar,fullfort,overfort"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Navn på befaringen"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="lead_id"/>
                            <field name="partner_id"/>
                            <field name="sale_order_id"/>
                        </group>
                        <group>
                            <field name="dato"/>
                            <field name="utfort_av_id"/>
                            <field name="project_id"/>
                            <field name="befaring_task_id" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Rom (romskjema)" name="rom">
                            <field name="rom_ids">
                                <list string="Rom" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="etasje"/>
                                    <field name="areal"/>
                                    <field name="tiltak"/>
                                    <field name="ai_tiltak_no" optional="hide"/>
                                    <field name="ai_tiltak_en" optional="hide"/>
                                </list>
                                <form string="Rom">
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="name"/>
                                                <field name="etasje"/>
                                                <field name="areal"/>
                                            </group>
                                            <group>
                                                <field name="foto" widget="image" class="oe_avatar"/>
                                            </group>
                                        </group>
                                        <group string="Tiltak">
                                            <field name="tiltak" nolabel="1"/>
                                        </group>
                                        <group string="Talenotat / AI-tiltak">
                                            <field name="talenotat"/>
                                            <field name="ai_tiltak_no"/>
                                            <field name="ai_tiltak_en"/>
                                        </group>
                                        <group string="Funn / avvik i rommet">
                                            <field name="funn_ids" nolabel="1">
                                                <list string="Funn" editable="bottom">
                                                    <field name="name"/>
                                                    <field name="type"/>
                                                    <field name="alvorlighet"/>
                                                    <field name="status"/>
                                                </list>
                                            </field>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Funn / avvik" name="funn">
                            <field name="funn_ids">
                                <list string="Funn / avvik" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="rom_id"/>
                                    <field name="type"/>
                                    <field name="alvorlighet"/>
                                    <field name="status" widget="badge"
                                           decoration-warning="status == 'apen'"
                                           decoration-success="status == 'lukket'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notat" name="notat">
                            <field name="notat" placeholder="Generelt notat om befaringen"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_fiq_befaring_search" model="ir.ui.view">
        <field name="name">fiq.befaring.search</field>
        <field name="model">fiq.befaring</field>
        <field name="arch" type="xml">
            <search string="Søk befaringer">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="lead_id"/>
                <field name="project_id"/>
                <field name="utfort_av_id"/>
                <filter name="mine" string="Mine befaringer"
                        domain="[('utfort_av_id', '=', uid)]"/>
                <separator/>
                <filter name="utkast" string="Utkast" domain="[('state', '=', 'utkast')]"/>
                <filter name="pagaar" string="Pågår" domain="[('state', '=', 'pagaar')]"/>
                <filter name="fullfort" string="Fullført" domain="[('state', '=', 'fullfort')]"/>
                <filter name="overfort" string="Overført" domain="[('state', '=', 'overfort')]"/>
                <separator/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_partner" string="Kunde" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_utfort" string="Befarer" context="{'group_by': 'utfort_av_id'}"/>
                    <filter name="group_dato" string="Befaringsdato" context="{'group_by': 'dato'}"/>
                
            </search>
        </field>
    </record>

    <record id="action_fiq_befaring" model="ir.actions.act_window">
        <field name="name">Befaringer</field>
        <field name="res_model">fiq.befaring</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_fiq_befaring_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiley_face">Registrer den første befaringen</p>
            <p>En befaring starter i salgsprosessen (salgsmulighet), fanger rom og funn,
               genererer romskjema, fyller tilbud og overføres til prosjektet under
               oppgaven «Befaring». Generisk for alle FIQ-kunder, tenant-isolert per firma.</p>
        </field>
    </record>

    <!-- ================================================================= -->
    <!-- fiq.befaring.funn — flat oversikt over alle funn/avvik -->
    <!-- ================================================================= -->

    <record id="view_fiq_befaring_funn_list" model="ir.ui.view">
        <field name="name">fiq.befaring.funn.list</field>
        <field name="model">fiq.befaring.funn</field>
        <field name="arch" type="xml">
            <list string="Funn / avvik">
                <field name="name"/>
                <field name="befaring_id"/>
                <field name="rom_id"/>
                <field name="type"/>
                <field name="alvorlighet"/>
                <field name="status" widget="badge"
                       decoration-warning="status == 'apen'"
                       decoration-success="status == 'lukket'"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_fiq_befaring_funn_form" model="ir.ui.view">
        <field name="name">fiq.befaring.funn.form</field>
        <field name="model">fiq.befaring.funn</field>
        <field name="arch" type="xml">
            <form string="Funn / avvik">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Kort beskrivelse av funnet"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="befaring_id"/>
                            <field name="rom_id"/>
                            <field name="type"/>
                        </group>
                        <group>
                            <field name="alvorlighet"/>
                            <field name="status"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Beskrivelse">
                        <field name="beskrivelse" nolabel="1"/>
                    </group>
                    <group>
                        <field name="foto" widget="image"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fiq_befaring_funn_search" model="ir.ui.view">
        <field name="name">fiq.befaring.funn.search</field>
        <field name="model">fiq.befaring.funn</field>
        <field name="arch" type="xml">
            <search string="Søk funn / avvik">
                <field name="name"/>
                <field name="befaring_id"/>
                <field name="rom_id"/>
                <filter name="apen" string="Åpne" domain="[('status', '=', 'apen')]"/>
                <filter name="avvik" string="Avvik" domain="[('type', '=', 'avvik')]"/>
                <filter name="hoy" string="Høy alvorlighet" domain="[('alvorlighet', '=', 'hoy')]"/>
                <separator/>
                    <filter name="group_befaring" string="Befaring" context="{'group_by': 'befaring_id'}"/>
                    <filter name="group_type" string="Type" context="{'group_by': 'type'}"/>
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_alvor" string="Alvorlighet" context="{'group_by': 'alvorlighet'}"/>
                
            </search>
        </field>
    </record>

    <record id="action_fiq_befaring_funn" model="ir.actions.act_window">
        <field name="name">Funn / avvik</field>
        <field name="res_model">fiq.befaring.funn</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_fiq_befaring_funn_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiley_face">Ingen funn registrert ennå</p>
            <p>Funn, avvik og endringer fanges under befaringen (per rom) og kan dras
               med videre inn i prosjektet.</p>
        </field>
    </record>

</odoo>
