<?xml version="1.0" encoding="utf-8" ?>
<data>
    <record id="crm_lead_view_list_leads" model="ir.ui.view">
        <field name="name">crm.lead.view.list.inherit.crm_documents_tag</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_leads" />
        <field name="arch" type="xml">
            <data>
                <list position="inside">
                    <field name="documents_tag_id" optional="hide"/>
                    <field name="documents_tag_ids" optional="hide" widget="many2many_tags"/>
                </list>
            </data>
        </field>
    </record>
    <record id="crm_lead_view_list_oppor" model="ir.ui.view">
        <field name="name">crm.lead.view.list.inherit.crm_documents_tag</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_oppor" />
        <field name="arch" type="xml">
            <data>
                <list position="inside">
                    <field name="documents_tag_id" optional="hide"/>
                    <field name="documents_tag_ids" optional="hide" widget="many2many_tags"/>
                </list>
            </data>
        </field>
    </record>
    <record id="crm_lead_view_form" model="ir.ui.view">
        <field name="name">crm.lead.view.form.inherit.crm_documents_tag</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form" />
        <field name="arch" type="xml">
            <data>
                <group name="lead_partner" position="inside">
                    <field name="documents_tag_id" />
                    <field name="documents_tag_tooltip_translate" />
                    <field name="documents_tag_ids_filter" widget="boolean_toggle" />
                    <div class="d-inline-flex w-100" colspan="2">
                        <button
                            string="Select DOC Tags"
                            type="object"
                            name="action_open_tag_selector"
                            class="btn-secondary"
                        />
                        <field
                            name="documents_tag_ids"
                            invisible="documents_tag_ids_filter"
                            widget="many2many_tags"
                            options="{'no_quick_create': True}"
                        />
                        <field
                            name="documents_tag_ids"
                            domain="[('id', 'in', documents_tag_all_child_ids)]"
                            invisible="not documents_tag_ids_filter"
                            widget="many2many_tags"
                            options="{'no_quick_create': True}"
                        />
                    </div>
                </group>
                <group name="opportunity_partner" position="inside">
                    <field name="documents_tag_id" />
                    <field name="documents_tag_tooltip_translate" />
                    <field name="documents_tag_ids_filter" widget="boolean_toggle" />
                    <div class="d-inline-flex w-100">
                        <button
                            string="Select DOC Tags"
                            type="object"
                            name="action_open_tag_selector"
                            class="btn-secondary"
                        />
                        <field
                            name="documents_tag_ids"
                            invisible="documents_tag_ids_filter"
                            widget="many2many_tags"
                            options="{'no_quick_create': True}"
                        />
                        <field
                            name="documents_tag_ids"
                            domain="[('id', 'in', documents_tag_all_child_ids)]"
                            invisible="not documents_tag_ids_filter"
                            widget="many2many_tags"
                            options="{'no_quick_create': True}"
                        />
                    </div>
                </group>
            </data>
        </field>
    </record>
</data>
