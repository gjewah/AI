<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Klient-handling: OWL-dashbordet -->
    <record id="action_fiq_gui_hoved" model="ir.actions.client">
        <field name="name">Hovedmeny</field>
        <field name="tag">fiq_gui_hoved_dashboard</field>
    </record>

    <!-- Topp-meny som åpner Hovedmeny – kun Hovedmeny-brukere -->
    <menuitem id="menu_fiq_gui_hoved_root"
              name="Hovedmeny"
              action="action_fiq_gui_hoved"
              web_icon="fiq_gui_hoved,static/description/icon.png"
              groups="fiq_gui_hoved.group_user"
              sequence="1"/>

    <!-- Ved install OG oppgradering: sett oppstart til Hovedmeny for alle interne brukere -->
    <function model="fiq.gui.hoved.config" name="_action_set_home_all"/>
</odoo>
