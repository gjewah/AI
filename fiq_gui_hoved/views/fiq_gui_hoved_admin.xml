<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Brukeroppsett (config) – list + form -->
    <record id="view_fiq_gui_hoved_config_list" model="ir.ui.view">
        <field name="name">fiq.gui.hoved.config.list</field>
        <field name="model">fiq.gui.hoved.config</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="user_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="level"/>
                <field name="show_kpis"/>
                <field name="show_projects"/>
                <field name="show_chart"/>
                <field name="show_copilot"/>
            </list>
        </field>
    </record>

    <record id="view_fiq_gui_hoved_config_form" model="ir.ui.view">
        <field name="name">fiq.gui.hoved.config.form</field>
        <field name="model">fiq.gui.hoved.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="level"/>
                        </group>
                        <group string="Synlige widgets">
                            <field name="show_kpis"/>
                            <field name="show_projects"/>
                            <field name="show_activity"/>
                            <field name="show_tasks"/>
                            <field name="show_chart"/>
                            <field name="show_copilot"/>
                            <field name="show_quick"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fiq_gui_hoved_config" model="ir.actions.act_window">
        <field name="name">Brukeroppsett (Hovedmeny)</field>
        <field name="res_model">fiq.gui.hoved.config</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Firma-branding (aksent/logo) -->
    <record id="action_fiq_gui_hoved_branding" model="ir.actions.act_window">
        <field name="name">Firma-branding</field>
        <field name="res_model">res.company</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ADMIN-HOVEDMENY: egen rot, kun for Hovedmeny-administrator -->
    <menuitem id="menu_fiq_gui_hoved_admin_root"
              name="Hovedmeny Admin"
              web_icon="fiq_gui_hoved,static/description/icon.png"
              groups="fiq_gui_hoved.group_admin"
              sequence="2"/>
    <menuitem id="menu_fiq_gui_hoved_admin_config"
              name="Brukeroppsett"
              parent="menu_fiq_gui_hoved_admin_root"
              action="action_fiq_gui_hoved_config"
              groups="fiq_gui_hoved.group_admin"
              sequence="10"/>
    <menuitem id="menu_fiq_gui_hoved_admin_branding"
              name="Firma-branding"
              parent="menu_fiq_gui_hoved_admin_root"
              action="action_fiq_gui_hoved_branding"
              groups="fiq_gui_hoved.group_admin"
              sequence="20"/>
    <menuitem id="menu_fiq_gui_hoved_admin_users"
              name="Brukere &amp; tilgang"
              parent="menu_fiq_gui_hoved_admin_root"
              action="base.action_res_users"
              groups="fiq_gui_hoved.group_admin"
              sequence="30"/>
</odoo>
