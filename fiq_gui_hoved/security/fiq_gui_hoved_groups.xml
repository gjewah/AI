<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FIQs rettighetsgrupper for Hovedmeny (Odoo 19: kun name + implied_ids).
         Hierarki: Bruker < Leder < Administrator. Admin styrer oppsett + tilgang. -->
    <record id="group_user" model="res.groups">
        <field name="name">FIQ Hovedmeny / Bruker</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_manager" model="res.groups">
        <field name="name">FIQ Hovedmeny / Leder</field>
        <field name="implied_ids" eval="[(4, ref('fiq_gui_hoved.group_user'))]"/>
    </record>

    <record id="group_admin" model="res.groups">
        <field name="name">FIQ Hovedmeny / Administrator</field>
        <field name="implied_ids" eval="[(4, ref('fiq_gui_hoved.group_manager'))]"/>
    </record>

    <!-- Odoo-systemadmin får automatisk Hovedmeny-admin -->
    <record id="base.group_system" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('fiq_gui_hoved.group_admin'))]"/>
    </record>

    <!-- ALLE interne brukere får Hovedmeny-Bruker (så alle kan starte i Hovedmenyen) -->
    <record id="base.group_user" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('fiq_gui_hoved.group_user'))]"/>
    </record>

    <!-- Tilgangsregler: bruker ser/redigerer KUN sitt eget oppsett; admin ser alle.
         (Tenant-isolasjon: company_id-filter arves av Odoos multi-company-regler.) -->
    <record id="rule_config_own" model="ir.rule">
        <field name="name">Hovedmeny-oppsett: eget</field>
        <field name="model_id" ref="model_fiq_gui_hoved_config"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('fiq_gui_hoved.group_user'))]"/>
    </record>
    <record id="rule_config_admin" model="ir.rule">
        <field name="name">Hovedmeny-oppsett: admin alle</field>
        <field name="model_id" ref="model_fiq_gui_hoved_config"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('fiq_gui_hoved.group_admin'))]"/>
    </record>
</odoo>
