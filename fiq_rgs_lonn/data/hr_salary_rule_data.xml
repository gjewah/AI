<?xml version="1.0" encoding="utf-8"?>
<!--
    NORSK LOENNSSTRUKTUR — grunnlag og arbeidsgiveravgift

    Testene med EKTE data (21-26) avslørte at beregningen leste loennslinjer
    som INGENTING skrev: `fiq_aga_grunnlag()` summerer kategorien BASIC, men
    modulen hadde ingen loennsart som produserte den. Aggregatet ga derfor
    alltid tomt — stille, uten feilmelding.

    🔑 Det er nøyaktig klassen 2.80 RGS kalte «virker, men galt»: formen var
    riktig, innholdet fantes ikke. Formtester uten data fanget det ikke.

    ⚠️ AGA er en ARBEIDSGIVERKOSTNAD, ikke et trekk fra den ansatte.
    Den skal ALDRI redusere nettoloennen — derfor `appears_on_payslip` med
    egen kategori, og ingen paavirkning paa NET.
-->
<odoo>

    <!-- ============================================================
         STRUKTURTYPE + STRUKTUR
         ============================================================ -->
    <record id="structure_type_no_employee" model="hr.payroll.structure.type">
        <field name="name">Norge: ansatt</field>
        <field name="country_id" ref="base.no"/>
    </record>

    <record id="hr_payroll_structure_no_employee" model="hr.payroll.structure">
        <field name="name">Norge: månedslønn</field>
        <field name="type_id" ref="structure_type_no_employee"/>
        <field name="country_id" ref="base.no"/>
    </record>

    <!-- ============================================================
         01 · GRUNNLOENN — grunnlaget alt annet regnes fra
         ============================================================ -->
    <record id="rule_no_basic" model="hr.salary.rule">
        <field name="name">Grunnlønn</field>
        <field name="code">BASIC</field>
        <field name="sequence">1</field>
        <field name="category_id" ref="hr_payroll.BASIC"/>
        <field name="struct_id" ref="hr_payroll_structure_no_employee"/>
        <field name="condition_select">none</field>
        <!-- `basic_wage` er et EKTE felt paa hr.payslip (verifisert i basen).
             l10n_lt bruker `paid_amount`, som IKKE finnes som lagret felt —
             ikke kopier den uten aa sjekke. -->
        <field name="amount_select">code</field>
        <field name="amount_python_compute">result = payslip.basic_wage</field>
    </record>

    <!-- ============================================================
         02 · ARBEIDSGIVERAVGIFT — arbeidsgiverkostnad, ikke trekk
         ============================================================ -->
    <record id="rule_no_aga" model="hr.salary.rule">
        <field name="name">Arbeidsgiveravgift</field>
        <field name="code">AGA</field>
        <field name="sequence">200</field>
        <!-- COMP = arbeidsgiverens kostnad. IKKE DED (trekk fra ansatt) —
             AGA betales AV arbeidsgiver, ikke AV den ansatte. Feil kategori
             ville trukket avgiften fra nettoloennen. -->
        <field name="category_id" ref="hr_payroll.COMP"/>
        <field name="struct_id" ref="hr_payroll_structure_no_employee"/>
        <!-- Kjoerer bare naar en sone finnes. Uten denne betingelsen ville
             `fiq_aga_belop()` kastet ValueError og stoppet HELE
             loennskjoeringen for et selskap som mangler sone. Avviket
             rapporteres i stedet via status_forpliktelser() til 2.80 RGS. -->
        <field name="condition_select">python</field>
        <field name="condition_python">result = bool(payslip.fiq_aga_sone())</field>
        <field name="amount_select">code</field>
        <field name="amount_python_compute">result = -payslip.fiq_aga_belop()</field>
        <field name="appears_on_payslip" eval="True"/>
    </record>

</odoo>
