<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sone paa selskapet — HOVEDREGELEN.
         Legges i firmainnstillingene fordi sonen foelger virksomhetens
         registrerte lokalisering, ikke den enkelte ansatte. -->
    <record id="view_company_form_aga" model="ir.ui.view">
        <field name="name">res.company.form.fiq.aga</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <!-- general_info er en <page>, IKKE en <group> — verifisert i
                 odoo/addons/base/views/res_company_views.xml. Feil elementtype
                 gir «cannot be located in parent view» og roedt bygg. -->
            <page name="general_info" position="inside">
                <group string="Arbeidsgiveravgift" name="fiq_aga">
                    <field name="fiq_aga_sone"/>
                    <field name="fiq_aga_fribelop_brukt"
                           invisible="fiq_aga_sone not in ('1a', '4a')"/>
                    <div colspan="2"
                         invisible="fiq_aga_sone not in ('1a', '4a')">
                        <span class="text-muted">
                            Redusert sats gjelder inntil fribeløpet er brukt opp.
                            Deretter full sats for det overskytende.
                        </span>
                    </div>
                </group>
            </page>
        </field>
    </record>

    <!-- Sone-unntak paa ansattkortet — AMBULERENDE VIRKSOMHET.
         Feltet er et unntak og skal staa tomt i normaltilfellet. -->
    <record id="view_employee_form_aga" model="ir.ui.view">
        <field name="name">hr.employee.form.fiq.aga</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <!-- Feltet hoerer hjemme paa loennsfanen, ikke ved stillingstittelen.
                 job_title finnes DESSUTEN to steder i skjemaet (linje 162 og 576)
                 — et tvetydig anker gir uforutsigbar plassering. -->
            <page name="payroll_information" position="inside">
                <group string="Arbeidsgiveravgift" name="fiq_aga_ansatt">
                    <field name="fiq_aga_sone_override"
                           groups="hr_payroll.group_hr_payroll_user"/>
                </group>
            </page>
        </field>
    </record>

</odoo>
