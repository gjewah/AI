<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Odoo 19: en gruppe UTEN privilege_id er USYNLIG i Innstillinger.
         res.groups har ingen category_id-kolonne i 19 — den gaar via
         res.groups.privilege → category_id. Samme moenster som fiq_gui_rgs. -->
    <record id="res_groups_privilege_lonn" model="res.groups.privilege">
        <field name="name">FIQ Lønn</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
        <field name="sequence">20</field>
    </record>

    <!-- ===================================================================
         TILGANGSMODELL (Gjermund 23.07.2026, ordrett):
         «Den har 2.20 HRi rettigheter for lesing, men loenningsansvarlig skal
          ha rettigheter til aa lese sammen med daglig leder, men det er en
          regnskapsfunksjon.»

         TRE roller — ALLE LESING. Ingen skrivegruppe er definert her med vilje:
         selve loennskjoeringen eies av hr_payroll sine egne grupper, og denne
         modulen legger norsk lokalisering PAA den. Skrivetilgang skal ikke
         oppfinnes paa nytt i et lag over.

         🛑 KRITISK — dette er en TILGANGSGRENSE, ikke en systemgrense.
         Foer: ansattdata laa i POG, altsaa et ANNET SYSTEM. Veggen holdt seg
         selv fordi dataene fysisk ikke fantes i basen.
         Naa: Odoo koerer loenna → ansattdata ligger i SAMME base som regnskapet.
         Veggen baeres av rettigheter, som kan feilkonfigureres, arves feil,
         eller omgaas av en rapport noen lager om et halvaar.
         SAMME LOEFTE, LANGT SVAKERE HAANDHEVING. Derfor smale grupper fra dag én.
         Reist av 2.80 RGS, kanonisert av AI PK. Se brain/beslutning_fiq_rgs_lonn.
         =================================================================== -->

    <!-- 01 · 2.20 HRi — HR eier ansattdataene modulen bygger paa. -->
    <record id="group_hri_lese" model="res.groups">
        <field name="name">FIQ Lønn / 2.20 HRi — lesing</field>
        <field name="privilege_id" ref="fiq_rgs_lonn.res_groups_privilege_lonn"/>
        <!-- Arver hr.group_hr_user: den som ikke ser ansatte i HR, har heller
             ingen grunn til aa se loennsgrunnlaget deres. -->
        <field name="implied_ids" eval="[(4, ref('hr.group_hr_user'))]"/>
    </record>

    <!-- 02 · Loenningsansvarlig — den som faktisk foerer loenn. -->
    <record id="group_lonningsansvarlig" model="res.groups">
        <field name="name">FIQ Lønn / Lønningsansvarlig — lesing</field>
        <field name="privilege_id" ref="fiq_rgs_lonn.res_groups_privilege_lonn"/>
    </record>

    <!-- 03 · Daglig leder — leser SAMMEN MED loenningsansvarlig (Gjermunds ord).
         Egen gruppe, ikke arv fra 02: rollene er sidestilte lesere, og
         daglig leder skal ikke arve noe som senere maatte legges paa
         loenningsansvarlig. Implisitt arv er hvordan en tilgangsgrense
         lekker uten at noen bestemte det. -->
    <record id="group_daglig_leder" model="res.groups">
        <field name="name">FIQ Lønn / Daglig leder — lesing</field>
        <field name="privilege_id" ref="fiq_rgs_lonn.res_groups_privilege_lonn"/>
    </record>

    <!-- 🔒 MERK — det som med VILJE IKKE staar her:
         * INGEN implied_ids fra base.group_user. Loennsdata tildeles bevisst,
           aldri til «alle interne brukere». Samme feil ble fjernet i fiq_gui_rgs.
         * INGEN arv fra regnskapsgruppene (fiq_gui_rgs.group_user/_manager).
           Modulen ER en regnskapsfunksjon, men det gir ikke regnskap innsyn i
           personopplysninger. Husets regel «loenningsansvarlig ≠ regnskap»
           handler om HVEM SOM SER HVA, ikke om fagomraade.
         * 2.80/2.70 faar KUN SUMMER via aggregat-kontrakten, aldri via en gruppe
           her. Se brain/kontrakt_lonn_2_20_til_rgs_2_80.md. -->
</odoo>
