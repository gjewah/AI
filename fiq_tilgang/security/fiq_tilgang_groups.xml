<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Odoo 19: res.groups har INGEN category_id-kolonne (den fantes i 18).
         Grupperingen i Innstillinger > Brukere gaar naa via res.groups.privilege,
         som selv peker paa en ir.module.category. En gruppe UTEN privilege_id er
         usynlig i UI - den virker, men ingen kan huke den av.
         Samme moenster som fiq_gui_control v6.77 og fiq_gui_fin. -->
    <record id="module_category_fiq_tilgang" model="ir.module.category">
        <field name="name">FIQ Tilgang</field>
    </record>

    <record id="res_groups_privilege_fiq_tilgang" model="res.groups.privilege">
        <field name="name">FIQ Tilgang</field>
        <field name="category_id" ref="module_category_fiq_tilgang"/>
    </record>

    <!-- Global admin per selskap: alt i eget selskap -->
    <record id="group_company_admin" model="res.groups">
        <field name="name">Global admin (selskap)</field>
        <field name="privilege_id" ref="res_groups_privilege_fiq_tilgang"/>
    </record>

    <!-- Global admin paa topp: alt, alle selskap (arver selskaps-admin) -->
    <record id="group_global_admin" model="res.groups">
        <field name="name">Global admin (topp)</field>
        <field name="privilege_id" ref="res_groups_privilege_fiq_tilgang"/>
        <field name="implied_ids" eval="[(4, ref('group_company_admin'))]"/>
    </record>
</odoo>
