<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- 7 kanoniske start-roller (org-hierarki). Dynamisk: legg til flere per firma. -->
        <record id="rolle_direktor" model="fiq.tilgang.rolle">
            <field name="name">Direktør</field>
            <field name="sequence">10</field>
            <field name="art">intern</field>
        </record>
        <record id="rolle_daglig_leder" model="fiq.tilgang.rolle">
            <field name="name">Daglig leder</field>
            <field name="sequence">20</field>
            <field name="parent_id" ref="rolle_direktor"/>
            <field name="art">intern</field>
        </record>
        <record id="rolle_avdelingsleder" model="fiq.tilgang.rolle">
            <field name="name">Avdelingsleder</field>
            <field name="sequence">30</field>
            <field name="parent_id" ref="rolle_daglig_leder"/>
            <field name="art">intern</field>
        </record>
        <record id="rolle_fagansvarlig" model="fiq.tilgang.rolle">
            <field name="name">Fagansvarlig</field>
            <field name="sequence">40</field>
            <field name="parent_id" ref="rolle_avdelingsleder"/>
            <field name="art">intern</field>
        </record>
        <record id="rolle_teamleder" model="fiq.tilgang.rolle">
            <field name="name">Teamleder (Arbeidsleder)</field>
            <field name="sequence">50</field>
            <field name="parent_id" ref="rolle_fagansvarlig"/>
            <field name="art">intern</field>
        </record>
        <record id="rolle_arbeider" model="fiq.tilgang.rolle">
            <field name="name">Arbeider</field>
            <field name="sequence">60</field>
            <field name="parent_id" ref="rolle_teamleder"/>
            <field name="art">intern</field>
        </record>
        <record id="rolle_assistent" model="fiq.tilgang.rolle">
            <field name="name">Assistent</field>
            <field name="sequence">70</field>
            <field name="parent_id" ref="rolle_arbeider"/>
            <field name="art">intern</field>
        </record>
    </data>
</odoo>
