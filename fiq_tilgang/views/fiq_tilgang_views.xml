<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fiq_tilgang_regel_list" model="ir.ui.view">
        <field name="name">fiq.tilgang.regel.list</field>
        <field name="model">fiq.tilgang.regel</field>
        <field name="arch" type="xml">
            <list string="Tilgangsregler">
                <field name="ressurs_id"/>
                <field name="subjekt_type"/>
                <field name="gruppe_id"/>
                <field name="bruker_id"/>
                <field name="partner_id"/>
                <field name="nivaa"/>
                <field name="regel_type"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="view_fiq_tilgang_regel_form" model="ir.ui.view">
        <field name="name">fiq.tilgang.regel.form</field>
        <field name="model">fiq.tilgang.regel</field>
        <field name="arch" type="xml">
            <form string="Tilgangsregel">
                <sheet>
                    <group>
                        <field name="ressurs_id"/>
                        <field name="regel_type"/>
                        <field name="nivaa"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                    <group string="Gjelder for">
                        <field name="subjekt_type"/>
                        <field name="rolle_id" invisible="subjekt_type != 'rolle'" required="subjekt_type == 'rolle'"/>
                        <field name="gruppe_id" invisible="subjekt_type != 'gruppe'" required="subjekt_type == 'gruppe'"/>
                        <field name="bruker_id" invisible="subjekt_type != 'bruker'" required="subjekt_type == 'bruker'"/>
                        <field name="partner_id" invisible="subjekt_type != 'partner'" required="subjekt_type == 'partner'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fiq_tilgang_regel" model="ir.actions.act_window">
        <field name="name">Tilgangsregler</field>
        <field name="res_model">fiq.tilgang.regel</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_fiq_tilgang_root" name="FIQ Tilgang" sequence="90"
              groups="fiq_tilgang.group_company_admin"/>
    <menuitem id="menu_fiq_tilgang_regler" name="Tilgangsregler"
              parent="menu_fiq_tilgang_root" action="action_fiq_tilgang_regel" sequence="10"/>

    <!-- Roller (org-hierarki) -->
    <record id="view_fiq_tilgang_rolle_list" model="ir.ui.view">
        <field name="name">fiq.tilgang.rolle.list</field>
        <field name="model">fiq.tilgang.rolle</field>
        <field name="arch" type="xml">
            <list string="Roller">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="parent_id"/>
                <field name="art"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_fiq_tilgang_rolle_form" model="ir.ui.view">
        <field name="name">fiq.tilgang.rolle.form</field>
        <field name="model">fiq.tilgang.rolle</field>
        <field name="arch" type="xml">
            <form string="Rolle">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="parent_id"/>
                        <field name="art"/>
                        <field name="group_id"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                    <field name="child_ids" nolabel="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fiq_tilgang_rolle" model="ir.actions.act_window">
        <field name="name">Roller</field>
        <field name="res_model">fiq.tilgang.rolle</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_fiq_tilgang_roller" name="Roller"
              parent="menu_fiq_tilgang_root" action="action_fiq_tilgang_rolle" sequence="5"/>
</odoo>
