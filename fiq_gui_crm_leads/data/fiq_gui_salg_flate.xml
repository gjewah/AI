<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
      Selvregistrering i Kontrollrom-menyen.

      Uten denne har flaten INGEN dør inn fra KR-menyen — den virker, men vises
      uten sidemeny. Det var symptomet Gjermund meldte 18.07.2026.

      MODULEN MELDER SEG INN SELV — `fiq_gui_control` røres aldri.
      `get_fiq_flater()` leser alle nøkler med prefikset
      `fiq_gui_control.flate.` uansett hvilken modul de kommer fra.

      ⚠️ TO ULIKE MEKANISMER — ikke bland dem:
        * DENNE (server): `ir.config_parameter` → KR-menyen.
        * `static/src/salg.js` (nettleser): `registry.category("fiq_gui_flates")`
          → innmaten i sloten. Begge trengs; de gjør forskjellige ting.

      Språk: `label` er ENGELSK i kilden, norsk via i18n/nb_NO.po. Aldri
      hardkod norsk i modulkilde. `nb_NO` tas med i verdien fordi de øvrige
      flatene gjør det, og KR leser norsk før engelsk (kanon 19.07).

      Sekvens 40: salg hører før finans-familien (fin 70, rgs 75) og etter
      tidslinje (45), slik at pipelinen ligger høyt der man leter etter den.
    -->
    <data noupdate="0">

        <record id="flate_salg" model="ir.config_parameter">
            <field name="key">fiq_gui_control.flate.salg</field>
            <field name="value">{"label": {"en_US": "Sales", "nb_NO": "Salg"}, "xmlid": "fiq_gui_crm_leads.action_fiq_gui_crm_leads", "sequence": 40}</field>
        </record>

    </data>
</odoo>
