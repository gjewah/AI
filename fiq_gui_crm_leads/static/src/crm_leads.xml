<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!--
      Salgsflaten (6 SALG) — pipeline-oversikt.

      Tekstene står på ENGELSK i kilden og oversettes via i18n/nb_NO.po.
      Aldri hardkod norsk i modulkilde: en engelsk bruker skal se engelsk.

      🛑 Ingen `if`-setning i inline t-on-* — det kompilerer ikke, og da dør
         HELE malen for alle brukere. Verken XML-validering eller en ren
         syntakssjekk av JavaScript fanger det. Bruk metode eller ternary.
    -->
    <t t-name="fiq_gui_crm_leads.Dashboard">
        <div class="fiq_gui_salg">

            <div class="fiq_gui_salg_topp">
                <span class="fiq_gui_salg_merke">6</span>
                <span class="fiq_gui_salg_navn">Sales</span>
            </div>

            <t t-if="state.laster">
                <div class="fiq_gui_salg_laster">Loading…</div>
            </t>

            <t t-else="">
                <div class="fiq_gui_salg_noekkeltall">
                    <div class="fiq_gui_salg_tall">
                        <span class="fiq_gui_salg_verdi" t-esc="apneAntall"/>
                        <span class="fiq_gui_salg_merkelapp">Open opportunities</span>
                    </div>
                    <div class="fiq_gui_salg_tall">
                        <span class="fiq_gui_salg_verdi" t-esc="formatKr(apenVerdi)"/>
                        <span class="fiq_gui_salg_merkelapp">Expected revenue, open stages only</span>
                    </div>
                </div>

                <div class="fiq_gui_salg_stadier">
                    <t t-foreach="state.stadier" t-as="stadium" t-key="stadium.id">
                        <div class="fiq_gui_salg_rad"
                             t-att-class="stadium.avsluttet ? 'fiq_gui_salg_avsluttet' : ''"
                             t-on-click="() => this.apneStadium(stadium)">
                            <div class="fiq_gui_salg_radtopp">
                                <span class="fiq_gui_salg_stadienavn" t-esc="stadium.navn"/>
                                <span class="fiq_gui_salg_antall" t-esc="stadium.antall"/>
                            </div>
                            <div class="fiq_gui_salg_spor">
                                <div class="fiq_gui_salg_stolpe"
                                     t-attf-style="width:{{ stolpeBredde(stadium) }}"/>
                            </div>
                            <div class="fiq_gui_salg_radbunn" t-esc="formatKr(stadium.verdi)"/>
                        </div>
                    </t>
                </div>

                <!--
                  Kildemerknad. En flate som viser tall UTEN å si hvor de kommer fra,
                  er verre enn en tom flate: på Dev er dette demodata, og Gjermund kan
                  ikke skille det fra ekte tall. Finans gjør det riktig og sier rett ut
                  at datakildene ikke er koblet. Samme prinsipp som de grå boksene i
                  Kontrollrommet: en grå boks sier hva den ikke vet, en tom boks lyver.
                -->
                <div class="fiq_gui_salg_kilde">
                    Source: opportunities in this database (crm.lead). Open stages exclude
                    won and lost. Figures are live data — on a demo database they are demo figures.
                </div>
            </t>

        </div>
    </t>
</templates>
