<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="fiq_gui_relations.Flate">
        <div class="fiq-rel o_fiq_flate">

            <div t-if="state.laster" class="fiq-rel-melding">
                Loading relations…
            </div>

            <div t-elif="state.feil" class="fiq-rel-melding fiq-rel-feil">
                Relations could not be loaded. Try again, or say so if it persists.
            </div>

            <t t-else="">
                <div class="fiq-rel-verktoy">
                    <div class="fiq-rel-seg">
                        <button t-att-class="state.visning === 'kort' ? 'on' : ''"
                                t-on-click="() => this.byttVisning('kort')">Cards</button>
                        <button t-att-class="state.visning === 'graf' ? 'on' : ''"
                                t-on-click="() => this.byttVisning('graf')">Graph</button>
                    </div>
                    <button t-if="state.visning === 'graf'" class="btn btn-sm btn-light"
                            t-on-click="() => this.foldAlt(true)">Collapse all</button>
                    <button t-if="state.visning === 'graf'" class="btn btn-sm btn-light"
                            t-on-click="() => this.foldAlt(false)">Expand all</button>
                    <span class="fiq-rel-tall">
                        <t t-esc="state.noder.length"/> contacts ·
                        <t t-esc="state.kanter.length"/> relations
                    </span>
                </div>

                <div t-if="state.utenfor" class="fiq-rel-utenfor">
                    <strong><t t-esc="state.utenfor"/></strong>
                    <t t-if="state.utenfor === 1"> relation points</t>
                    <t t-else=""> relations point</t>
                    at companies you do not have access to, and are not shown here.
                    The graph below is therefore not the whole picture.
                </div>

                <div t-if="!state.noder.length" class="fiq-rel-melding">
                    No relations recorded yet. Add them on the contact form,
                    under the Relations tab.
                </div>

                <t t-if="state.visning === 'kort'">
                    <div t-if="!state.forvaltere.length and state.noder.length"
                         class="fiq-rel-melding">
                        No property managers recorded. A manager appears here once a
                        contact has a "manages" relation to a property.
                    </div>

                    <div t-if="state.forvaltere.length" class="fiq-rel-chips">
                        <button t-foreach="state.forvaltere" t-as="f" t-key="f.id"
                                class="fiq-rel-chip"
                                t-att-class="valgtForvalter and valgtForvalter.id === f.id ? 'on' : ''"
                                t-on-click="() => this.velgForvalter(f.id)">
                            <t t-esc="f.navn"/>
                            <span class="fiq-rel-cnt" t-esc="f.eiendommer.length"/>
                        </button>
                    </div>

                    <t t-if="valgtForvalter">
                        <div class="fiq-rel-fcard">
                            <span class="fiq-rel-badge-f">Manager</span>
                            <strong t-esc="valgtForvalter.navn"/>
                            <span t-if="valgtForvalter.kontakt" class="fiq-rel-kontakt">
                                <t t-esc="valgtForvalter.kontakt"/>
                                <t t-if="valgtForvalter.telefon">
                                    · <t t-esc="valgtForvalter.telefon"/>
                                </t>
                            </span>
                        </div>

                        <div class="fiq-rel-insight">
                            <span class="fiq-rel-i">i</span>
                            <p>
                                <strong><t t-esc="valgtForvalter.navn"/> manages, but does
                                not own.</strong>
                                The buildings below belong to others — invoicing and contact
                                go through the manager.
                            </p>
                        </div>

                        <div t-foreach="valgtForvalter.eiendommer" t-as="e" t-key="e.id"
                             class="fiq-rel-estate">
                            <div class="fiq-rel-ehead">
                                <strong t-esc="e.adresse"/>
                                <span t-if="e.eier" class="fiq-rel-eier">
                                    <span class="fiq-rel-lbl">owned by</span>
                                    <t t-esc="e.eier"/>
                                </span>
                            </div>
                            <div t-if="e.prosjekter.length" class="fiq-rel-prosjekter">
                                <span t-foreach="e.prosjekter" t-as="p" t-key="p.id"
                                      class="fiq-rel-pchip">
                                    <span t-if="p.nr" class="fiq-rel-pnr" t-esc="p.nr"/>
                                    <t t-esc="p.navn"/>
                                </span>
                            </div>
                            <div t-else="" class="fiq-rel-tomt">No projects on this property.</div>
                        </div>
                    </t>
                </t>

                <div t-if="state.visning === 'graf'" class="fiq-rel-grupper">
                    <div t-foreach="grupper" t-as="g" t-key="g.kind" class="fiq-rel-gruppe">
                        <div class="fiq-rel-gruppehode" t-on-click="() => this.vippFold(g.kind)">
                            <span class="fiq-rel-vipp">
                                <t t-esc="erFoldet(g.kind) ? '+' : '−'"/>
                            </span>
                            <span class="fiq-rel-gruppenavn" t-esc="g.navn"/>
                            <span class="fiq-rel-antall" t-esc="g.noder.length"/>
                        </div>

                        <div t-if="!erFoldet(g.kind)" class="fiq-rel-noder">
                            <div t-foreach="g.noder" t-as="n" t-key="n.id"
                                 class="fiq-rel-node"
                                 t-att-class="{ 'fiq-rel-valgt': state.valgt and state.valgt.id === n.id }"
                                 t-on-click="() => this.velg(n)">
                                <span class="fiq-rel-navn" t-esc="n.navn"/>
                                <span t-if="n.antall" class="fiq-rel-badge" t-esc="n.antall"/>
                            </div>
                        </div>
                    </div>
                </div>

                <div t-if="state.visning === 'graf' and state.valgt" class="fiq-rel-panel">
                    <div class="fiq-rel-panelhode">
                        <strong t-esc="state.valgt.navn"/>
                        <span class="fiq-rel-lukk" t-on-click="() => this.velg(state.valgt)">×</span>
                    </div>
                    <div t-if="!valgteRelasjoner.length" class="fiq-rel-tomt">
                        No relations to show for this contact.
                    </div>
                    <div t-foreach="valgteRelasjoner" t-as="r" t-key="r.id" class="fiq-rel-rad">
                        <span class="fiq-rel-type" t-esc="r.label"/>
                        <span class="fiq-rel-motpart" t-esc="r.partner_name"/>
                        <span t-if="r.periode" class="fiq-rel-periode" t-esc="r.periode"/>
                        <span t-if="!r.is_current" class="fiq-rel-avsluttet">ended</span>
                    </div>
                </div>
            </t>
        </div>
    </t>

</templates>
