<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fiq_gui_relation_list" model="ir.ui.view">
        <field name="name">fiq.gui.relation.list</field>
        <field name="model">fiq.gui.relation</field>
        <field name="arch" type="xml">
            <list string="Relations">
                <field name="partner_a_id"/>
                <field name="type_id"/>
                <field name="partner_b_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="is_current" widget="boolean_toggle" readonly="1"/>
                <field name="note" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_fiq_gui_relation_form" model="ir.ui.view">
        <field name="name">fiq.gui.relation.form</field>
        <field name="model">fiq.gui.relation</field>
        <field name="arch" type="xml">
            <form string="Relation">
                <sheet>
                    <group>
                        <!-- string= on a group is valid in a FORM view in Odoo 19.
                             It is only expand= in a SEARCH view that was removed. -->
                        <group string="Who">
                            <field name="partner_a_id"/>
                            <field name="type_id"/>
                            <field name="partner_b_id"/>
                        </group>
                        <group string="When">
                            <field name="date_start"/>
                            <field name="date_end" placeholder="Empty = ongoing"/>
                            <field name="is_current" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <group string="Note">
                        <field name="note" nolabel="1"
                               placeholder="For example the job title held through this affiliation"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fiq_gui_relation_search" model="ir.ui.view">
        <field name="name">fiq.gui.relation.search</field>
        <field name="model">fiq.gui.relation</field>
        <field name="arch" type="xml">
            <search string="Relations">
                <field name="partner_a_id"/>
                <field name="partner_b_id"/>
                <field name="type_id"/>
                <filter name="current" string="Current"
                        domain="[('is_current','=',True)]"/>
                <filter name="ended" string="Ended"
                        domain="[('is_current','=',False)]"/>
                <separator/>
                <filter name="archived" string="Archived"
                        domain="[('active','=',False)]"/>
                <!-- Bare <group> - expand= exists nowhere in Odoo 19 and breaks the build. -->
                <group>
                    <filter name="group_type" string="Relation"
                            context="{'group_by': 'type_id'}"/>
                    <filter name="group_a" string="From"
                            context="{'group_by': 'partner_a_id'}"/>
                    <filter name="group_b" string="To"
                            context="{'group_by': 'partner_b_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_fiq_gui_relation_type_list" model="ir.ui.view">
        <field name="name">fiq.gui.relation.type.list</field>
        <field name="model">fiq.gui.relation.type</field>
        <field name="arch" type="xml">
            <list string="Relation types" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="name_inverse"/>
                <field name="symmetric" widget="boolean_toggle"/>
                <field name="partner_a_kind"/>
                <field name="partner_b_kind"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_fiq_gui_relation" model="ir.actions.act_window">
        <field name="name">Relations</field>
        <field name="res_model">fiq.gui.relation</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Record a relation</p>
            <p>A relation links two contacts with a type, a direction and a period -
               so one person can belong to several companies at once, without being
               entered twice.</p>
        </field>
    </record>

    <record id="action_fiq_gui_relation_type" model="ir.actions.act_window">
        <field name="name">Relation types</field>
        <field name="res_model">fiq.gui.relation.type</field>
        <field name="view_mode">list</field>
    </record>

    <!-- Own door: the surface must be reachable without the control room, which would
         otherwise be a single point of failure. -->
    <menuitem id="menu_fiq_relations_root" name="Relations"
              parent="contacts.menu_contacts" sequence="30"/>
    <menuitem id="menu_fiq_relations" name="Relations"
              parent="menu_fiq_relations_root" action="action_fiq_gui_relation"
              sequence="10"/>
    <menuitem id="menu_fiq_relation_types" name="Relation types"
              parent="menu_fiq_relations_root" action="action_fiq_gui_relation_type"
              sequence="20" groups="base.group_partner_manager"/>

</odoo>
