<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- The relations live on the standard contact form. Test for every function:
         "does this work in native Odoo without the control room?" - here it does. -->
    <record id="view_partner_form_fiq_relations" model="ir.ui.view">
        <field name="name">res.partner.form.fiq.relations</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page name="fiq_relations" string="Relations">
                    <div class="alert alert-info" role="alert">
                        A contact can belong to several companies at once. Add an
                        affiliation here instead of creating another contact for the
                        same person - and when one ends, set an end date rather than
                        archiving the person.
                    </div>
                    <separator string="From this contact"/>
                    <field name="fiq_relation_a_ids" nolabel="1"
                           context="{'default_partner_a_id': id}">
                        <list editable="bottom">
                            <field name="type_id"/>
                            <field name="partner_b_id" string="To"/>
                            <field name="date_start"/>
                            <field name="date_end" placeholder="Ongoing"/>
                            <field name="note" optional="show"/>
                            <field name="is_current" widget="boolean_toggle" readonly="1"/>
                        </list>
                    </field>
                    <separator string="To this contact"/>
                    <field name="fiq_relation_b_ids" nolabel="1"
                           context="{'default_partner_b_id': id}">
                        <list editable="bottom">
                            <field name="partner_a_id" string="From"/>
                            <field name="type_id"/>
                            <field name="date_start"/>
                            <field name="date_end" placeholder="Ongoing"/>
                            <field name="note" optional="show"/>
                            <field name="is_current" widget="boolean_toggle" readonly="1"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>


    <!-- Absorbed from partner_short_name (Loym). Same placement as the source module
         used, so nothing moves for anyone already used to the field. -->
    <record id="view_partner_form_fiq_short_name" model="ir.ui.view">
        <field name="name">res.partner.form.fiq.short.name</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <span name="address_name" position="before">
                <field name="short_name"/>
            </span>
        </field>
    </record>

    <!-- Search-only fields exposed in the contact search view. Without this the
         fields exist but nothing can reach them: a filter nobody can find is the
         same as no filter. Bare <group> - expand= does not exist in Odoo 19. -->
    <record id="view_res_partner_filter_fiq_relations" model="ir.ui.view">
        <field name="name">res.partner.search.fiq.relations</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="fiq_search_relation_type_id"/>
                <field name="fiq_search_relation_partner_id"/>
                <field name="fiq_search_relation_date"/>
            </xpath>
        </field>
    </record>

</odoo>
