<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- is_current is a STORED compute that depends on today's date.
         A stored compute is recalculated when its dependencies change - and the calendar
         moving forward is not a dependency. Without this cron a relation that expired
         last night keeps reading "current" until something happens to touch the record.
         Searches and groupings would quietly return yesterday's truth. -->
    <data noupdate="1">
        <record id="cron_recompute_is_current" model="ir.cron">
            <field name="name">FIQ Relations: refresh current/ended</field>
            <field name="model_id" ref="model_fiq_gui_relation"/>
            <field name="state">code</field>
            <field name="code">model._cron_recompute_is_current()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
