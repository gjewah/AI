<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Generic starter catalogue (masterspec section C.2). Loaded as noupdate so a
         customer's own edits are never overwritten by a module upgrade.
         Branch-specific types (property management, construction) arrive as additional
         DATA in a later overlay - never as a customer fork of this module. -->
    <data noupdate="1">

        <record id="type_employee" model="fiq.gui.relation.type">
            <field name="code">employee</field>
            <field name="name">is employed by</field>
            <field name="name_inverse">employs</field>
            <field name="partner_a_kind">person</field>
            <field name="partner_b_kind">company</field>
            <field name="sequence">10</field>
        </record>

        <record id="type_general_manager" model="fiq.gui.relation.type">
            <field name="code">general_manager</field>
            <field name="name">is general manager of</field>
            <field name="name_inverse">has as general manager</field>
            <field name="partner_a_kind">person</field>
            <field name="partner_b_kind">company</field>
            <field name="sequence">20</field>
        </record>

        <record id="type_board_member" model="fiq.gui.relation.type">
            <field name="code">board_member</field>
            <field name="name">is board member of</field>
            <field name="name_inverse">has as board member</field>
            <field name="partner_a_kind">person</field>
            <field name="partner_b_kind">company</field>
            <field name="sequence">30</field>
        </record>

        <record id="type_owner" model="fiq.gui.relation.type">
            <field name="code">owner</field>
            <field name="name">owns</field>
            <field name="name_inverse">is owned by</field>
            <field name="sequence">40</field>
        </record>

        <record id="type_supplier" model="fiq.gui.relation.type">
            <field name="code">supplier</field>
            <field name="name">is supplier to</field>
            <field name="name_inverse">buys from</field>
            <field name="sequence">50</field>
        </record>

        <record id="type_subcontractor" model="fiq.gui.relation.type">
            <field name="code">subcontractor</field>
            <field name="name">is subcontractor for</field>
            <field name="name_inverse">has as subcontractor</field>
            <field name="sequence">60</field>
        </record>

        <record id="type_contact_person" model="fiq.gui.relation.type">
            <field name="code">contact_person</field>
            <field name="name">is contact person at</field>
            <field name="name_inverse">has as contact person</field>
            <field name="partner_a_kind">person</field>
            <field name="sequence">70</field>
        </record>

        <record id="type_property_manager" model="fiq.gui.relation.type">
            <field name="code">property_manager</field>
            <field name="name">manages</field>
            <field name="name_inverse">is managed by</field>
            <field name="sequence">80</field>
        </record>

        <record id="type_subsidiary" model="fiq.gui.relation.type">
            <field name="code">subsidiary</field>
            <field name="name">is a subsidiary of</field>
            <field name="name_inverse">has as subsidiary</field>
            <field name="partner_a_kind">company</field>
            <field name="partner_b_kind">company</field>
            <field name="sequence">90</field>
        </record>

        <record id="type_partner" model="fiq.gui.relation.type">
            <field name="code">partner</field>
            <field name="name">collaborates with</field>
            <field name="symmetric" eval="True"/>
            <field name="sequence">100</field>
        </record>

    </data>
</odoo>
