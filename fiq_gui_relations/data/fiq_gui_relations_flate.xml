<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Self-registration in the control room menu (mechanism verified in
         fiq_gui_control_config.py:1243 get_fiq_flater).

         The module declares itself with ONE parameter; the control room discovers it.
         fiq_gui_control is NOT touched here - the reader picks up the prefix regardless
         of which module shipped the key, so no cross-module edit is needed.

         The value must be valid JSON with an "xmlid" that resolves in this database.
         Both failures are logged rather than silent (fixed 18.07.2026), but a typo still
         means an invisible surface - so the JSON is validated before push, not eyeballed.

         label in English; Norwegian arrives via i18n, never hardcoded in module source.

         noupdate="0" deliberately: the label and sequence SHOULD follow the module when
         it is upgraded. This is a declaration about the module itself, not customer data. -->
    <data>
        <record id="flate_relations" model="ir.config_parameter">
            <field name="key">fiq_gui_control.flate.relations</field>
            <field name="value">{"label": "Relations", "xmlid": "fiq_gui_relations.action_fiq_gui_relation", "sequence": 70}</field>
        </record>
    </data>
</odoo>
