<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
      Selvregistrering i Kontrollrom-menyen (KR v6.82-mekanismen).

      Modulen var installert (19.0.2.3.0) og hadde en fungerende handling
      (`fiq_gui_ai_kr.action_fiq_ai_kr`) + eget native menypunkt — men ingen dør INN fra
      KR-menyen. Derfor opplevdes AI KR som «ikke klar» uansett hva som ble levert.

      MODULEN MELDER SEG INN SELV — KR-modulen røres ikke. `fiq_gui_control/data/
      fiq_gui_control_flater.xml` sier det uttrykkelig: «En NY modul trenger ikke røre denne
      fila heller — den kan sende med sin egen ir.config_parameter fra sitt eget data/.»
      Verifisert i `get_fiq_flater()` (fiq_gui_control_config.py:1240): den leser ALLE nøkler
      med prefikset uansett hvilken modul de kommer fra.

      Sikkerhet: `env.ref(xmlid, raise_if_not_found=False)` dropper linja hvis handlingen ikke
      finnes i basen -> aldri et dødt menypunkt i en tenant som ikke har modulen.

      ⚠️ Dette er SERVER-SIDE KR-meny (ir.config_parameter) — en ANNEN mekanisme enn skallets
      nettleser-registry «fiq_gui_flates». Ikke bland dem.

      Språk: `label` er ENGELSK i kilden (som de fem eksisterende oppføringene) — norsk kommer
      via i18n/*.po. Aldri hardkod norsk i modulkilde.
    -->
    <data noupdate="0">

        <record id="flate_ai_kr" model="ir.config_parameter">
            <field name="key">fiq_gui_control.flate.ai_kr</field>
            <field name="value">{"label": "AI control room", "xmlid": "fiq_gui_ai_kr.action_fiq_ai_kr", "sequence": 30}</field>
        </record>

    </data>
</odoo>
