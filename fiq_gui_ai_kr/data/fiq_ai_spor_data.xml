<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
      SPORENE SOM FAKTISK FINNES — verifisert mot git + fiqas Staging 19.07.2026.
      Ikke oppdiktet: hver `modul` er en modul som eksisterer i gjewah/AI.

      `noupdate="1"`: Gjermund (eller en økt) kan endre status og milepæl fritt uten at
      en modul-oppgradering overskriver det. Seeden gir startpunktet, ikke fasiten for alltid.

      Milepælen bumpes AUTOMATISK 00 → 01 av `sjekk_milepaeler()` når modulen står
      `installed` i basen. Derfor settes versjon_hoved = 0 her selv for moduler som ER
      installert — cron-en retter det ved første kjøring, og da er tallet MÅLT, ikke påstått.
    -->
    <data noupdate="1">

        <record id="spor_ai_kr" model="fiq.ai.spor">
            <field name="name">AI Kontrollrom</field>
            <field name="kode">AI KR</field>
            <field name="modul">fiq_gui_ai_kr</field>
            <field name="beskrivelse">Operatør-cockpit: øktregister, samlebokser fra hvert rom, AI-organisasjonskart, forbruk og ROI.</field>
            <field name="status">bygges</field>
        </record>

        <record id="spor_kr_kjerne" model="fiq.ai.spor">
            <field name="name">Kontrollrom-kjernen</field>
            <field name="kode">KR</field>
            <field name="modul">fiq_gui_control</field>
            <field name="beskrivelse">KR-kjernen: meny, selvregistrering av flater, firma-scope, rettigheter. Laget alle andre flater plugger seg inn i.</field>
            <field name="status">bygges</field>
        </record>

        <record id="spor_prosjekt" model="fiq.ai.spor">
            <field name="name">Prosjekt</field>
            <field name="kode">PRJ</field>
            <field name="modul">fiq_gui_prj</field>
            <field name="beskrivelse">Prosjektoversikt (WBS-tre med timer mot budsjett), disposisjonsnummer, generisk sjekkliste-motor.</field>
            <field name="status">bygges</field>
        </record>

        <record id="spor_kommunikasjon" model="fiq.ai.spor">
            <field name="name">Kommunikasjon</field>
            <field name="kode">KOMM</field>
            <field name="modul">fiq_gui_comm</field>
            <field name="beskrivelse">Kommunikasjon som paraply; e-post er en kanal inne i den. Paring mot prosjekt/oppgave.</field>
            <field name="status">bygges</field>
        </record>

        <record id="spor_finans" model="fiq.ai.spor">
            <field name="name">Finans</field>
            <field name="kode">FIN</field>
            <field name="modul">fiq_gui_fin</field>
            <field name="beskrivelse">Finans-flate: forfalt, haster, likviditet. Regnskap (RGS) er undermeny under denne.</field>
            <field name="status">bygges</field>
        </record>

        <record id="spor_regnskap" model="fiq.ai.spor">
            <field name="name">Regnskap</field>
            <field name="kode">RGS</field>
            <field name="modul">fiq_gui_rgs</field>
            <field name="beskrivelse">Regnskapsbilde fra account.move: inngående, utgående, forfalte poster. Kun lesing.</field>
            <field name="status">bygges</field>
        </record>

        <record id="spor_relasjoner" model="fiq.ai.spor">
            <field name="name">Relasjoner</field>
            <field name="kode">REL</field>
            <field name="modul">fiq_gui_relations</field>
            <field name="beskrivelse">Relasjonsmodell: forvalter ≠ eier ≠ ansvarlig. Rolle- og rettighetssporet.</field>
            <field name="status">bygges</field>
        </record>

        <record id="spor_skall" model="fiq.ai.spor">
            <field name="name">Skall</field>
            <field name="kode">SHELL</field>
            <field name="modul">fiq_gui_shell</field>
            <field name="beskrivelse">Delt skall (Vei C): fast chrome + innmat-slot. Flate-registeret i nettleseren.</field>
            <field name="status">bygges</field>
        </record>

        <!--
          🔴 SALG/CRM: tre moduler står som TOMME «Kommer»-skall og har vært urørt
          siden 09.07.2026 — ti dager, uten eier. Funnet i dypdykket 19.07.
          Sporet opprettes her nettopp for at hullet skal være SYNLIG i AI KR
          i stedet for å ligge usett i git.
        -->
        <record id="spor_salg" model="fiq.ai.spor">
            <field name="name">Salg</field>
            <field name="kode">SALG</field>
            <field name="modul">fiq_gui_crm</field>
            <field name="beskrivelse">🔴 UTEN EIER. Leads, salgsmuligheter, mail inn/ut per mulighet, hvem trenger oppfølging. Modulen er et tomt «Kommer»-skall (16 linjer JS), urørt siden 09.07.2026.</field>
            <field name="status">planlagt</field>
        </record>

        <record id="spor_befaring" model="fiq.ai.spor">
            <field name="name">Befaring</field>
            <field name="kode">BEF</field>
            <field name="modul">fiq_befaring</field>
            <field name="beskrivelse">Mobil befaringsflyt: prosjekt → leilighet → rom → foto/tilstand/tiltak → romskjema → tilbud. Byggeeier uavklart (hull H5).</field>
            <field name="status">planlagt</field>
        </record>

    </data>
</odoo>
