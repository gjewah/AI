<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
      AI PROSJEKTSPOR — den varige enheten. Økter er arbeidsperioder inne i et spor.
      Gjermund 19.07.2026: «Jeg ser ikke på dette som økter men som prosjekter.»
      KANON «Odoo-native først»: sporet skal virke i Odoos egne visninger uten KR.
    -->

    <record id="view_fiq_ai_spor_list" model="ir.ui.view">
        <field name="name">fiq.ai.spor.list</field>
        <field name="model">fiq.ai.spor</field>
        <field name="arch" type="xml">
            <list string="AI Prosjektspor" decoration-success="status == 'godkjent'"
                  decoration-muted="status == 'planlagt'">
                <field name="versjon" string="Ver."/>
                <field name="kode"/>
                <field name="name"/>
                <field name="modul" optional="show"/>
                <field name="modul_installert" string="I Odoo" optional="show"/>
                <field name="modul_versjon" string="Modulver." optional="show"/>
                <field name="aktive_okter" string="Aktive"/>
                <field name="antall_okter" string="Økter"/>
                <field name="status" widget="badge"
                       decoration-success="status in ('produksjon','godkjent')"
                       decoration-info="status == 'i_odoo'"
                       decoration-warning="status == 'bygges'"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_fiq_ai_spor_form" model="ir.ui.view">
        <field name="name">fiq.ai.spor.form</field>
        <field name="model">fiq.ai.spor</field>
        <field name="arch" type="xml">
            <form string="AI Prosjektspor">
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="planlagt,bygges,i_odoo,testet,produksjon,godkjent"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="versjon" readonly="1" class="oe_inline"/>
                            <field name="name" placeholder="F.eks. AI Kontrollrom" class="oe_inline"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="kode" placeholder="AI KR"/>
                            <field name="modul" placeholder="fiq_gui_ai_kr"/>
                            <field name="modul_installert" string="Står i Odoo"/>
                            <field name="modul_versjon"/>
                        </group>
                        <group>
                            <!-- 00 = ikke i Odoo · 01 = står og virker (auto-detektert) -->
                            <field name="versjon_hoved" string="Milepæl"/>
                            <field name="versjon_lop" string="Løpenr"/>
                            <field name="aktive_okter" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <field name="beskrivelse" placeholder="Hva sporet leverer …"/>
                    <notebook>
                        <page string="Økter i sporet">
                            <field name="okt_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="spor_visning" string="Spor"/>
                                    <field name="status" widget="badge"/>
                                    <field name="sist_aktiv"/>
                                    <field name="sammendrag" optional="show"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fiq_ai_spor_search" model="ir.ui.view">
        <field name="name">fiq.ai.spor.search</field>
        <field name="model">fiq.ai.spor</field>
        <field name="arch" type="xml">
            <search string="AI Prosjektspor">
                <field name="name"/>
                <field name="kode"/>
                <field name="modul"/>
                <filter name="i_odoo" string="Står i Odoo" domain="[('versjon_hoved','&gt;=',1)]"/>
                <filter name="ikke_i_odoo" string="Ikke i Odoo ennå" domain="[('versjon_hoved','=',0)]"/>
                <separator/>
                <filter name="har_aktive" string="Har aktive økter" domain="[('aktive_okter','&gt;',0)]"/>
                <!-- Odoo 19: <group> i søkevisning tar hverken expand= eller string=. -->
                <group>
                    <filter name="g_status" string="Status" context="{'group_by':'status'}"/>
                    <filter name="g_milepael" string="Milepæl" context="{'group_by':'versjon_hoved'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_fiq_ai_spor" model="ir.actions.act_window">
        <field name="name">AI Prosjektspor</field>
        <field name="res_model">fiq.ai.spor</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Ingen prosjektspor ennå</p>
            <p>Sporet er den varige enheten — økter er arbeidsperioder inne i et spor.
               Milepælen bumpes automatisk fra 00 til 01 når modulen står i Odoo.</p>
        </field>
    </record>

    <menuitem id="menu_fiq_ai_spor"
              name="Prosjektspor"
              parent="menu_fiq_ai_kr_root"
              action="action_fiq_ai_spor"
              sequence="15"/>

    <!--
      Milepæl-sjekk: bumper 00 → 01 for spor der modulen nå faktisk står i Odoo.
      Automatisk detektert (Gjermunds valg 19.07) — ingen manuell bokføring.
      Videre milepæler (testet/production/godkjent) er Gjermunds beslutning.
    -->
    <record id="cron_fiq_ai_spor_milepael" model="ir.cron">
        <field name="name">AI Prosjektspor: sjekk milepæler</field>
        <field name="model_id" ref="model_fiq_ai_spor"/>
        <field name="state">code</field>
        <field name="code">model.sjekk_milepaeler()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
