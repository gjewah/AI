<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
      STYRINGSFLATEN — «Alternativ Visning» i AI KR.
      Gjermund 22.07.2026: «bør bli en Alternativ Visning for FIQ GUI KR …
      innlemmes i menyen for GUI AI KR ASAP. Den fungerer til alt er oppe.»

      Egen handling = egen ramme. AI KR er et EGET kontrollrom, og styringssiden
      er en visning INNE i det — ikke en flate i skallet til noen andre.
    -->
    <data>

        <record id="action_fiq_ai_styring" model="ir.actions.client">
            <field name="name">Styring</field>
            <field name="tag">fiq_ai_styring</field>
        </record>

        <!-- Menypunkt under AI Kontrollrom-roten, ved siden av de øvrige. -->
        <menuitem id="menu_fiq_ai_styring"
                  name="Styring"
                  parent="menu_fiq_ai_kr_root"
                  action="action_fiq_ai_styring"
                  sequence="5"/>

        <!--
          Selvregistrering i KR-menyen (v6.82-mekanismen), nøkkel godkjent av
          AI PK 22.07: `ai_styring`.

          ⚠️ Dette er SERVER-SIDE KR-meny (ir.config_parameter) — en ANNEN
          mekanisme enn skallets nettleser-registry. Bland dem aldri: AI KR
          skal IKKE registreres i `fiq_gui_flates`, for da mister flaten sin
          egen ramme (Gjermund fanget nettopp det i nettleser 22.07).
        -->
        <record id="flate_ai_styring" model="ir.config_parameter">
            <field name="key">fiq_gui_control.flate.ai_styring</field>
            <field name="value">{"label": {"en_US": "Management", "nb_NO": "Styring"}, "xmlid": "fiq_gui_ai_kr.action_fiq_ai_styring", "sequence": 31}</field>
        </record>

    </data>
</odoo>
