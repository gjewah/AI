<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
      KANON «Odoo-native først» (Gjermund 2026-07-16): KR er et LAG, ikke systemet.
      Testen: «Virker dette i native Odoo uten KR?»
      `fiq.ai.okt` fantes som modell + data-metoder, men UTEN egne views -> øktregisteret
      var usynlig i Odoo uten KR-flaten. Rettet her.

      TVILLING-PRINSIPPET: dette er brain/okt_register.md som LEVENDE Odoo-tabell.
      Claude fører den selv via registrer_okt() — Gjermund rører den aldri.
    -->

    <record id="view_fiq_ai_okt_list" model="ir.ui.view">
        <field name="name">fiq.ai.okt.list</field>
        <field name="model">fiq.ai.okt</field>
        <field name="arch" type="xml">
            <list string="AI-økter"
                  decoration-success="status == 'aktiv'"
                  decoration-muted="status == 'ferdig'"
                  decoration-danger="status == 'feilet'">
                <field name="name"/>
                <field name="okt_ref" optional="show"/>
                <field name="kilde"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'aktiv'"
                       decoration-warning="status == 'pause'"
                       decoration-danger="status == 'feilet'"/>
                <field name="task_id" optional="show"/>
                <field name="sist_aktiv"/>
                <field name="start" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_fiq_ai_okt_form" model="ir.ui.view">
        <field name="name">fiq.ai.okt.form</field>
        <field name="model">fiq.ai.okt</field>
        <field name="arch" type="xml">
            <form string="AI-økt">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Øktnavn"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="okt_ref"/>
                            <field name="kilde"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="task_id"/>
                            <field name="start"/>
                            <field name="sist_aktiv"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Hva økta gjør">
                        <field name="sammendrag" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fiq_ai_okt_search" model="ir.ui.view">
        <field name="name">fiq.ai.okt.search</field>
        <field name="model">fiq.ai.okt</field>
        <field name="arch" type="xml">
            <search string="AI-økter">
                <field name="name"/>
                <field name="okt_ref"/>
                <field name="task_id"/>
                <filter name="f_aktiv" string="Aktive" domain="[('status','=','aktiv')]"/>
                <filter name="f_pause" string="På pause" domain="[('status','=','pause')]"/>
                <filter name="f_feilet" string="Feilet" domain="[('status','=','feilet')]"/>
                <separator/>
                <!-- Odoo 19s egen relative dato-syntaks (verifisert i addons:
                     domain="[('last_connection_datetime', '>', '-7d')]").
                     Mitt første forsøk brukte context_today() - datetime.timedelta(...) —
                     det mønsteret finnes IKKE i Odoos egne views. Rettet. -->
                <filter name="f_stille" string="Stille &gt; 1 døgn"
                        domain="[('sist_aktiv','&lt;','-1d')]"
                        help="Økter uten aktivitet siste døgn — kandidat for etterlysning."/>
                <group expand="0" string="Grupper etter">
                    <filter name="g_status" string="Status" context="{'group_by':'status'}"/>
                    <filter name="g_kilde" string="Kilde" context="{'group_by':'kilde'}"/>
                    <filter name="g_firma" string="Firma" context="{'group_by':'company_id'}"/>
                    <filter name="g_sist" string="Sist aktiv" context="{'group_by':'sist_aktiv:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_fiq_ai_okt" model="ir.actions.act_window">
        <field name="name">AI-økter</field>
        <field name="res_model">fiq.ai.okt</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_f_aktiv': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Ingen økter registrert ennå</p>
            <p>Claude fører dette registeret selv ved hvert checkpoint — du rører det aldri.</p>
        </field>
    </record>

    <!-- Under «AI Kontrollrom»-roten: synlig i native Odoo, uten KR-flaten -->
    <menuitem id="menu_fiq_ai_okt"
              name="AI-økter"
              parent="menu_fiq_ai_kr_root"
              action="action_fiq_ai_okt"
              sequence="20"/>
</odoo>
