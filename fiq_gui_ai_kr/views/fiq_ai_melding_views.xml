<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
      AI-MELDINGER — Gjermund 19.07.2026: all AI-kommunikasjon skal ha en egen flate,
      og være tilgjengelig for alle brukere i Meldingssenteret.
      KANON «Odoo-native først»: dette virker i Odoos egne visninger uten KR.
    -->

    <record id="view_fiq_ai_melding_list" model="ir.ui.view">
        <field name="name">fiq.ai.melding.list</field>
        <field name="model">fiq.ai.melding</field>
        <field name="arch" type="xml">
            <list string="AI-meldinger"
                  decoration-danger="krever_svar and not besvart and viktighet == 'haster'"
                  decoration-warning="krever_svar and not besvart and viktighet != 'haster'"
                  decoration-muted="filtrert_bort">
                <field name="sendt"/>
                <field name="alder" string="Alder"/>
                <field name="fra_navn" string="Fra"/>
                <field name="til_navn" string="Til" optional="show"/>
                <field name="name" string="Emne"/>
                <field name="type_melding" widget="badge" optional="show"/>
                <field name="viktighet" widget="badge"
                       decoration-danger="viktighet == 'haster'"
                       decoration-warning="viktighet == 'i_dag'"/>
                <field name="krever_svar" string="Krever svar"/>
                <field name="besvart"/>
                <field name="filtrert_bort" string="Filtrert" optional="hide"/>
                <field name="bruker_id" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_fiq_ai_melding_form" model="ir.ui.view">
        <field name="name">fiq.ai.melding.form</field>
        <field name="model">fiq.ai.melding</field>
        <field name="arch" type="xml">
            <form string="AI-melding">
                <header>
                    <button name="marker_besvart" type="object" string="Marker besvart"
                            class="btn-primary" invisible="besvart or not krever_svar"/>
                    <field name="viktighet" widget="statusbar"
                           statusbar_visible="haster,i_dag,orientering"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Emne …"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="fra_navn"/>
                            <field name="til_navn"/>
                            <field name="type_melding"/>
                            <field name="bruker_id"/>
                        </group>
                        <group>
                            <field name="sendt"/>
                            <field name="alder"/>
                            <field name="krever_svar"/>
                            <field name="besvart"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <!-- Filtrert bort = nedprioritert, ALDRI slettet. Grunnen skal stå
                         synlig, så en feilvurdering kan oppdages og rettes. -->
                    <group string="Postmesterens vurdering" invisible="not filtrert_bort">
                        <field name="filtrert_bort"/>
                        <field name="filtrert_grunn"/>
                    </group>
                    <group>
                        <field name="fra_spor_id"/>
                        <field name="til_spor_id"/>
                    </group>
                    <field name="innhold" placeholder="Melding …"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_fiq_ai_melding_search" model="ir.ui.view">
        <field name="name">fiq.ai.melding.search</field>
        <field name="model">fiq.ai.melding</field>
        <field name="arch" type="xml">
            <search string="AI-meldinger">
                <field name="name"/>
                <field name="fra_navn"/>
                <field name="til_navn"/>
                <field name="innhold"/>
                <filter name="mine" string="Mine"
                        domain="[('bruker_id','=',uid)]"/>
                <filter name="krever_svar" string="Venter svar"
                        domain="[('krever_svar','=',True),('besvart','=',False)]"/>
                <filter name="haster" string="Haster" domain="[('viktighet','=','haster')]"/>
                <separator/>
                <!-- Filtrerte er SKJULT som standard, men ett klikk unna. Aldri tapt. -->
                <filter name="vis_filtrerte" string="Vis filtrerte"
                        domain="[('filtrert_bort','=',True)]"/>
                <!-- Odoo 19: <group> i søkevisning tar hverken expand= eller string=. -->
                <group>
                    <filter name="g_type" string="Type" context="{'group_by':'type_melding'}"/>
                    <filter name="g_vikt" string="Viktighet" context="{'group_by':'viktighet'}"/>
                    <filter name="g_fra" string="Fra" context="{'group_by':'fra_navn'}"/>
                    <filter name="g_spor" string="Spor" context="{'group_by':'fra_spor_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_fiq_ai_melding" model="ir.actions.act_window">
        <field name="name">AI-meldinger</field>
        <field name="res_model">fiq.ai.melding</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_krever_svar': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Ingen AI-meldinger ennå</p>
            <p>Her samles kommunikasjonen mellom AI-økter, rådgivere og deg — og dine
               egne forespørsler til AI.</p>
        </field>
    </record>

    <menuitem id="menu_fiq_ai_melding"
              name="AI-meldinger"
              parent="menu_fiq_ai_kr_root"
              action="action_fiq_ai_melding"
              sequence="18"/>
</odoo>
