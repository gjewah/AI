<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<!--
  STYRINGSFLATEN — fase 1. Fasit: artifact 72aae7c9.
  Gjermunds språkregler gjelder: Stor Forbokstav i overskrifter, hvit uthevet
  skrift på fargede flater (grå tekst er avvist), DEV/Staging/Production som
  egennavn, «Oppdatere» ikke «bygge».
-->
<t t-name="fiq_gui_ai_kr.Styring">
  <div class="aistyr">

    <div t-if="state.laster" class="styr_laster">Henter arbeidet …</div>

    <t t-else="">
      <!-- Egen ramme. AI KR er et EGET kontrollrom, ikke innmat i et annet. -->
      <div class="styr_topp">
        <div class="styr_merke">AI</div>
        <div class="styr_navn">
          <div class="styr_eb">FIQ AI · Kontrollrom</div>
          <h1>Styring</h1>
        </div>
        <span class="styr_fyll"/>
        <label class="styr_bryter">
          <input type="checkbox" t-att-checked="state.skjul_ferdig"
                 t-on-change="() => this.vekslFerdig()"/>
          Skjul Ferdige
        </label>
        <button class="styr_ub" t-on-click="() => this.tilbake()">‹ AI Kontrollrom</button>
      </div>

      <!-- STADIE-PILLER. Gjermunds egne farger; hvit uthevet skrift oppå. -->
      <div class="styr_stadier">
        <button t-foreach="state.stadier" t-as="s" t-key="s.kode"
                t-att-class="'styr_pille' + (state.stadiefilter === s.kode ? ' valgt' : '')"
                t-attf-style="background:{{s.farge}}"
                t-on-click="() => this.filtrerStadium(s.kode)">
          <span t-esc="s.navn"/>
          <b t-esc="s.antall"/>
        </button>
      </div>

      <!-- AI-SPØRSMÅL. Fasitens gule felt = godkjenningskøen (fiq.ai.godkjenning).
           «Hvem spør, spørsmålet, og HVORFOR det betyr noe.» -->
      <div t-if="state.sporsmaal.length" class="styr_spm_bolk">
        <h2 class="styr_h2">Venter På Deg</h2>
        <div t-foreach="state.sporsmaal" t-as="q" t-key="q.id" class="styr_spm">
          <div class="styr_spm_fra">
            <span t-esc="q.kilde_tekst"/>
            <span t-if="q.spor" class="styr_spor" t-esc="q.spor"/>
            <span t-if="q.alder" class="styr_alder" t-esc="q.alder"/>
          </div>
          <p class="styr_spm_tekst" t-esc="q.sporsmaal"/>
          <p t-if="q.detalj" class="styr_spm_hvorfor" t-esc="q.detalj"/>

          <textarea class="styr_felt" placeholder="Forbehold — kreves ved «Ja, men …»"
                    t-att-value="state.svarUtkast[q.id] or ''"
                    t-on-input="(ev) => state.svarUtkast[q.id] = ev.target.value"/>

          <div class="styr_knapper">
            <button t-foreach="q.knapper" t-as="k" t-key="k.valg"
                    t-attf-class="styr_svar styr_{{k.farge}}"
                    t-att-disabled="k.valg === 'alltid' and not q.kan_alltid"
                    t-att-title="k.valg === 'alltid' and not q.kan_alltid
                                 ? 'Dette spørsmålet kan ikke huskes — det mangler en nøkkel'
                                 : ''"
                    t-on-click="() => this.svar(q, k.valg)">
              <t t-esc="k.tekst"/>
            </button>
          </div>
        </div>
      </div>

      <!-- OPPGAVELISTE -->
      <h2 class="styr_h2">
        Arbeidet
        <span class="styr_tell" t-esc="this.synlige.length"/>
      </h2>

      <div t-if="!this.synlige.length" class="styr_tom">
        <b t-if="state.stadiefilter">Ingen oppgaver i dette stadiet.</b>
        <b t-else="">Ingen oppgaver ennå.</b>
      </div>

      <div t-foreach="this.synlige" t-as="o" t-key="o.id" class="styr_rad"
           t-on-click="() => this.apne(o)">
        <span class="styr_stmerke" t-attf-style="background:{{this.stadieFarge(o.stadium)}}"
              t-esc="o.stadium_navn or '—'"/>
        <span class="styr_nr" t-esc="o.nr"/>
        <span class="styr_tittel" t-esc="o.navn"/>
        <span t-if="o.spor" class="styr_spor" t-esc="o.spor"/>
        <span t-attf-class="styr_eier {{o.er_ai ? 'ai' : ''}}" t-esc="o.eier"/>
        <span t-if="o.firma" class="styr_firma" t-esc="o.firma"/>
        <span t-if="o.frist" class="styr_frist" t-esc="o.frist"/>
        <span t-if="o.kommentarer" class="styr_komm" t-esc="o.kommentarer"/>
      </div>
    </t>

    <!-- OPPGAVEPANEL: stadier + beskrivelse + kommentarlogg -->
    <div t-if="state.valgt" class="styr_overlegg" t-on-click="() => this.lukk()">
      <div class="styr_panel" t-on-click.stop="">
        <div class="styr_p_topp">
          <div>
            <div class="styr_p_nr" t-esc="state.valgt.nr"/>
            <h3 t-esc="state.valgt.navn"/>
          </div>
          <button class="styr_x" t-on-click="() => this.lukk()">✕</button>
        </div>

        <!-- Stadiene, klikkbare. Dette ER flyttingen Gjermund ba om. -->
        <div class="styr_p_stadier">
          <button t-foreach="state.stadier" t-as="s" t-key="s.kode"
                  t-att-class="'styr_stg' + (state.valgt.stadium === s.kode ? ' aktiv' : '')"
                  t-attf-style="{{state.valgt.stadium === s.kode ? 'background:' + s.farge : ''}}"
                  t-on-click="() => this.flytt(state.valgt, s.kode)">
            <t t-esc="s.navn"/>
          </button>
        </div>

        <div class="styr_p_meta">
          <span t-if="state.valgt.firma">Lagres i <b t-esc="state.valgt.firma"/></span>
          <span t-if="state.valgt.eier">Eier: <b t-esc="state.valgt.eier"/></span>
          <span t-if="state.valgt.frist">Frist: <b t-esc="state.valgt.frist"/></span>
        </div>

        <div t-if="state.valgt.beskrivelse" class="styr_p_besk">
          <t t-out="state.valgt.beskrivelse"/>
        </div>

        <!-- KOMMENTARLOGG: Odoos egen chatter. Nye legger seg til, gamle blir stående. -->
        <div class="styr_logg">
          <h4>Logg</h4>
          <div t-if="!state.logg.length" class="styr_tom_liten">Ingen kommentarer ennå.</div>
          <div t-foreach="state.logg" t-as="l" t-key="l.id" class="styr_l">
            <div class="styr_l_hode">
              <b t-esc="l.fra"/>
              <span t-esc="l.naar"/>
            </div>
            <div class="styr_l_tekst"><t t-out="l.tekst"/></div>
            <div t-if="l.bilder.length" class="styr_l_bilder">
              <img t-foreach="l.bilder" t-as="b" t-key="b.id"
                   t-att-src="b.url" t-att-alt="b.navn"/>
            </div>
          </div>

          <div class="styr_skriv">
            <textarea placeholder="Skriv en kommentar …"
                      t-att-value="state.nyKommentar"
                      t-on-input="(ev) => state.nyKommentar = ev.target.value"/>
            <button class="styr_send" t-on-click="() => this.skrivKommentar()">Send</button>
          </div>
        </div>

        <div class="styr_p_bunn">
          <button class="styr_ub" t-on-click="() => this.aapneOdoo(state.valgt.id)">
            Åpne i Odoo
          </button>
        </div>
      </div>
    </div>

  </div>
</t>

</templates>
