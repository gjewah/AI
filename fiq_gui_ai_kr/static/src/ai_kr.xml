<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="fiq_gui_ai_kr.AiKr">
        <div class="aikr">
            <div t-if="state.loading" class="loading">Laster AI Kontrollrom…</div>
            <t t-else="">
                <!-- Topplinje -->
                <div class="top">
                    <div class="logo">AI</div>
                    <div class="brand">
                        <div class="eb">FIQ Kontrollrom · 8.50 AI</div>
                        <div class="ti">AI Kontrollrom</div>
                    </div>
                    <div class="sp"/>
                    <div class="tabs">
                        <button t-att-class="state.view==='oppgaver'?'on':''" t-on-click="() => this.settFane('oppgaver')">Oppgaver</button>
                        <button t-att-class="state.view==='spor'?'on':''" t-on-click="() => this.settFane('spor')">Prosjektspor</button>
                        <button t-att-class="state.view==='okter'?'on':''" t-on-click="() => this.settFane('okter')">Øktregister</button>
                        <button t-att-class="state.view==='org'?'on':''" t-on-click="() => this.settFane('org')">Org-kart</button>
                    </div>
                    <button class="ubtn kr" t-on-click="tilbakeKR">‹ Kontrollrom</button>
                </div>

                <!-- OPPGAVER -->
                <div t-if="state.view==='oppgaver'">

                    <!--
                      SAMLEBOKSER — «hva haster hvor», én boks per flate.
                      Gjermund 19.07.2026: «5 saker som haster på finans og tre i dag vises
                      som en boks i KR; trykker jeg på den kommer jeg inn i finans.»
                      Kravspek kontrollrom_spec.md: Pulse-laget («3 KPI + hva haster»).
                      Ro-budsjett: tall, ikke varsler. Ingen popup, ingen masing.
                    -->
                    <div t-if="state.bokser.length" class="bokser">
                        <div t-foreach="state.bokser" t-as="b" t-key="b.key"
                             t-att-class="'boks ' + b.farge"
                             t-on-click="() => this.apneFlate(b)">
                            <div class="boks_topp">
                                <span class="boks_navn" t-esc="b.label"/>
                                <span class="boks_pil">›</span>
                            </div>
                            <div class="boks_tall">
                                <span t-if="b.haster" class="tall haster">
                                    <b t-esc="b.haster"/> haster
                                </span>
                                <span t-if="b.i_dag" class="tall i_dag">
                                    <b t-esc="b.i_dag"/> i dag
                                </span>
                                <span t-if="!b.haster and !b.i_dag" class="tall rolig">
                                    <b t-esc="b.totalt"/> åpne
                                </span>
                            </div>
                            <div t-if="b.linjer.length" class="boks_linjer">
                                <div t-foreach="b.linjer" t-as="l" t-key="l_index"
                                     class="boks_linje" t-esc="l.tekst"/>
                            </div>
                        </div>
                    </div>
                    <!-- Draghåndtak: styrer boksbredden. Samme mønster som Meldingssenteret. -->
                    <div t-if="state.bokser.length" class="boks_drag_rad">
                        <span class="boks_drag" title="Dra for å endre bredden på boksene"
                              t-on-pointerdown="startDragBoks"/>
                    </div>

                    <div class="filters">
                        <label><input type="checkbox" t-att-checked="state.skjul_ferdig" t-on-change="() => this.veksle('skjul_ferdig')"/> Skjul fullførte</label>
                        <label><input type="checkbox" t-att-checked="state.skjul_kansellert" t-on-change="() => this.veksle('skjul_kansellert')"/> Skjul kansellerte</label>
                        <label><input type="checkbox" t-att-checked="state.kun_kunde" t-on-change="() => this.veksle('kun_kunde')"/> Kun kundeprosjekter</label>
                        <span class="sp"/>
                        <span class="tot">Ferdig <b t-esc="state.oppg.tot.pct || 0"/>% · <t t-esc="state.oppg.tot.tot || 0"/> oppgaver</span>
                    </div>

                    <div t-if="state.oppg.krever.length" class="krever">
                        <h4>Krever handling</h4>
                        <button t-foreach="state.oppg.krever" t-as="k" t-key="k.id" class="kchip" t-on-click="() => this.aapne(k)">
                            <span t-att-class="k.over?'over':''" t-esc="k.name"/>
                            <span class="frist" t-if="k.frist" t-esc="k.frist"/>
                        </button>
                    </div>

                    <div t-if="!state.oppg.groups.length" class="empty">Ingen prosjekter matcher filtrene.</div>
                    <div t-foreach="state.oppg.groups" t-as="g" t-key="g.id" class="grp">
                        <div class="ghead">
                            <span class="gno" t-esc="g.no"/><span class="gnm" t-esc="g.name"/>
                            <span class="gp"><t t-esc="g.done"/>/<t t-esc="g.total"/></span>
                        </div>
                        <button t-foreach="g.tasks" t-as="t" t-key="t.id" class="task" t-on-click="() => this.aapne(t)">
                            <span class="who" t-esc="t.who==='du' ? '👤' : '🤖'"/>
                            <span class="tno" t-esc="t.no"/>
                            <span class="tnm" t-esc="t.name"/>
                            <span t-if="t.delt" class="delt" t-att-title="t.delt_med.join(', ')">delt</span>
                            <span t-att-class="'st st_' + t.st + (t.over?' over':'')" t-esc="t.st"/>
                        </button>
                    </div>
                </div>

                <!-- ØKTREGISTER -->
                <div t-if="state.view==='okter'">
                    <div t-if="!state.okter.length" class="empty">Ingen økter registrert ennå (Claude fører dem automatisk).</div>
                    <div t-foreach="state.okter" t-as="o" t-key="o.id"
                         t-att-class="'okt' + (o.stille ? ' stille' : '')">
                        <div class="or1">
                            <span class="onm" t-esc="o.navn"/>
                            <span t-att-class="'ost ost_' + o.status" t-esc="o.status"/>
                            <!-- STILLE: meldte seg aktiv, men har ikke gitt lyd siden.
                                 Uten dette ser en stoppet økt ut som en som jobber. -->
                            <span t-if="o.stille" class="ost ost_stille"
                                  t-att-title="'Ingen aktivitet på ' + o.alder">
                                stille i <t t-esc="o.alder"/>
                            </span>
                        </div>
                        <div class="or2">
                            <span class="okilde" t-esc="o.kilde"/> · <t t-esc="o.firma"/>
                            · <t t-esc="o.sist_aktiv"/>
                            <span t-if="o.alder" class="oalder">(<t t-esc="o.alder"/> siden)</span>
                        </div>
                        <div class="osum" t-esc="o.sammendrag"/>
                    </div>
                </div>

                <!-- PROSJEKTSPOR — den varige enheten. Oekter er arbeidsperioder i den. -->
                <div t-if="state.view==='spor'">
                    <div t-if="!state.spor.length" class="empty">Ingen prosjektspor ennå.</div>
                    <div t-else="" class="sporliste">
                        <div t-foreach="state.spor" t-as="s" t-key="s.id"
                             t-att-class="'spor' + (s.uten_eier ? ' uteneier' : '')">
                            <div class="sp1">
                                <span class="spver" t-esc="s.versjon"/>
                                <span class="spkode" t-esc="s.kode"/>
                                <span class="spnavn" t-esc="s.navn"/>
                                <span t-if="s.uten_eier" class="spvarsel">uten eier</span>
                                <span class="sp_sp"/>
                                <span t-if="s.aktive" class="spaktiv"><t t-esc="s.aktive"/> aktive</span>
                                <span t-att-class="'spstat spstat_' + s.status" t-esc="s.status"/>
                            </div>
                            <div class="sp2">
                                <t t-esc="s.modul"/>
                                <t t-if="s.i_odoo"> · står i Odoo <t t-esc="s.modul_versjon"/></t>
                                <t t-else=""> · ikke i Odoo</t>
                            </div>
                            <div class="spbesk" t-if="s.beskrivelse" t-esc="s.beskrivelse"/>
                        </div>
                    </div>
                </div>

                <!-- ORG-KART -->
                <div t-if="state.view==='org'">
                    <div t-if="!state.org.installert" class="empty">AI-organisasjonen (Rolle-modulen) er ikke installert ennå.</div>
                    <div t-else="" class="orgwrap">
                        <div t-foreach="state.org.roller" t-as="r" t-key="r.id" t-att-class="'rolle ' + (r.type==='leder'?'leder':'radgiver')">
                            <div class="ro1"><span class="romr" t-esc="r.omraade"/><span class="rnm" t-esc="r.navn"/></div>
                            <div class="rt" t-esc="r.type==='leder' ? 'Leder' : 'Rådgiver'"/>
                            <div class="rfirma" t-esc="r.firma"/>
                            <div class="rskill" t-if="r.skill" t-esc="r.skill"/>
                        </div>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
