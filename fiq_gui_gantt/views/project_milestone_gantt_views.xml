<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================= -->
    <!--  Milepæl-Gantt (delmål som endagssøyler)                      -->
    <!-- ============================================================= -->
    <record id="view_project_milestone_gantt_fiq" model="ir.ui.view">
        <field name="name">project.milestone.gantt.fiq</field>
        <field name="model">project.milestone</field>
        <field name="arch" type="xml">
            <gantt
                date_start="fiq_gantt_start"
                date_stop="fiq_gantt_stop"
                default_scale="month"
                scales="week,month,year"
                default_group_by="project_id"
                decoration-danger="time_status == 'rod'"
                decoration-warning="time_status == 'oransje'"
                decoration-success="time_status == 'gronn'">
                <field name="project_id"/>
                <field name="deadline"/>
                <field name="is_reached"/>
                <field name="time_status"/>
                <templates>
                    <div t-name="gantt-popover" class="o_fiq_gantt_popover">
                        <ul class="p-0 m-0" style="list-style:none;">
                            <li t-if="deadline"><strong>Frist:</strong> <t t-esc="deadline"/></li>
                            <li><strong>Nådd:</strong> <t t-esc="is_reached ? 'Ja' : 'Nei'"/></li>
                        </ul>
                    </div>
                </templates>
            </gantt>
        </field>
    </record>

    <!-- Handling: Milepæl-Gantt -->
    <record id="action_project_milestone_gantt_fiq" model="ir.actions.act_window">
        <field name="name">Milepæl-Gantt</field>
        <field name="res_model">project.milestone</field>
        <field name="view_mode">gantt,list,form</field>
        <field name="view_id" ref="view_project_milestone_gantt_fiq"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Ingen milepæler med frist ennå</p>
            <p>Sett en <b>Frist</b> på milepæler for å se dem i tidslinjen.</p>
        </field>
    </record>

</odoo>
