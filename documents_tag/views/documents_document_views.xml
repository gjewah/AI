<odoo>
    <record id="documents_document_view_list" model="ir.ui.view">
        <field name="name">documents.document.view.list.inherit</field>
        <field name="model">documents.document</field>
        <field name="inherit_id" ref="documents.documents_view_list"/>
        <field name="arch" type="xml">
            <data>
                <list position="inside">
                    <field name="documents_tag_id" optional="hide" />
                    <field name="documents_tag_ids" optional="hide" widget="many2many_tags"/>
                </list>
            </data>
        </field>
    </record>
    <record id="documents_document_view_kanban" model="ir.ui.view">
        <field name="name">documents.document.view.kanban.inherit</field>
        <field name="model">documents.document</field>
        <field name="inherit_id" ref="documents.document_view_kanban"/>
        <field name="arch" type="xml">
            <data>
                <kanban position="attributes">
                    <attribute name="highlight_color">documents_tag_color</attribute>
                </kanban>
                <kanban position="inside">
                    <field name="documents_tag_id"/>
                </kanban>
                <footer position="attributes">
                    <attribute name="groups">base.group_user</attribute>
                    <attribute name="t-if"></attribute>
                    <attribute name="class">d-flex flex-column px-2</attribute>
                </footer>
                <field name="tag_ids" position="attributes">
                    <attribute name="groups">base.group_user</attribute>
                </field>
                <field name="tag_ids" position="before">
                    <field name="documents_tag_id" groups="base.group_user" />
                    <field name="documents_tag_tooltip_translate" invisible="type != 'folder'" groups="base.group_user" />
                </field>
            </data>
        </field>
    </record>
    <record id="documents_document_view_form" model="ir.ui.view">
        <field name="name">documents.document.view.form.inherit</field>
        <field name="model">documents.document</field>
        <field name="inherit_id" ref="documents_form.document_view_form"/>
        <field name="arch" type="xml">
            <data>
                <field name="tag_ids" position="replace">
                    <field name="documents_tag_id" />
                    <field name="documents_tag_tooltip_translate" />
                    <field name="documents_tag_ids_filter" widget="boolean_toggle" />
                    <div class="d-flex w-100" colspan="2">
                        <button
                            string="Select DOC Tags"
                            type="object"
                            name="action_open_tag_selector"
                            class="btn-secondary"
                        />
                        <field
                            name="documents_tag_ids"
                            invisible="documents_tag_ids_filter"
                            widget="many2many_tags"
                            options="{'no_quick_create': True}"
                        />
                        <field
                            name="documents_tag_ids"
                            domain="[('id', 'in', documents_tag_all_child_ids)]"
                            invisible="not documents_tag_ids_filter"
                            widget="many2many_tags"
                            options="{'no_quick_create': True}"
                        />
                    </div>
                </field>
            </data>
        </field>
    </record>
</odoo>
