<odoo>
    <!-- company_id vises kun når fler-selskap er aktivert. -->

    <record id="crm_stage_form_company" model="ir.ui.view">
        <field name="name">crm.stage.form.fiq.company</field>
        <field name="model">crm.stage</field>
        <field name="inherit_id" ref="crm.crm_stage_form"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="company_id" groups="base.group_multi_company"
                       options="{'no_create': True}"/>
            </field>
        </field>
    </record>

    <record id="crm_lost_reason_form_company" model="ir.ui.view">
        <field name="name">crm.lost.reason.form.fiq.company</field>
        <field name="model">crm.lost.reason</field>
        <field name="inherit_id" ref="crm.crm_lost_reason_view_form"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="company_id" groups="base.group_multi_company"
                       options="{'no_create': True}"/>
            </field>
        </field>
    </record>

    <record id="mail_template_form_company" model="ir.ui.view">
        <field name="name">mail.template.form.fiq.company</field>
        <field name="model">mail.template</field>
        <field name="inherit_id" ref="mail.email_template_form"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="company_id" groups="base.group_multi_company"
                       options="{'no_create': True}"/>
            </field>
        </field>
    </record>

    <record id="res_partner_category_form_company" model="ir.ui.view">
        <field name="name">res.partner.category.form.fiq.company</field>
        <field name="model">res.partner.category</field>
        <field name="inherit_id" ref="base.view_partner_category_form"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="company_id" groups="base.group_multi_company"
                       options="{'no_create': True}"/>
            </field>
        </field>
    </record>
</odoo>
