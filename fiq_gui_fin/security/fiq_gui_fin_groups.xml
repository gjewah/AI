<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Odoo 19: en gruppe UTEN privilege_id er USYNLIG i Innstillinger.
         res.groups har ingen category_id-kolonne i 19 — den går via
         res.groups.privilege → category_id. Samme mønster som fiq_gui_control v6.77. -->
    <record id="res_groups_privilege_finans" model="res.groups.privilege">
        <field name="name">FIQ Finans</field>
        <field name="category_id" ref="base.module_category_productivity"/>
        <field name="sequence">70</field>
    </record>

    <!-- 2.70 Bruker: ser finans-flaten (analyse, KPI, simulator). -->
    <record id="group_user" model="res.groups">
        <field name="name">FIQ Finans / Bruker</field>
        <field name="privilege_id" ref="fiq_gui_fin.res_groups_privilege_finans"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- 2.70 Finansansvarlig: full finans-flate.
         Tildeles bevisst — finans er IKKE for alle interne brukere. -->
    <record id="group_manager" model="res.groups">
        <field name="name">FIQ Finans / Finansansvarlig</field>
        <field name="privilege_id" ref="fiq_gui_fin.res_groups_privilege_finans"/>
        <field name="implied_ids" eval="[(4, ref('fiq_gui_fin.group_user'))]"/>
    </record>
</odoo>
