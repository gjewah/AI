<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mail_chat_rule_internal_all" model="ir.rule">
        <field name="name">Mail Chat Internal Access</field>
        <field name="model_id" ref="model_mail_chat"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="mail_chat_rule_portal_follower" model="ir.rule">
        <field name="name">Mail Chat Portal Follower Access</field>
        <field name="model_id" ref="model_mail_chat"/>
        <field name="domain_force">[('message_partner_ids', 'in', [user.partner_id.id])]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
    </record>
</odoo>
