<?xml version="1.0" encoding="utf-8" ?>
<data>
    <record id="res_country_view_list" model="ir.ui.view">
        <field name="name">res.country.view.list.inherit.location</field>
        <field name="model">res.country</field>
        <field name="inherit_id" ref="base.view_country_tree"/>
        <field name="arch" type="xml">
            <list position="inside">
                <field name="assign_location_ids" widget="many2many_tags" optional="hide"/>
            </list>
        </field>
    </record>
    <record id="res_country_view_form" model="ir.ui.view">
        <field name="name">res.country.view.form.inherit.location</field>
        <field name="model">res.country</field>
        <field name="inherit_id" ref="base.view_country_form"/>
        <field name="arch" type="xml">
            <sheet position="inside">
                <group string="Assigned Locations">
                    <field name="assign_location_ids" nolabel="1"/>
                </group>
            </sheet>
        </field>
    </record>
</data>
