<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="crm_lead_view_form" model="ir.ui.view">
        <field name="name">crm.lead.view.form.inherit.button</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form" />
        <field name="arch" type="xml">
            <data>
                <xpath expr="//form[1]/header[1]/field[@name='stage_id']" position="after">
                    <button
                        string="Create SO &amp; PRJ"
                        name="action_create_sale_order_and_project"
                        type="object"
                        invisible="sale_order_project_count"
                        groups="sales_team.group_sale_salesman"
                    />
                    <button
                        string="Move docs"
                        name="move_attachments_to_task_or_project"
                        type="object"
                        invisible="not sale_order_project_count"
                        groups="sales_team.group_sale_salesman"
                    />
                </xpath>
                <xpath expr="//group[@name='lead_partner']/field[@name='partner_id']" position="after">
                    <field name="project_address"/>
                </xpath>
                <xpath expr="//group[@name='opportunity_partner']/field[@name='partner_id']" position="after">
                    <field name="project_address"/>
                </xpath>
                <field name="user_id" position="after">
                    <field name="sale_order_product_id" domain="['|', ('project_id', '!=', False), ('project_template_id', '!=', False)]"/>
                </field>
                <notebook position="inside">
                    <page name="sale_order_project_ids" string="Projects" invisible="sale_order_project_count == 0">
                        <field name="sale_order_project_ids" readonly="1" />
                    </page>
                </notebook>
            </data>
        </field>
    </record>
</odoo>
