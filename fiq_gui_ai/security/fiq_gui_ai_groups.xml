<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Odoo 19: en res.groups UTEN privilege_id er USYNLIG i Innstillinger > Brukere
         - den virker, men ingen kan huke den av. Grupperingen gaar via
         res.groups.privilege, som selv peker paa en ir.module.category.
         Samme felle som traff fiq_gui_control v6.77 og fiq_tilgang v1.2.0.
         Meldt av «0.00 8.50 GUI 2.70 Finans (00.00)» 18.07.2026. -->
    <record id="module_category_fiq_gui_ai" model="ir.module.category">
        <field name="name">FIQ AI</field>
    </record>

    <record id="res_groups_privilege_fiq_gui_ai" model="res.groups.privilege">
        <field name="name">FIQ AI co-worker</field>
        <field name="category_id" ref="module_category_fiq_gui_ai"/>
    </record>

    <!-- FIQ AI co-worker access group (Odoo 19: res.groups takes name + implied_ids).
         "AI MGM" (AI Management) governs configuration of the AI co-worker
         (API key, model). The chat itself is open to all internal users. -->
    <record id="group_ai_mgm" model="res.groups">
        <field name="name">AI MGM</field>
        <field name="privilege_id" ref="res_groups_privilege_fiq_gui_ai"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Odoo system admin automatically gets AI MGM. -->
    <record id="base.group_system" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('fiq_gui_ai.group_ai_mgm'))]"/>
    </record>
</odoo>
