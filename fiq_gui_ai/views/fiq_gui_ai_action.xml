<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Client action: the OWL "Ask AI for help" co-worker flate.
         Registered so it can be opened standalone AND embedded (Control room). -->
    <record id="action_fiq_gui_ai" model="ir.actions.client">
        <field name="name">FIQ AI co-worker</field>
        <field name="tag">fiq_gui_ai_coworker</field>
    </record>

    <!-- Top menu that opens the co-worker – open to all internal users. -->
    <menuitem id="menu_fiq_gui_ai_root"
              name="FIQ AI co-worker"
              action="action_fiq_gui_ai"
              web_icon="fiq_gui_ai,static/description/icon.png"
              groups="base.group_user"
              sequence="2"/>
</odoo>
