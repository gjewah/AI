#. module: fiq_gui_ai
#. Python – spor(): empty question
msgid "Write a question and I'll help you."
msgstr "Skriv et spørsmål, så hjelper jeg deg."

#. module: fiq_gui_ai
#. Python – spor(): key not configured
msgid ""
"AI is not configured yet. An administrator must add the Anthropic API key "
"under the 'fiq_gui_ai.anthropic_api_key' system parameter before the "
"assistant can answer."
msgstr ""
"AI er ikke konfigurert ennå. En administrator må legge inn Anthropic-API-"
"nøkkelen under systemparameteret «fiq_gui_ai.anthropic_api_key» før "
"assistenten kan svare."

#. module: fiq_gui_ai
#. Python – spor(): default user label in the system note
msgid "an Odoo user"
msgstr "en Odoo-bruker"

#. module: fiq_gui_ai
#. Python – spor(): system note
msgid ""
"You are FIQ's helpful AI co-worker inside Odoo. Answer concisely and in the "
"same language as the user's question. The user is %s."
msgstr ""
"Du er FIQs hjelpsomme AI-medarbeider inne i Odoo. Svar kort og på samme "
"språk som brukerens spørsmål. Brukeren er %s."

#. module: fiq_gui_ai
#. Python – spor(): request failed / mail unreachable
msgid ""
"AI is unavailable right now – I couldn't reach the assistant. Please try "
"again in a moment."
msgstr ""
"AI er utilgjengelig akkurat nå – jeg fikk ikke kontakt med assistenten. "
"Prøv igjen om et øyeblikk."

#. module: fiq_gui_ai
#. Python – spor(): unreadable response
msgid "AI is unavailable right now – I got an unreadable answer."
msgstr "AI er utilgjengelig akkurat nå – jeg fikk et uleselig svar."

#. module: fiq_gui_ai
#. Python – spor(): empty answer
msgid "AI is unavailable right now – the assistant returned no answer."
msgstr "AI er utilgjengelig akkurat nå – assistenten ga ikke noe svar."

#. module: fiq_gui_ai
#. JS – transport error fallback
msgid "AI is unavailable right now – please try again in a moment."
msgstr "AI er utilgjengelig akkurat nå – prøv igjen om et øyeblikk."
