<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="fiq_gui_ai.Coworker">
        <div class="fiq_ai">
            <!-- Top bar -->
            <div class="fiq_ai_top">
                <div class="fiq_ai_brand">
                    <span class="fiq_ai_mark">✨</span>
                    <span class="fiq_ai_name">Ask AI for help</span>
                </div>
                <span class="fiq_ai_spacer"/>
                <button class="btn fiq_ai_pbtn" t-on-click="() => this.togglePresence()"
                        title="Show who is online">
                    <span class="fiq_ai_dot on"/>
                    <t t-esc="onlineCount"/> online
                </button>
            </div>

            <div class="fiq_ai_wrap">
                <!-- Chat column -->
                <section class="fiq_ai_chat">
                    <div class="fiq_ai_list" t-ref="list">
                        <t t-if="!state.messages.length">
                            <div class="fiq_ai_hint">
                                Ask me anything – e.g. "Summarize this project's status"
                                or "How do I create a task in Odoo?"
                            </div>
                        </t>
                        <t t-foreach="state.messages" t-as="m" t-key="m_index">
                            <div t-att-class="'fiq_ai_msg ' + m.role">
                                <span class="fiq_ai_who" t-esc="m.role === 'user' ? 'You' : 'AI'"/>
                                <span class="fiq_ai_txt" t-esc="m.text"/>
                            </div>
                        </t>
                        <t t-if="state.busy">
                            <div class="fiq_ai_msg ai fiq_ai_typing">
                                <span class="fiq_ai_who">AI</span>
                                <span class="fiq_ai_txt">…</span>
                            </div>
                        </t>
                    </div>

                    <div class="fiq_ai_compose">
                        <textarea class="fiq_ai_input" t-ref="input"
                                  placeholder="Write your question and press Enter…"
                                  t-att-value="state.draft"
                                  t-on-input="(ev) => state.draft = ev.target.value"
                                  t-on-keydown="(ev) => this.onKeydown(ev)"/>
                        <button class="btn fiq_ai_send" t-att-disabled="state.busy"
                                t-on-click="() => this.send()">Send</button>
                    </div>
                </section>

                <!-- Presence column -->
                <aside t-if="state.showPresence" class="fiq_ai_side">
                    <div class="fiq_ai_side_h">Presence</div>
                    <t t-if="state.presence.length">
                        <t t-foreach="state.presence" t-as="u" t-key="u.id">
                            <div class="fiq_ai_user">
                                <span t-att-class="'fiq_ai_dot ' + u.status"/>
                                <span class="fiq_ai_uname" t-esc="u.name"/>
                                <span t-if="u.is_me" class="fiq_ai_me">you</span>
                            </div>
                        </t>
                    </t>
                    <t t-else="">
                        <div class="fiq_ai_hint">No users to show.</div>
                    </t>
                </aside>
            </div>
        </div>
    </t>
</templates>
