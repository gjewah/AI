<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Klient-handling: Meldingssenter (V00.04). Samme tag som skjelettet,
         slik at KR-sidemenyen (fiq_gui_control) fortsatt åpner flaten. -->
    <!-- Kommunikasjon = HOVEDFLATEN (Gjermund 16.07.2026). Forsiden er oversikten;
         E-post er ETT av underpunktene. Samme tag som før, så KR-koblingen holder. -->
    <record id="action_fiq_gui_epost" model="ir.actions.client">
        <field name="name">Kommunikasjon</field>
        <field name="tag">fiq_gui_epost_dashboard</field>
    </record>

    <!-- Egen inngang, i tillegg til KR-sidemenyen, så flaten alltid er å finne. -->
    <menuitem id="menu_fiq_msg_root"
              name="Kommunikasjon"
              sequence="26"/>
    <menuitem id="menu_fiq_msg_main"
              name="Oversikt"
              parent="menu_fiq_msg_root"
              action="action_fiq_gui_epost"
              sequence="1"/>
</odoo>
