<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Klient-handling: Meldingssenter (V00.04). Samme tag som skjelettet,
         slik at KR-sidemenyen (fiq_gui_control) fortsatt åpner flaten. -->
    <!-- Kommunikasjon = HOVEDFLATEN (Gjermund 16.07.2026). Forsiden er oversikten;
         E-post er ETT av underpunktene. Samme tag som før, så KR-koblingen holder. -->
    <record id="action_fiq_gui_epost" model="ir.actions.client">
        <field name="name">Kommunikasjon</field>
        <field name="tag">fiq_gui_epost_dashboard</field>
    </record>

    <!-- E-POST HAR IKKE LENGER EGET PUNKT I HOVEDMENYEN (Gjermund 17.07.2026):
         «e-post skal ikke vises før vi er inne i kommunikasjonssenteret». Inngangen er
         «Kommunikasjon» (fiq_gui_comm); E-post er en kanal DER inne.
         Menyene SLETTES IKKE — de er installert på Staging + Production, og en meny som
         forsvinner under føttene på en installert modul er nettopp fella vi unngår.
         De deaktiveres i stedet (active=False) → borte fra menyen, men trygt reversibelt. -->
    <record id="menu_fiq_msg_root" model="ir.ui.menu">
        <field name="name">Kommunikasjon — E-post</field>
        <field name="active" eval="False"/>
        <field name="sequence">26</field>
    </record>
    <record id="menu_fiq_msg_main" model="ir.ui.menu">
        <field name="name">Oversikt</field>
        <field name="parent_id" ref="menu_fiq_msg_root"/>
        <field name="action" ref="action_fiq_gui_epost"/>
        <field name="active" eval="False"/>
        <field name="sequence">1</field>
    </record>
</odoo>
