<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Rutingregler (if/then) — brukerstyrt, klartekst. Odoo 19: <list> ikke <tree>. -->
    <record id="view_fiq_komm_regel_list" model="ir.ui.view">
        <field name="name">fiq.komm.regel.list</field>
        <field name="model">fiq.komm.regel</field>
        <field name="arch" type="xml">
            <list string="Rutingregler" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="felt"/>
                <field name="operator"/>
                <field name="verdi"/>
                <field name="handling"/>
                <field name="treff"/>
                <field name="sist_kjort"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_fiq_komm_regel_form" model="ir.ui.view">
        <field name="name">fiq.komm.regel.form</field>
        <field name="model">fiq.komm.regel</field>
        <field name="arch" type="xml">
            <form string="Rutingregel">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                    <group string="Hvis">
                        <field name="felt"/>
                        <field name="operator"/>
                        <field name="verdi"/>
                    </group>
                    <group string="Så">
                        <field name="handling"/>
                    </group>
                    <group string="Logg">
                        <field name="treff"/>
                        <field name="sist_kjort"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fiq_komm_regel" model="ir.actions.act_window">
        <field name="name">Rutingregler</field>
        <field name="res_model">fiq.komm.regel</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Rutingreglene hører til Kommunikasjon-flaten (paraplyen), ikke under den
         deaktiverte E-post-roten — ellers ville de blitt utilgjengelige uten feilmelding. -->
    <menuitem id="menu_fiq_msg_regler"
              name="Rutingregler"
              parent="fiq_gui_comm.menu_fiq_comm_root"
              action="action_fiq_komm_regel"
              sequence="20"/>
</odoo>
