<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="fiq_gui_epost.MsgSenter">
        <div class="msapp">
            <div t-if="state.loading" class="loading">Laster Meldingssenter…</div>
            <t t-else="">

                <!-- TIL STEDE NÅ -->
                <div class="presence">
                    <span class="pl">Til stede nå</span>
                    <t t-foreach="state.presence.slice(0,8)" t-as="p" t-key="p.id">
                        <button t-att-class="'pc ' + pcls(p.status)" t-on-click="() => this.openPerson(p.id)" title="Åpne person">
                            <span class="pa" t-esc="initialer(p.navn)"/>
                            <t t-esc="p.navn"/>
                        </button>
                    </t>
                </div>

                <!-- Topplinje -->
                <div class="top">
                    <img t-if="state.logo" class="logo logoimg" t-att-src="state.logo" alt="Firmalogo"/>
                    <div t-else="" class="logo" t-esc="'FIQ'"/>
                    <div class="brand">
                        <div class="eb">FIQ Kontrollrom · 8.50 GUI · V00.06</div>
                        <div class="ti">Kommunikasjon</div>
                    </div>
                    <div class="sp"/>
                    <div class="switch">
                        <button t-foreach="state.firms" t-as="f" t-key="f.id"
                                t-att-class="'swb' + (f.id===state.current_firm?' on':'')"
                                t-on-click="() => this.byttFirma(f.id)">
                            <b t-esc="f.kode || ''"/><span t-esc="f.navn"/>
                        </button>
                    </div>
                    <button class="ubtn ai">✦ AI</button>
                    <button class="ubtn kr" t-on-click="tilbakeKR">‹ Kontrollrom</button>
                </div>

                <!-- TRE-RUTE: mappetre | liste | lese-/kontekstpanel -->
                <div class="pane">

                    <!-- Venstre: mappetre -->
                    <div class="tree">
                        <button t-att-class="'home' + (state.view==='hjem'?' on':'')" t-on-click="visHjem">
                            🏠 <span>Oversikt</span>
                        </button>

                        <!-- E-POST = ETT underpunkt under Kommunikasjon (ikke hele flaten) -->
                        <div class="sh">Kanaler</div>
                        <div class="nav">
                            <button t-att-class="'kanal' + (state.view==='inbox'?' on':'')" t-on-click="aapneEpost">
                                <span class="dot" style="--nc:var(--blaa)"/><b>E-post</b>
                                <span class="c tnum" t-esc="(state.basis[0] || {}).count || 0"/>
                            </button>
                        </div>

                        <t t-if="state.view==='inbox'">
                        <div class="sh">E-post — postkasse</div>
                        <div class="nav">
                            <button t-foreach="state.basis" t-as="b" t-key="b.kode"
                                    t-att-class="(state.aktivBoks===b.kode?'on':'') + ' cd_' + b.farge"
                                    t-on-click="() => this.aapneBoks(b.kode, b.navn)">
                                <span class="dot"/><t t-esc="b.navn"/>
                                <span class="c tnum" t-esc="b.count"/>
                            </button>
                        </div>

                        <div class="sh trehead">
                            <span>Smarte mapper — taksonomi</span>
                            <button class="trealle" t-on-click="vekslHeleTreet" t-esc="treLabel()"/>
                        </div>
                        <div class="nav">
                            <t t-foreach="state.taks" t-as="b" t-key="b.kode">
                                <button t-if="!skjult(b.kode)"
                                        t-att-class="(state.view==='inbox' &amp;&amp; state.aktivBoks===b.kode?'on':'') + ' cd_' + b.farge + ' niva' + (b.nivaa || 0)"
                                        t-on-click="() => this.aapneBoks(b.kode, b.navn)">
                                    <!-- Pil KUN på mapper som faktisk har undermapper. Egen knapp
                                         inni raden: klikk på pilen folder, klikk på navnet åpner. -->
                                    <span t-if="harBarn(b.kode)"
                                          t-att-class="'ch' + (state.trekollaps[b.kode] ? ' col' : '')"
                                          t-on-click="(ev) => this.vekslTre(b.kode, ev)">▾</span>
                                    <span t-else="" class="ch tom"/>
                                    <span class="code" t-esc="b.kode"/><t t-esc="b.navn"/>
                                    <span class="c tnum" t-esc="b.count"/>
                                </button>
                            </t>
                            <button t-foreach="state.tverr" t-as="b" t-key="b.kode"
                                    t-att-class="(state.view==='inbox' &amp;&amp; state.aktivBoks===b.kode?'on':'') + ' cd_' + b.farge"
                                    t-on-click="() => this.aapneBoks(b.kode, b.navn)">
                                <span class="dot"/><t t-esc="b.navn"/>
                                <span class="c tnum" t-esc="b.count"/>
                            </button>
                        </div>
                        </t>

                        <div class="sh">Møter</div>
                        <div class="nav">
                            <button class="cd_blaa" t-on-click="aapneKalender"><span class="dot"/>Møter &amp; Kalender</button>
                            <button class="cd_tealx" t-on-click="() => this.aapneBoks('motereferater','Møtereferater')"><span class="dot"/>Møtereferater</button>
                        </div>

                        <div class="sh">Mer</div>
                        <div class="nav">
                            <button class="cd_graa" t-on-click="aapneInnstillinger"><span class="dot"/>Innstillinger</button>
                        </div>
                    </div>

                    <!-- KALENDER: måned INNE i flaten (Gjermund 19.07.2026: «kalenderen mangler»).
                         Før kastet knappen brukeren ut til Odoos native kalender — samme feil som
                         `view:`-fella. Native kalender finnes fortsatt, som eget valg. -->
                    <div class="col kalender" t-if="state.view==='kalender' and state.kal">
                        <div class="hjemhead">
                            <div class="crumb">
                                <button class="kbla" t-on-click="() => this.blaMnd(-1)">‹</button>
                                <span class="cur"><t t-esc="state.kal.mnd_navn"/> <t t-esc="state.kal.aar"/></span>
                                <button class="kbla" t-on-click="() => this.blaMnd(1)">›</button>
                            </div>
                            <span class="kantall"><t t-esc="state.kal.antall"/> i måneden</span>
                            <button class="tilbakeb" t-on-click="aapneNativKalender">Odoo-kalender ›</button>
                        </div>
                        <div class="kaluker">
                            <span>Man</span><span>Tir</span><span>Ons</span><span>Tor</span>
                            <span>Fre</span><span>Lør</span><span>Søn</span>
                        </div>
                        <div class="kalgrid">
                            <t t-foreach="kalCeller()" t-as="c" t-key="c.key">
                                <div t-if="c.tom" class="kdag tom"/>
                                <div t-else="" t-att-class="'kdag' + (c.i_dag ? ' idag' : '') + (c.hendelser.length ? ' har' : '')">
                                    <span class="kd" t-esc="c.dag"/>
                                    <button t-foreach="c.hendelser" t-as="h" t-key="h.model + h.id"
                                            t-att-class="'kev ' + h.type"
                                            t-on-click="() => this.aapneHendelse(h)">
                                        <span t-if="h.tid" class="kt" t-esc="h.tid"/>
                                        <t t-esc="h.navn"/>
                                    </button>
                                </div>
                            </t>
                        </div>
                    </div>

                    <!-- HJEM: cockpit-oversikt (fargebokser) -->
                    <div class="col hjem" t-if="state.view==='hjem'">
                        <div class="hjemhead">
                            <div class="crumb"><span class="cur">Kommunikasjon — oversikt</span></div>
                            <button class="tilbakeb" t-on-click="aapneEpost">Åpne E-post ›</button>
                        </div>
                        <div class="sub-lbl">Tverrgående</div>
                        <div class="boxes">
                            <button t-foreach="state.tverr" t-as="b" t-key="b.kode"
                                    t-att-class="'box c_' + b.farge"
                                    t-on-click="() => this.aapneBoks(b.kode, b.navn)">
                                <div class="bl"><span class="nm" t-esc="b.navn"/></div>
                                <div class="n tnum" t-esc="b.count"/>
                            </button>
                        </div>
                        <div class="sub-lbl">Områder</div>
                        <div class="boxes">
                            <button t-foreach="state.taks" t-as="b" t-key="b.kode"
                                    t-att-class="'box c_' + b.farge + ' niva' + (b.nivaa || 0)"
                                    t-on-click="() => this.aapneBoks(b.kode, b.navn)">
                                <div class="bl"><span class="code" t-esc="b.kode"/><span class="nm" t-esc="b.navn"/></div>
                                <div class="n tnum" t-esc="b.count"/>
                            </button>
                        </div>
                    </div>

                    <!-- Dra-håndtak: mappetre ↔ liste -->
                    <button class="drag" t-if="state.view==='inbox'" t-ref="dragTre"
                            t-on-pointerdown="(ev) => this.startDrag(ev, 'tre')"
                            title="Dra for å justere bredden" aria-label="Juster bredde på mappetreet"/>

                    <!-- MIDT: meldingsliste -->
                    <div class="col list" t-if="state.view==='inbox'">
                        <div class="lhead">
                            <input class="lsok" type="search" placeholder="Søk avsender, emne, prosjektnr…"
                                   t-att-value="state.q" t-on-change="sok"/>
                            <select class="lgrp" t-on-change="setGroup">
                                <option value="avsender">Avsender</option>
                                <option value="prosjekt">Prosjekt</option>
                                <option value="dato">Dato</option>
                                <option value="type">Type</option>
                            </select>
                            <button class="lgrp" t-on-click="toggleAlle" t-esc="kollapsLabel()"/>
                            <button class="lgrp skriv" t-on-click="skrivNy">✎ Skriv</button>
                        </div>
                        <div class="listbody">
                            <div t-if="!state.meldinger.length" class="empty">Ingen meldinger i <t t-esc="state.aktivNavn"/>.</div>
                            <t t-foreach="grupper()" t-as="g" t-key="g.key">
                                <button class="grp" t-on-click="() => this.toggleGroup(g.key)">
                                    <span class="ch" t-esc="state.kollaps[g.key] ? '▸' : '▾'"/>
                                    <span class="gk" t-esc="g.label"/>
                                    <span class="gc tnum" t-esc="g.n"/>
                                </button>
                                <t t-if="!state.kollaps[g.key]">
                                    <button t-foreach="g.items" t-as="m" t-key="m.id"
                                            t-att-class="'mi' + (state.valgt?.id===m.id?' on':'') + (m.ulest?' un':'')"
                                            t-on-click="() => this.velgMelding(m)">
                                        <div class="r1"><span class="fr" t-esc="m.fra"/><span class="tm" t-esc="m.dato"/></div>
                                        <div class="su" t-esc="m.emne"/>
                                        <div class="pv" t-esc="m.preview"/>
                                        <div class="r3" t-if="m.status || m.element || m.risiko || (state.kryss_firma &amp;&amp; m.firma)">
                                            <span t-if="state.kryss_firma &amp;&amp; m.firma" class="chip firma"
                                                  t-esc="m.firmakode ? (m.firmakode + ' ' + m.firma) : m.firma"/>
                                            <span t-if="m.risiko==='hoy'" class="chip risk">⚠ Mulig svindel</span>
                                            <span t-if="m.status" t-att-class="'chip ' + statuscls(m.status)" t-esc="m.status_navn || m.status"/>
                                            <span t-if="m.element" class="chip el" t-esc="m.element"/>
                                        </div>
                                    </button>
                                </t>
                            </t>
                        </div>
                    </div>

                    <!-- Dra-håndtak: liste ↔ lesepanel -->
                    <button class="drag" t-if="state.view==='inbox'"
                            t-on-pointerdown="(ev) => this.startDrag(ev, 'liste')"
                            title="Dra for å justere bredden" aria-label="Juster bredde på meldingslisten"/>

                    <!-- HØYRE: lese- og kontekstpanel -->
                    <div class="col read" t-if="state.view==='inbox'">
                        <t t-if="state.valgt">
                            <div class="rtool">
                                <button class="tbtn pri" t-on-click="() => this.svar(false)">Svar</button>
                                <button class="tbtn" t-on-click="() => this.svar(true)">Svar alle</button>
                                <button class="tbtn">Videresend</button>
                                <button class="tbtn">Arkivér</button>
                                <button class="tbtn">Tildel ansvarlig</button>
                                <button class="tbtn ai">✦ AI</button>
                            </div>
                            <div class="rbody">
                                <h3 class="rsub" t-esc="state.valgt.emne"/>
                                <div class="rmeta">
                                    <span class="ra" t-esc="initialer(state.valgt.fra)"/>
                                    <div>
                                        <div class="who" t-esc="state.valgt.fra"/>
                                        <div class="addr" t-esc="state.valgt.adresse"/>
                                    </div>
                                    <div class="rt">
                                        <div t-esc="state.valgt.dato"/>
                                        <button class="hodebtn" t-on-click="toggleHoder"
                                                t-esc="state.visHoder ? 'Skjul detaljer ▴' : 'Vis alle mottakere ▾'"/>
                                    </div>
                                </div>

                                <!-- Nøyaktig e-posthode: Fra · Til · Kopi · Blindkopi · Svar-til -->
                                <div class="hoder" t-if="state.hoder">
                                    <div class="hrad">
                                        <span class="hl">Fra</span>
                                        <span class="hv" t-esc="navnAdr(state.hoder.fra)"/>
                                    </div>
                                    <div class="hrad" t-if="state.hoder.til.length || state.hoder.raa_til.length">
                                        <span class="hl">Til</span>
                                        <span class="hv">
                                            <t t-foreach="state.hoder.til" t-as="p" t-key="'t'+p_index">
                                                <span class="adr" t-esc="navnAdr(p)"/>
                                            </t>
                                            <t t-foreach="state.hoder.raa_til" t-as="a" t-key="'rt'+a_index">
                                                <span class="adr raa" t-esc="a"/>
                                            </t>
                                        </span>
                                    </div>
                                    <div class="hrad" t-if="state.hoder.kopi.length || state.hoder.raa_kopi.length">
                                        <span class="hl">Kopi</span>
                                        <span class="hv">
                                            <t t-foreach="state.hoder.kopi" t-as="p" t-key="'k'+p_index">
                                                <span class="adr" t-esc="navnAdr(p)"/>
                                            </t>
                                            <t t-foreach="state.hoder.raa_kopi" t-as="a" t-key="'rk'+a_index">
                                                <span class="adr raa" t-esc="a"/>
                                            </t>
                                        </span>
                                    </div>
                                    <t t-if="state.visHoder">
                                        <div class="hrad" t-if="state.hoder.blindkopi.length">
                                            <span class="hl">Blindkopi</span>
                                            <span class="hv">
                                                <t t-foreach="state.hoder.blindkopi" t-as="p" t-key="'b'+p_index">
                                                    <span class="adr" t-esc="navnAdr(p)"/>
                                                </t>
                                            </span>
                                        </div>
                                        <div class="hrad" t-if="state.hoder.svar_til">
                                            <span class="hl">Svar-til</span>
                                            <span class="hv"><span class="adr varsel" t-esc="state.hoder.svar_til"/></span>
                                        </div>
                                    </t>
                                    <!-- Konsekvensen av Svar alle — synlig FØR man trykker -->
                                    <div class="hrad konsekvens" t-if="state.hoder.svar_alle.length">
                                        <span class="hl">↩ Svar alle</span>
                                        <span class="hv">
                                            <span class="ktall" t-esc="state.hoder.svar_alle.length + ' mottakere:'"/>
                                            <t t-foreach="state.hoder.svar_alle" t-as="p" t-key="'sa'+p_index">
                                                <span class="adr treff" t-esc="navnAdr(p)"/>
                                            </t>
                                        </span>
                                    </div>
                                </div>

                                <!-- Arbeidsstatus -->
                                <div class="statusbar">
                                    <span class="sl">Status</span>
                                    <select class="statussel" t-on-change="onStatusChange">
                                        <option value="" t-att-selected="!state.trad.status">— sett status —</option>
                                        <option value="apen" t-att-selected="state.trad.status==='apen'">Åpen</option>
                                        <option value="pagar" t-att-selected="state.trad.status==='pagar'">Pågår</option>
                                        <option value="ferdig" t-att-selected="state.trad.status==='ferdig'">Ferdig</option>
                                    </select>

                                    <!-- Overstyr gruppe (Gjermund 19.07: «hvordan endrer jeg på
                                         denne statusen på en e-post?»). Gruppene kommer fra
                                         nøkkelord i emnet; her kan mennesket rette når maskinen
                                         bommer. Tomt valg = tilbake til automatikk. -->
                                    <span class="sl">Gruppe</span>
                                    <select class="statussel" t-on-change="onTverrChange">
                                        <option t-foreach="state.tverrValg" t-as="v" t-key="v.kode"
                                                t-att-value="v.kode"
                                                t-att-selected="state.trad.tverr_kode === v.kode"
                                                t-esc="v.navn"/>
                                    </select>
                                    <span class="tverrav" t-if="state.trad.tverr_av">
                                        satt av <t t-esc="state.trad.tverr_av"/>
                                    </span>
                                </div>

                                <!-- AI-sammendrag (vises når backend gir det) -->
                                <div class="card aisum" t-if="state.valgt.ai_sammendrag">
                                    <div class="ch"><span class="icn">✦</span>AI-sammendrag</div>
                                    <div class="prose" t-esc="state.valgt.ai_sammendrag"/>
                                </div>

                                <!-- MELDINGSTEKSTEN — hele e-posten slik den er.
                                     Gjermund 23.07: «vis den slik den er med innhold og
                                     signatur osv.» Før viste vi `preview` = 140 tegn ren
                                     tekst; formatering, lenker og signatur forsvant.
                                     🛑 `body` er HTML fra ekstern avsender → vises i en
                                     AVGRENSET ramme (sandbox uten skript), samme valg
                                     Odoo selv tar i Discuss. Rammen vokser med innholdet. -->
                                <div class="mailbody">
                                    <div t-if="state.brodtekst.laster" class="mbtom">Henter meldingen …</div>
                                    <iframe t-elif="!state.brodtekst.tom" class="mbramme"
                                            sandbox="" title="Meldingstekst"/>
                                    <div t-else="" class="mbtom">Denne meldingen har ingen tekst.</div>
                                </div>

                                <!-- Internt notat (team-only) -->
                                <div class="card note">
                                    <div class="ch"><span class="icn">📝</span>Internt notat — kun team, usynlig for avsender</div>
                                    <div class="noteitem" t-foreach="state.trad.notater" t-as="n" t-key="n_index">
                                        <span class="av" t-esc="initialer(n.navn)"/>
                                        <div class="nb"><b t-esc="n.navn"/>: <t t-esc="n.body"/> <span class="nt" t-esc="n.dato"/></div>
                                    </div>
                                    <div class="noterow">
                                        <input type="text" placeholder="Skriv et internt notat til teamet…"
                                               t-att-value="state.nyNotat" t-on-input="onNotatInput"/>
                                        <button class="notesend" t-on-click="leggNotat">Legg til</button>
                                    </div>
                                </div>

                                <!-- Vedlegg → lagre på element (Loym) -->
                                <div class="card vedlegg" t-if="state.vedlegg.length">
                                    <div class="ch"><span class="icn">📎</span>Vedlegg → lagre på element (Loym)</div>
                                    <!-- Dokumentnavn · PDF · forhåndsvisning (Gjermund 19.07.2026).
                                         Navnet er redigerbart direkte i lista: klikk, skriv, Enter.
                                         Escape angrer. Filendelsen beholdes automatisk. -->
                                    <div class="attitem" t-foreach="state.vedlegg" t-as="a" t-key="a.id">
                                        <span class="fic">📄</span>
                                        <input t-if="state.redigerer === a.id" class="fnedit"
                                               t-att-value="state.nyttNavn"
                                               t-on-input="(ev) => this.state.nyttNavn = ev.target.value"
                                               t-on-keydown="(ev) => ev.key === 'Enter' ? this.lagreNavn(a) : (ev.key === 'Escape' ? this.avbrytNavn() : null)"
                                               t-on-blur="() => this.lagreNavn(a)"/>
                                        <span t-else="" class="fn" t-on-click="() => this.startNavn(a)"
                                              title="Klikk for å endre navn" t-esc="a.navn"/>
                                        <span class="fkb" t-esc="a.kb + ' kB'"/>
                                        <button class="fbtn" t-on-click="() => this.visVedlegg(a)"
                                                title="Forhåndsvis">👁</button>
                                        <button class="fbtn" t-on-click="() => this.tilPdf(a)"
                                                title="Konvertér til PDF (originalen beholdes)">PDF</button>
                                    </div>
                                    <div class="saverow" t-if="state.kandidater.prosjekt.length || state.kandidater.oppgave.length">
                                        <span class="lab">Lagre på:</span>
                                        <button class="savebtn" t-foreach="state.kandidater.prosjekt" t-as="k" t-key="'sp'+k.id"
                                                t-on-click="() => this.lagrePaaElement('project.project', k.id, k.navn)">
                                            <span class="kt kt_p">Prosjekt</span><t t-esc="k.navn"/>
                                        </button>
                                        <button class="savebtn" t-foreach="state.kandidater.oppgave" t-as="k" t-key="'so'+k.id"
                                                t-on-click="() => this.lagrePaaElement('project.task', k.id, k.navn)">
                                            <span class="kt kt_o">Oppgave</span><t t-esc="k.navn"/>
                                        </button>
                                    </div>
                                    <div class="savemsg" t-if="state.vedleggMsg" t-esc="state.vedleggMsg"/>
                                </div>

                                <!-- FORHÅNDSVISNING: vises inne i flaten, ikke som nedlasting.
                                     Vi henter en URL, ikke selve fila — store vedlegg skal ikke
                                     gjennom en RPC-runde bare for å vises. -->
                                <div class="fvmodal" t-if="state.fv">
                                    <div class="fvbg" t-on-click="lukkVedlegg"/>
                                    <div class="fvcard">
                                        <div class="fvhead">
                                            <span class="fvn" t-esc="state.fv.navn"/>
                                            <span class="fvkb" t-esc="state.fv.kb + ' kB'"/>
                                            <a class="fvbtn" t-att-href="state.fv.last_ned">Last ned</a>
                                            <button class="fvx" t-on-click="lukkVedlegg">×</button>
                                        </div>
                                        <iframe t-if="state.fv.kan_vises" class="fvramme"
                                                t-att-src="state.fv.url" title="Forhåndsvisning"/>
                                        <div t-else="" class="fvtom">
                                            Denne filtypen kan ikke vises i nettleseren
                                            (<t t-esc="state.fv.mimetype || 'ukjent type'"/>).
                                            Last den ned, eller konvertér til PDF.
                                        </div>
                                    </div>
                                </div>

                                <!-- Paring / tildeling (eksisterende backend) -->
                                <div class="card paring">
                                    <div class="ch"><span class="icn">🔗</span>Paring / tildeling</div>
                                    <div class="kobling">
                                        <div class="kh">🤖 Hører sannsynligvis til (nyeste øverst)</div>
                                        <div t-if="!harKobling()" class="ktom">Fant ingen kobling for denne avsenderen ennå.</div>
                                        <button class="kand" t-foreach="state.kandidater.prosjekt" t-as="k" t-key="'p'+k.id">
                                            <span class="kt kt_p">Prosjekt</span><span class="kn" t-esc="(k.no ? k.no + ' ' : '') + k.navn"/>
                                        </button>
                                        <button class="kand" t-foreach="state.kandidater.oppgave" t-as="k" t-key="'o'+k.id">
                                            <span class="kt kt_o">Oppgave</span><span class="kn" t-esc="(k.no ? k.no + ' ' : '') + k.navn"/>
                                        </button>
                                    </div>
                                    <!-- MANUELL paring (Gjermund 18.07.2026: disse sto som tomme
                                         skall uten funksjon). Søker på nummer OG navn; treffliste
                                         under feltet; klikk parer/velger. -->
                                    <!-- TO FELT, som den godkjente mockupen: smalt NUMMER-felt +
                                         eget NAVN-felt. Gjermund 19.07.2026: «oppgave og PRJ nummer
                                         mangler». Ett felt tvang deg til å søke deg fram selv når du
                                         VET nummeret; nå kan du taste 24_108 rett inn. Begge felt
                                         søker mot samme kilde og fyller hverandre ut. -->
                                    <div class="prow psok">
                                        <label>Prosjekt</label>
                                        <input class="nofield" placeholder="Nr."
                                               t-att-value="state.paring.prosjekt.nr"
                                               t-on-input="(ev) => this.sokMal('prosjekt', ev, 'nr')"/>
                                        <input placeholder="Prosjektnavn"
                                               t-att-value="state.paring.prosjekt.tekst"
                                               t-on-input="(ev) => this.sokMal('prosjekt', ev)"/>
                                        <div class="ptreff" t-if="state.paring.apen === 'prosjekt' and state.paring.prosjekt.treff.length">
                                            <button t-foreach="state.paring.prosjekt.treff" t-as="t" t-key="'tp'+t.id"
                                                    t-on-click="() => this.velgMal('prosjekt', t)">
                                                <span class="kt kt_p" t-esc="t.no || '—'"/><t t-esc="t.navn"/>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="prow psok">
                                        <label>Oppgave</label>
                                        <input class="nofield" placeholder="Nr."
                                               t-att-value="state.paring.oppgave.nr"
                                               t-on-input="(ev) => this.sokMal('oppgave', ev, 'nr')"/>
                                        <input placeholder="Oppgavenavn"
                                               t-att-value="state.paring.oppgave.tekst"
                                               t-on-input="(ev) => this.sokMal('oppgave', ev)"/>
                                        <div class="ptreff" t-if="state.paring.apen === 'oppgave' and state.paring.oppgave.treff.length">
                                            <button t-foreach="state.paring.oppgave.treff" t-as="t" t-key="'to'+t.id"
                                                    t-on-click="() => this.velgMal('oppgave', t)">
                                                <span class="kt kt_o" t-esc="t.no || '—'"/><t t-esc="t.navn"/>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="prow psok">
                                        <label>Ansvarlig</label>
                                        <input placeholder="Velg ansvarlig"
                                               t-att-value="state.paring.ansvarlig.tekst"
                                               t-on-input="(ev) => this.sokMal('ansvarlig', ev)"/>
                                        <div class="ptreff" t-if="state.paring.apen === 'ansvarlig' and state.paring.ansvarlig.treff.length">
                                            <button t-foreach="state.paring.ansvarlig.treff" t-as="t" t-key="'ta'+t.id"
                                                    t-on-click="() => this.velgMal('ansvarlig', t)">
                                                <t t-esc="t.navn"/>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="prow">
                                        <label>Frist</label>
                                        <input type="date" t-att-value="state.paring.frist"
                                               t-on-input="(ev) => this.state.paring.frist = ev.target.value"/>
                                    </div>
                                    <div class="prow">
                                        <label></label>
                                        <button class="tbtn primary" t-on-click="tildelAnsvarlig">Tildel ansvarlig</button>
                                    </div>
                                    <div class="savemsg" t-if="state.paring.msg" t-esc="state.paring.msg"/>
                                </div>
                            </div>
                        </t>
                        <div class="readempty" t-else="">Velg en melding for å lese den.</div>
                    </div>

                </div>

                <!-- PERSON-MODAL (klikk «Til stede»-navn) -->
                <div class="pmodal" t-if="state.personOpen">
                    <div class="pmbg" t-on-click="lukkPerson"/>
                    <div class="pmcard">
                        <div class="pmhead">
                            <span class="pmav" t-esc="initialer(state.person.navn)"/>
                            <div class="pmwho">
                                <div class="pmn" t-esc="state.person.navn"/>
                                <div class="pma" t-esc="state.person.epost || '(ingen e-postadresse)'"/>
                            </div>
                            <button class="pmx" t-on-click="lukkPerson">✕</button>
                        </div>
                        <div class="pmact">
                            <button class="tbtn pri" t-on-click="aapneKontakt">✉ E-post / kontakt</button>
                            <button class="tbtn" t-on-click="personChat">💬 Chat</button>
                        </div>
                        <div class="pmtabs">
                            <button t-att-class="'pmtab' + (state.ctxTab==='rel'?' on':'')" t-on-click="() => this.setCtxTab('rel')">Tilknyttede personer</button>
                            <button t-att-class="'pmtab' + (state.ctxTab==='hist'?' on':'')" t-on-click="() => this.setCtxTab('hist')">Siste hos oss</button>
                            <button t-att-class="'pmtab' + (state.ctxTab==='week'?' on':'')" t-on-click="() => this.setCtxTab('week')">Ukesplan</button>
                        </div>
                        <div class="pmbody">
                            <t t-if="state.ctxTab==='rel'">
                                <div t-if="!state.person.relasjoner.length" class="pmempty">Ingen registrerte relasjoner ennå.</div>
                                <div class="rel">
                                    <span class="relc" t-foreach="state.person.relasjoner" t-as="r" t-key="r.id">
                                        <span class="rk" t-esc="r.type_navn"/><t t-esc="r.navn"/>
                                    </span>
                                </div>
                            </t>
                            <t t-if="state.ctxTab==='hist'">
                                <div t-if="!state.person.siste.length" class="pmempty">Ingen nylig aktivitet.</div>
                                <div class="kv" t-foreach="state.person.siste" t-as="s" t-key="s_index">
                                    <span t-att-class="'kk ' + s.type" t-esc="s.type"/>
                                    <span class="kn" t-esc="s.navn"/>
                                    <span class="kd" t-esc="s.dato"/>
                                </div>
                            </t>
                            <t t-if="state.ctxTab==='week'">
                                <div t-if="!state.person.ukesplan.length" class="pmempty">Ingenting planlagt denne uka.</div>
                                <div class="kv" t-foreach="state.person.ukesplan" t-as="u" t-key="u_index">
                                    <span t-att-class="'kk ' + u.type" t-esc="u.type==='kal' ? 'Møte' : 'Oppg'"/>
                                    <span class="kn" t-esc="u.navn"/>
                                    <span class="kd" t-esc="u.dato"/>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
