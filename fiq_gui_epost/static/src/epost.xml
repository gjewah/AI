<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="fiq_gui_epost.MsgSenter">
        <div class="msapp">
            <div t-if="state.loading" class="loading">Laster Meldingssenter…</div>
            <t t-else="">

                <!-- TIL STEDE NÅ -->
                <div class="presence">
                    <span class="pl">Til stede nå</span>
                    <t t-foreach="state.presence.slice(0,8)" t-as="p" t-key="p.id">
                        <span t-att-class="'pc ' + pcls(p.status)">
                            <span class="pa" t-esc="initialer(p.navn)"/>
                            <t t-esc="p.navn"/>
                        </span>
                    </t>
                </div>

                <!-- Topplinje -->
                <div class="top">
                    <img t-if="state.logo" class="logo logoimg" t-att-src="state.logo" alt="Firmalogo"/>
                    <div t-else="" class="logo" t-esc="'FIQ'"/>
                    <div class="brand">
                        <div class="eb">FIQ Kontrollrom · 8.50 GUI · V00.05</div>
                        <div class="ti">Meldingssenter</div>
                    </div>
                    <div class="sp"/>
                    <div class="switch">
                        <button t-foreach="state.firms" t-as="f" t-key="f.id"
                                t-att-class="'swb' + (f.id===state.current_firm?' on':'')"
                                t-on-click="() => this.byttFirma(f.id)">
                            <b t-esc="f.kode || ''"/><span t-esc="f.navn"/>
                        </button>
                    </div>
                    <button class="ubtn ai">✦ AI</button>
                    <button class="ubtn kr" t-on-click="tilbakeKR">‹ Kontrollrom</button>
                </div>

                <!-- TRE-RUTE: mappetre | liste | lese-/kontekstpanel -->
                <div class="pane">

                    <!-- Venstre: mappetre -->
                    <div class="tree">
                        <button t-att-class="'home' + (state.view==='hjem'?' on':'')" t-on-click="visHjem">
                            🏠 <span>Hjem — områdeoversikt</span>
                        </button>

                        <div class="sh">Postkasse</div>
                        <div class="nav">
                            <button t-foreach="state.basis" t-as="b" t-key="b.kode"
                                    t-att-class="(state.view==='inbox' &amp;&amp; state.aktivBoks===b.kode?'on':'') + ' cd_' + b.farge"
                                    t-on-click="() => this.aapneBoks(b.kode, b.navn)">
                                <span class="dot"/><t t-esc="b.navn"/>
                                <span class="c tnum" t-esc="b.count"/>
                            </button>
                        </div>

                        <div class="sh">Smarte mapper — taksonomi</div>
                        <div class="nav">
                            <button t-foreach="state.taks" t-as="b" t-key="b.kode"
                                    t-att-class="(state.view==='inbox' &amp;&amp; state.aktivBoks===b.kode?'on':'') + ' cd_' + b.farge"
                                    t-on-click="() => this.aapneBoks(b.kode, b.navn)">
                                <span class="code" t-esc="b.kode"/><t t-esc="b.navn"/>
                                <span class="c tnum" t-esc="b.count"/>
                            </button>
                            <button t-foreach="state.tverr" t-as="b" t-key="b.kode"
                                    t-att-class="(state.view==='inbox' &amp;&amp; state.aktivBoks===b.kode?'on':'') + ' cd_' + b.farge"
                                    t-on-click="() => this.aapneBoks(b.kode, b.navn)">
                                <span class="dot"/><t t-esc="b.navn"/>
                                <span class="c tnum" t-esc="b.count"/>
                            </button>
                        </div>

                        <div class="sh">Mer</div>
                        <div class="nav">
                            <button class="cd_blaa" t-on-click="aapneKalender"><span class="dot"/>Møter &amp; Kalender</button>
                            <button class="cd_tealx" t-on-click="() => this.aapneBoks('motereferater','Møtereferater')"><span class="dot"/>Møtereferater</button>
                            <button class="cd_graa" t-on-click="aapneInnstillinger"><span class="dot"/>Innstillinger</button>
                        </div>
                    </div>

                    <!-- HJEM: cockpit-oversikt (fargebokser) -->
                    <div class="col hjem" t-if="state.view==='hjem'">
                        <div class="hjemhead">
                            <div class="crumb"><span class="cur">Områdeoversikt</span></div>
                            <button class="tilbakeb" t-on-click="visInnboks">Til innboks ›</button>
                        </div>
                        <div class="sub-lbl">Tverrgående</div>
                        <div class="boxes">
                            <button t-foreach="state.tverr" t-as="b" t-key="b.kode"
                                    t-att-class="'box c_' + b.farge"
                                    t-on-click="() => this.aapneBoks(b.kode, b.navn)">
                                <div class="bl"><span class="nm" t-esc="b.navn"/></div>
                                <div class="n tnum" t-esc="b.count"/>
                            </button>
                        </div>
                        <div class="sub-lbl">Områder</div>
                        <div class="boxes">
                            <button t-foreach="state.taks" t-as="b" t-key="b.kode"
                                    t-att-class="'box c_' + b.farge"
                                    t-on-click="() => this.aapneBoks(b.kode, b.navn)">
                                <div class="bl"><span class="code" t-esc="b.kode"/><span class="nm" t-esc="b.navn"/></div>
                                <div class="n tnum" t-esc="b.count"/>
                            </button>
                        </div>
                    </div>

                    <!-- MIDT: meldingsliste -->
                    <div class="col list" t-if="state.view==='inbox'">
                        <div class="lhead">
                            <input class="lsok" type="search" placeholder="Søk avsender, emne, prosjektnr…"
                                   t-att-value="state.q" t-on-change="sok"/>
                            <select class="lgrp" t-on-change="setGroup">
                                <option value="avsender">Avsender</option>
                                <option value="prosjekt">Prosjekt</option>
                                <option value="dato">Dato</option>
                                <option value="type">Type</option>
                            </select>
                            <button class="lgrp" t-on-click="toggleAlle" t-esc="kollapsLabel()"/>
                        </div>
                        <div class="listbody">
                            <div t-if="!state.meldinger.length" class="empty">Ingen meldinger i <t t-esc="state.aktivNavn"/>.</div>
                            <t t-foreach="grupper()" t-as="g" t-key="g.key">
                                <button class="grp" t-on-click="() => this.toggleGroup(g.key)">
                                    <span class="ch" t-esc="state.kollaps[g.key] ? '▸' : '▾'"/>
                                    <span class="gk" t-esc="g.key"/>
                                    <span class="gc tnum" t-esc="g.n"/>
                                </button>
                                <t t-if="!state.kollaps[g.key]">
                                    <button t-foreach="g.items" t-as="m" t-key="m.id"
                                            t-att-class="'mi' + (state.valgt?.id===m.id?' on':'') + (m.ulest?' un':'')"
                                            t-on-click="() => this.velgMelding(m)">
                                        <div class="r1"><span class="fr" t-esc="m.fra"/><span class="tm" t-esc="m.dato"/></div>
                                        <div class="su" t-esc="m.emne"/>
                                        <div class="pv" t-esc="m.preview"/>
                                        <div class="r3" t-if="m.status || m.element || m.risiko">
                                            <span t-if="m.risiko==='hoy'" class="chip risk">⚠ Mulig svindel</span>
                                            <span t-if="m.status" t-att-class="'chip ' + statuscls(m.status)" t-esc="m.status_navn || m.status"/>
                                            <span t-if="m.element" class="chip el" t-esc="m.element"/>
                                        </div>
                                    </button>
                                </t>
                            </t>
                        </div>
                    </div>

                    <!-- HØYRE: lese- og kontekstpanel -->
                    <div class="col read" t-if="state.view==='inbox'">
                        <t t-if="state.valgt">
                            <div class="rtool">
                                <button class="tbtn pri" t-on-click="() => this.svar(false)">Svar</button>
                                <button class="tbtn" t-on-click="() => this.svar(true)">Svar alle</button>
                                <button class="tbtn">Videresend</button>
                                <button class="tbtn">Arkivér</button>
                                <button class="tbtn">Tildel ansvarlig</button>
                                <button class="tbtn ai">✦ AI</button>
                            </div>
                            <div class="rbody">
                                <h3 class="rsub" t-esc="state.valgt.emne"/>
                                <div class="rmeta">
                                    <span class="ra" t-esc="initialer(state.valgt.fra)"/>
                                    <div>
                                        <div class="who" t-esc="state.valgt.fra"/>
                                        <div class="addr" t-esc="state.valgt.adresse"/>
                                    </div>
                                    <div class="rt">
                                        <div t-esc="state.valgt.dato"/>
                                        <div t-if="state.valgt.til.length">Til: <t t-esc="state.valgt.til.join(', ')"/></div>
                                    </div>
                                </div>

                                <!-- AI-sammendrag (vises når backend gir det) -->
                                <div class="card aisum" t-if="state.valgt.ai_sammendrag">
                                    <div class="ch"><span class="icn">✦</span>AI-sammendrag</div>
                                    <div class="prose" t-esc="state.valgt.ai_sammendrag"/>
                                </div>

                                <!-- Meldingstekst -->
                                <div class="prose body" t-esc="state.valgt.preview"/>

                                <!-- Paring / tildeling (eksisterende backend) -->
                                <div class="card paring">
                                    <div class="ch"><span class="icn">🔗</span>Paring / tildeling</div>
                                    <div class="kobling">
                                        <div class="kh">🤖 Hører sannsynligvis til (nyeste øverst)</div>
                                        <div t-if="!harKobling()" class="ktom">Fant ingen kobling for denne avsenderen ennå.</div>
                                        <button class="kand" t-foreach="state.kandidater.prosjekt" t-as="k" t-key="'p'+k.id">
                                            <span class="kt kt_p">Prosjekt</span><span class="kn" t-esc="(k.no ? k.no + ' ' : '') + k.navn"/>
                                        </button>
                                        <button class="kand" t-foreach="state.kandidater.oppgave" t-as="k" t-key="'o'+k.id">
                                            <span class="kt kt_o">Oppgave</span><span class="kn" t-esc="(k.no ? k.no + ' ' : '') + k.navn"/>
                                        </button>
                                    </div>
                                    <div class="prow"><label>Prosjekt</label><input placeholder="Prosjektnr eller navn"/></div>
                                    <div class="prow"><label>Oppgave</label><input placeholder="Oppgavenr eller navn"/></div>
                                    <div class="prow"><label>Ansvarlig</label><input placeholder="Velg ansvarlig"/></div>
                                    <div class="prow"><label>Frist</label><input placeholder="dd.mm.åååå"/></div>
                                </div>
                            </div>
                        </t>
                        <div class="readempty" t-else="">Velg en melding for å lese den.</div>
                    </div>

                </div>
            </t>
        </div>
    </t>
</templates>
