<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Multicompany: en bruker ser kun arbeidsstatus/notater for sine firmaer.
         company_id = False → delt/uspesifisert (synlig for alle). -->
    <record id="rule_msg_state_company" model="ir.rule">
        <field name="name">Meldingssenter status: firma-scoping</field>
        <field name="model_id" ref="model_fiq_meldingssenter_state"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_msg_note_company" model="ir.rule">
        <field name="name">Meldingssenter notat: firma-scoping</field>
        <field name="model_id" ref="model_fiq_meldingssenter_note"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>
    <!-- Pinn er PERSONLIG: hver bruker ser kun sine egne.
         🛑 Her holder det ikke med firma-scoping som for de andre. En pinn betyr
         «jeg må ikke miste denne av syne» — så en delt pinneliste ville fylt flaten
         med andres påminnelser og gjort funksjonen ubrukelig. Derfor user_id, ikke
         company_id, som skille. -->
    <record id="rule_msg_pinn_egen" model="ir.rule">
        <field name="name">Meldingssenter pinn: kun egne</field>
        <field name="model_id" ref="model_fiq_meldingssenter_pinn"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
    </record>
    <record id="rule_partner_relation_company" model="ir.rule">
        <field name="name">Kontakt-relasjon: firma-scoping</field>
        <field name="model_id" ref="model_fiq_partner_relation"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_komm_regel_company" model="ir.rule">
        <field name="name">Rutingregel: firma-scoping</field>
        <field name="model_id" ref="model_fiq_komm_regel"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
