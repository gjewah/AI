<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FIQs rettighetsgruppe for FIQ GUI E-post/Kommunikasjon (Odoo 19: kun name + implied_ids). -->
    <record id="group_user" model="res.groups">
        <field name="name">FIQ GUI E-post/Kommunikasjon / Bruker</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- ALLE interne brukere får tilgang til denne flaten -->
    <record id="base.group_user" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('fiq_gui_epost.group_user'))]"/>
    </record>
</odoo>
