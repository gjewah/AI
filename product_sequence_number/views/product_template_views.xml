<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="product_template_view_tree" model="ir.ui.view">
        <field name="name">product.template.view.tree.inherit.sequence_number</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view" />
        <field name="arch" type="xml">
            <field name="name" position="before">
                <field name="company_code" optional="hide" />
                <field
                    name="sequence_number"
                    optional="hide"
                    readonly="1"
                />
            </field>
        </field>
    </record>
    <record id="product_template_view_search" model="ir.ui.view">
        <field name="name">product.template.view.search.inherit.sequence_number</field>
        <field name="model">product.template</field>
        <field name="priority">99</field>
        <field name="inherit_id" ref="product.product_template_search_view" />
        <field name="arch" type="xml">
            <field name="name" position="attributes">
                <attribute
                    name="filter_domain"
                >['|', '|', ('name', 'ilike', self), ('company_code', 'ilike', self), ('sequence_number', 'ilike', self)]</attribute>
            </field>
        </field>
    </record>
    <record id="product_template_view_form" model="ir.ui.view">
        <field name="name">product.template.view.form.inherit.sequence_number</field>
        <field name="model">product.template</field>
        <!-- <field name="inherit_id" ref="product.product_template_only_form_view" /> -->
        <field name="inherit_id" ref="product.product_template_form_view" />
        <field name="arch" type="xml">
            <label for="name" position="replace"/>
            <h1 position="before">
                <div class="d-flex h3">
                    <!-- <label for="sequence_number" string="No." /> -->
                    <field name="sequence_number" decoration-bf="1" readonly="1" />
                </div>
            </h1>
        </field>
    </record>
    <record id="product_template_view_kanban" model="ir.ui.view">
        <field name="name">product.template.view.kanban.inherit.sequence_number</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_kanban_view" />
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('d-flex', 'mb-0', 'h5')]" position="before">
                <div class="d-flex mb-0 h3">
                    <field name="sequence_number" string="Product No." decoration-bf="1" readonly="1" />
                </div>
            </xpath>
        </field>
    </record>
</odoo>
