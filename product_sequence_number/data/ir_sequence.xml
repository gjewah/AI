<?xml version="1.0" encoding="utf-8" ?>
<odoo noupdate="1">
    <record id="product_template_sequence" model="ir.sequence">
        <field name="name">Product Template Sequence</field>
        <field name="code">product.template</field>
        <field name="prefix">PT</field>
        <field name="padding">7</field>
        <field name="number_next_actual">1000000</field>
        <field name="company_id" eval="False" />
    </record>
    <record id="product_variant_sequence" model="ir.sequence">
        <field name="name">Product Variant Sequence</field>
        <field name="code">product.product</field>
        <field name="prefix">PV</field>
        <field name="padding">7</field>
        <field name="number_next_actual">1000000</field>
        <field name="company_id" eval="False" />
    </record>
</odoo>
