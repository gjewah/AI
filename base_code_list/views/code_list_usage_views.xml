<odoo>
    <record id="code_list_usage_view_list" model="ir.ui.view">
        <field name="model">code.list.usage</field>
        <field name="arch" type="xml">
            <list editable="bottom" >
                <field name="model"/>
                <field name="resource_id"/>
                <field name="code_list_id" />
                <field name="code_list_item_id" />
            </list>
        </field>
    </record>
    <record id="code_list_usage_view_search" model="ir.ui.view">
        <field name="model">code.list.usage</field>
        <field name="arch" type="xml">
            <search>
                <field name="model"/>
                <field name="resource_id" />
                <field name="code_list_id" />
                <field name="code_list_item_id" />
            </search>
        </field>
    </record>
    <record id="code_list_usage_action" model="ir.actions.act_window">
        <field name="name">Code List Usages</field>
        <field name="res_model">code.list.usage</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
