<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- VIEWS -->
    <record id="tag_view_list" model="ir.ui.view">
        <field name="name">res.users.tag.list</field>
        <field name="model">res.users.tag</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>
    <record id="tag_view_search" model="ir.ui.view">
        <field name="name">res.users.tag.search.inherit</field>
        <field name="model">res.users.tag</field>
        <field name="arch" type="xml">
            <search>
                <filter
                    name="my_tags"
                    string="My Tags"
                    domain="[('id', 'in', context.get('user_tag_ids', []))]"
                />
            </search>
        </field>
    </record>

    <!-- ACTIONS -->
    <record id="tag_window_action" model="ir.actions.act_window">
        <field name="name">User Tags</field>
        <field name="res_model">res.users.tag</field>
        <field name="view_mode">list</field>
    </record>
    <record id="tag_server_action" model="ir.actions.server">
        <field name="name">Open User Tags</field>
        <field name="model_id" ref="model_res_users_tag"/>
        <field name="state">code</field>
        <field name="code">
action = model.action_open_tags()
        </field>
    </record>

    <!-- MENUITEMS -->
    <menuitem id="res_users_tag_menu" name="User Tags" action="tag_window_action" parent="base.menu_administration"/>
</odoo>
