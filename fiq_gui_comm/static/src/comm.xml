<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="fiq_gui_comm.Kommunikasjon">
        <div class="commapp">
            <div t-if="state.loading" class="loading">Laster Kommunikasjon…</div>
            <t t-else="">

                <!-- Topplinje -->
                <div class="top">
                    <div class="logo">FIQ</div>
                    <div class="brand">
                        <div class="eb">FIQ Kontrollrom · 8.50 GUI · V01</div>
                        <div class="ti">Kommunikasjon</div>
                    </div>
                    <div class="sp"/>
                    <div class="switch" t-if="state.firms.length > 1">
                        <button t-foreach="state.firms" t-as="f" t-key="f.id"
                                t-att-class="'swb' + (f.id===state.current_firm?' on':'')"
                                t-on-click="() => this.byttFirma(f.id)">
                            <b t-esc="f.kode || ''"/><span t-esc="f.navn"/>
                        </button>
                    </div>
                    <button class="ubtn kr" t-on-click="tilbakeKR">‹ Kontrollrom</button>
                </div>

                <!-- KANAL-FILTER: Alle · E-post · (WhatsApp · Teams · chat når de kommer) -->
                <div class="kanaler">
                    <button t-foreach="state.kanaler" t-as="k" t-key="k.kode"
                            t-att-class="kanalCls(k)" t-on-click="() => this.velgKanal(k.kode)">
                        <span class="ki" t-esc="k.ikon"/>
                        <span class="kn" t-esc="k.navn"/>
                        <span class="kc tnum" t-if="k.antall" t-esc="k.antall"/>
                    </button>
                </div>

                <!-- TIL STEDE — samme kilde som Kontrollrommet (KR-kjernen eier presence,
                     så det betyr det samme overalt). -->
                <div class="presence" t-if="state.presence.length">
                    <span class="pl">Til stede nå</span>
                    <div class="pchips">
                        <span t-foreach="state.presence" t-as="p" t-key="p.id || p.navn"
                              t-att-class="'pc ' + (p.status || 'fra')">
                            <span class="pa" t-esc="p.initialer || (p.navn || '').slice(0,3).toUpperCase()"/>
                            <t t-esc="p.navn"/>
                        </span>
                    </div>
                </div>

                <div class="wrap">
                    <!-- VENSTRE: TO menyer, i tillegg til hverandre (Gjermund 19.07.2026:
                         «i tillegg»). Øverst KR-hovedmenyen — den skal stå fast; under
                         Kommunikasjons eget mappetre (kanalene). De blandes aldri. -->
                    <aside class="side">
                        <t t-if="state.krMeny.length">
                            <div class="sh">Kontrollrom</div>
                            <div class="nav krnav">
                                <button t-foreach="state.krMeny" t-as="f" t-key="f.key"
                                        t-on-click="() => this.aapneKrFlate(f)">
                                    <span class="dot"/><span class="nl" t-esc="f.label"/>
                                </button>
                            </div>
                        </t>

                        <div class="sh">Kanaler</div>
                        <div class="nav">
                            <button t-foreach="state.kanaler" t-as="k" t-key="k.kode"
                                    t-att-class="state.aktivKanal === k.kode ? 'on' : ''"
                                    t-on-click="() => this.velgKanal(k.kode)">
                                <span class="ki" t-esc="k.ikon"/>
                                <span class="nl" t-esc="k.navn"/>
                                <span class="c tnum" t-if="k.antall" t-esc="k.antall"/>
                            </button>
                        </div>
                    </aside>

                    <!-- HØYRE: forsiden = fargeboksene (originalen, ikke hjulene) -->
                    <main class="oversikt">
                        <div t-if="state.kanaler.length &lt;= 1" class="tom">
                            <div class="tomt">Ingen kanaler er installert ennå.</div>
                            <div class="tomh">E-post, WhatsApp, Teams og chat melder seg inn her når de tas i bruk.</div>
                        </div>
                        <t t-else="">
                            <div class="ohead">
                                <span class="oh">Klikk en boks for å åpne meldingene den gjelder.</span>
                                <button class="vt" t-on-click="vekslTomme" t-if="antallTomme()">
                                    <t t-if="state.visTomme">Skjul tomme</t>
                                    <t t-else="">Vis tomme (<t t-esc="antallTomme()"/>)</t>
                                </button>
                            </div>

                            <div t-if="!harBokser()" class="tom">
                                <div class="tomt">Ingen meldinger å vise akkurat nå.</div>
                                <div class="tomh">Boksene dukker opp her så snart det kommer post.</div>
                            </div>

                            <t t-else="">
                                <t t-if="bokser('basis').length">
                                    <div class="gh">Postkasse</div>
                                    <div class="bokser">
                                        <button t-foreach="bokser('basis')" t-as="b" t-key="'b'+b.kode"
                                                t-att-class="boksCls(b)" t-on-click="() => this.aapneBoks(b)">
                                            <div class="bl"><span class="bn" t-esc="b.navn"/></div>
                                            <div class="n tnum" t-esc="b.count || 0"/>
                                        </button>
                                    </div>
                                </t>

                                <t t-if="bokser('tverrgaende').length">
                                    <div class="gh">Tverrgående</div>
                                    <div class="bokser">
                                        <button t-foreach="bokser('tverrgaende')" t-as="b" t-key="'t'+b.kode"
                                                t-att-class="boksCls(b)" t-on-click="() => this.aapneBoks(b)">
                                            <div class="bl"><span class="bn" t-esc="b.navn"/></div>
                                            <div class="n tnum" t-esc="b.count || 0"/>
                                        </button>
                                    </div>
                                </t>

                                <t t-if="bokser('omraade').length">
                                    <div class="gh">Områder</div>
                                    <div class="bokser">
                                        <button t-foreach="bokser('omraade')" t-as="b" t-key="'o'+b.kode"
                                                t-att-class="boksCls(b)" t-on-click="() => this.aapneBoks(b)">
                                            <div class="bl">
                                                <span class="kode" t-esc="b.kode"/>
                                                <span class="bn" t-esc="b.navn"/>
                                            </div>
                                            <div class="n tnum" t-esc="b.count || 0"/>
                                        </button>
                                    </div>
                                </t>
                            </t>
                        </t>
                    </main>
                </div>
            </t>
        </div>
    </t>
</templates>
