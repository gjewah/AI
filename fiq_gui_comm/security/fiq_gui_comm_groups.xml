<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FIQs rettighetsgruppe for Kommunikasjon-flaten (Odoo 19: kun name + implied_ids). -->
    <record id="group_user" model="res.groups">
        <field name="name">FIQ Kommunikasjon / Bruker</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- ALLE interne brukere får tilgang til flaten. Hva de SER inne i den styres av
         000-rettigheten (KR-kjernens har_000_rettighet) + Odoos record rules — ikke av
         denne gruppa. Tilgang til flaten ≠ tilgang til innholdet. -->
    <record id="base.group_user" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('fiq_gui_comm.group_user'))]"/>
    </record>
</odoo>
