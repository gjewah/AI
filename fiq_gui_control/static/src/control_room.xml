<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Gjenbrukbar per-linje fremdrift (lag 2): bar ELLER ring, config-drevet.
         Kall med:  <t t-call="fiq_gui_control.ProgressMini">
                        <t t-set="pct" t-value="rad.progress"/>
                        <t t-set="shape" t-value="state.progressShape"/>
                    </t> -->
    <t t-name="fiq_gui_control.ProgressMini">
        <span t-if="shape === 'ring'" class="fiq_hm_ring" t-att-style="'--p:' + (pct || 0)" t-att-title="(pct || 0) + ' % fullført' + (hrs ? ' · ' + hrs : '')">
            <span class="fiq_hm_ring_t" t-esc="pct || 0"/>
        </span>
        <span t-else="" class="fiq_hm_pbar" t-att-title="(pct || 0) + ' % fullført' + (hrs ? ' · ' + hrs : '')">
            <span class="fiq_hm_pbar_t"><i t-att-style="'width:' + (pct || 0) + '%'"/></span>
            <b t-esc="(pct || 0) + '%'"/>
        </span>
    </t>
    <t t-name="fiq_gui_control.ControlRoom">
        <div class="fiq_hm" t-att-style="'--fiq-accent:' + state.accent + ';'">
            <!-- Topplinje -->
            <div class="fiq_hm_top">
                <div class="fiq_hm_brand">
                    <img src="/fiq_gui_control/static/img/vidir_v.png" class="fiq_hm_logo" alt="Vídir"/>
                </div>

                <!-- Hilsen -->
                <span class="fiq_hm_hilsen"><t t-esc="hilsen"/> 👋 — Kontrollrom · Leder</span>

                <!-- Firma-velger: knappene er firma-LOGOER (Vídir = vidir_v.png; ellers monogram-fallback) -->
                <div class="fiq_hm_firmavelger" t-if="state.companies.length">
                    <t t-foreach="state.companies" t-as="c" t-key="c.id">
                        <button t-att-class="c.id === state.companyId ? 'fiq_hm_firma on' : 'fiq_hm_firma'"
                                t-att-title="c.name" t-on-click="() => this.setCompany(c.id)" t-esc="c.name"/>
                    </t>
                </div>

                <!-- Total / Enkel -->
                <div class="fiq_hm_pseg fiq_hm_modeseg">
                    <button t-att-class="state.mode === 'total' ? 'on' : ''" t-on-click="() => this.setMode('total')">Total</button>
                    <button t-att-class="state.mode === 'enkel' ? 'on' : ''" t-on-click="() => this.setMode('enkel')">Enkel</button>
                </div>

                <button class="btn fiq_hm_refresh" t-att-class="state.refreshing ? 'fiq_hm_refresh spin' : 'fiq_hm_refresh'" t-on-click="() =&gt; this.refresh()" t-att-disabled="state.refreshing" title="Hent live data på nytt"><span class="fiq_hm_refresh_i">⟳</span> <t t-esc="state.refreshing ? 'Oppdaterer …' : 'Oppdater'"/></button>
                <button t-att-class="state.autoRefresh ? 'fiq_hm_auto on' : 'fiq_hm_auto'" t-on-click="() =&gt; this.toggleAuto()"
                        t-att-title="state.autoRefresh ? ('Auto-oppdatering PÅ — henter live data hvert ' + autoMin + '. minutt. Klikk for å skru av.') : ('Skru på auto-oppdatering (hvert ' + autoMin + '. minutt)')">
                    Auto <t t-if="state.autoRefresh">✓</t>
                </button>
                <span t-if="verVis" t-att-class="verVis.avvik ? 'fiq_hm_ver avvik' : 'fiq_hm_ver'" t-att-title="verVis.title">
                    <t t-esc="verVis.text"/><t t-if="verVis.avvik"> ⚠</t>
                </span>
                <button class="btn fiq_hm_gear" t-on-click="() => this.toggleCustomize()">⚙ Innstillinger</button>
            </div>

            <div class="fiq_hm_wrap">
                <!-- Mørk sidemeny -->
                <aside class="fiq_hm_side">
                    <!-- STYRING øverst (primær-nav) -->
                    <div class="fiq_hm_glbl">Styring</div>
                    <div t-att-class="state.view === 'oversikt' ? 'fiq_hm_nav on' : 'fiq_hm_nav'" t-on-click="() => this.setView('oversikt')"><span class="b"/>Kontrollrom</div>
                    <div t-att-class="state.view === 'kommunikasjon' ? 'fiq_hm_nav on' : 'fiq_hm_nav'" t-on-click="() => this.setView('kommunikasjon')"><img class="fiq_hm_navico" src="/fiq_gui_control/static/img/epost.png"/>Kommunikasjon</div>
                    <div t-att-class="state.view === 'hmsks' ? 'fiq_hm_nav on' : 'fiq_hm_nav'" t-on-click="() => this.setView('hmsks')"><span class="b"/>HMS/KS</div>
                    <div t-att-class="state.view === 'airmm' ? 'fiq_hm_nav on' : 'fiq_hm_nav'" t-on-click="() => this.setView('airmm')"><span class="b"/>AI-RMM</div>

                    <!-- Fagområder under: én rad per område (lang strek) + nedtrekk for underområder.
                         Treet leses fra Odoo prosjekt-hierarkiet (SSOT) — ingen hardkodet liste. -->
                    <div class="fiq_hm_glbl">Fagområder (SP)</div>
                    <div class="fiq_hm_alist">
                        <!-- t-key = post-id (unik) — prosjektNUMMER kan duplisere (to «0.90»-maler) -->
                        <t t-foreach="sideAreas" t-as="a" t-key="a.id || a.nr">
                            <div t-att-class="(state.view === 'oversikt' and state.projArea === a.nr) ? 'fiq_hm_arow on' : 'fiq_hm_arow'"
                                 t-att-title="a.nr + ' ' + a.name" t-on-click="() => this.pickArea(a.nr, a.id)">
                                <span t-att-class="a.dk ? 'fiq_hm_asq dk' : 'fiq_hm_asq'" t-att-style="'--sp:' + a.color + ';'" t-esc="a.nr"/>
                                <span class="fiq_hm_aname" t-esc="a.name"/>
                                <button t-if="a.subs.length" class="fiq_hm_achev" t-att-title="state.areaOpen[a.nr] ? 'Lukk underområder' : 'Vis underområder'"
                                        t-on-click.stop="() => this.toggleArea(a.nr)" t-esc="state.areaOpen[a.nr] ? '▾' : '▸'"/>
                            </div>
                            <t t-if="state.areaOpen[a.nr]">
                                <div t-foreach="a.subs" t-as="s" t-key="s.id"
                                     t-att-class="(state.view === 'oversikt' and state.projArea === s.nr) ? 'fiq_hm_asub on' : 'fiq_hm_asub'"
                                     t-on-click="() => this.pickArea(s.nr, s.id)">
                                    <span class="fiq_hm_asubnr" t-esc="s.nr"/>
                                    <span class="fiq_hm_aname" t-esc="s.name"/>
                                </div>
                            </t>
                        </t>
                    </div>
                </aside>

                <section class="fiq_hm_main">
                    <!-- Filter-stripe: Dag/Uke/Måned/Alle + søk (nå i innholdskolonnen) -->
                    <div class="fiq_hm_filter">
                        <div class="fiq_hm_pseg">
                            <button t-foreach="[['dag','Dag'],['uke','Uke'],['maaned','Måned'],['alle','Alle']]" t-as="pp" t-key="pp[0]"
                                    t-att-class="state.kommPeriod === pp[0] ? 'on' : ''"
                                    t-on-click="() => this.setKommPeriod(pp[0])" t-esc="pp[1]"/>
                        </div>
                        <div class="fiq_hm_topfield">
                            <span class="fiq_hm_toplbl">Søk</span>
                            <span class="fiq_hm_srch">
                                <input class="fiq_hm_filtersok" placeholder="Firma, person, prosjekt, oppgave …"
                                       t-att-value="state.kommQuery" t-on-input="(ev) =&gt; state.kommQuery = ev.target.value"/>
                                <span t-if="state.kommQuery" class="fiq_hm_srch_x" t-on-click="() =&gt; state.kommQuery = ''" title="Tøm søk">✕</span>
                            </span>
                        </div>
                        <div class="fiq_hm_topfield fiq_hm_aifield">
                            <span class="fiq_hm_toplbl">✨ Spør AI</span>
                            <div class="fiq_hm_airow">
                                <input class="fiq_hm_filtersok" placeholder="Spør Claude om hjelp …"
                                       t-att-value="state.aiQuery" t-on-input="(ev) =&gt; state.aiQuery = ev.target.value"
                                       t-on-keydown="(ev) =&gt; ev.key === 'Enter' ? this.askAi() : null"/>
                                <button class="fiq_hm_ai_send" t-on-click="() =&gt; this.askAi()">Spør</button>
                            </div>
                        </div>
                    </div>
                    <!-- AI responsrute -->
                    <div t-if="state.aiAnswer" class="fiq_hm_card fiq_hm_airesp">
                        <div class="fiq_hm_airesp_h"><span class="fiq_hm_airesp_t">✨ Svar fra AI</span><span class="fiq_hm_airesp_x" t-on-click="() =&gt; this.clearAi()" title="Lukk">✕</span></div>
                        <div class="fiq_hm_airesp_b" t-esc="state.aiAnswer"/>
                    </div>
                    <!-- Tilpass-panel: dynamisk vis/skjul -->
                    <div t-if="state.customize" class="fiq_hm_cust">
                        <strong>Innstillinger – velg innhold i kontrollrommet</strong>
                        <div class="fiq_hm_toggles">
                            <t t-foreach="['kpis','projects','kommunikasjon','activity','tasks','chart','copilot','quick']" t-as="w" t-key="w">
                                <label>
                                    <input type="checkbox" t-att-checked="state.show[w]" t-on-change="() => this.toggleWidget(w)"/>
                                    <span t-esc="w"/>
                                </label>
                            </t>
                        </div>
                    </div>
                    <div t-if="state.loading" class="fiq_hm_loading">Laster …</div>

                    <!-- Fagflate-visning (Prosjekt/CRM/… + SP-områder) som integrert placeholder i skallet -->
                    <div t-if="!state.loading and area" class="fiq_hm_card fiq_hm_area">
                        <img t-if="area.icon" class="fiq_hm_area_ico" t-att-src="'/fiq_gui_control/static/img/' + area.icon"/>
                        <div t-elif="area.color" class="fiq_hm_area_mono" t-att-style="'background:' + area.color + ';'" t-esc="area.title.slice(0,1)"/>
                        <h4 t-esc="area.title"/>
                        <p class="fiq_hm_area_txt">Egen flate under utvikling – innhold kommer her. Forventes levert: 2026-08-07.</p>
                    </div>

                    <!-- =================== OVERSIKT (Leder: rapport-opp / styring ved unntak) =================== -->
                    <t t-if="!state.loading and state.view === 'oversikt'">

                        <!-- (1) Til stede nå -->
                        <div t-att-class="'fiq_hm_card' + (state.collapsed.presence ? ' fiq_hm_collapsed' : '')">
                            <div class="fiq_hm_ch"><h4>👥 Til stede nå</h4><button class="fiq_hm_coll" t-on-click="() =&gt; this.toggleCollapse('presence')" t-esc="state.collapsed.presence ? 'Vis ▸' : 'Skjul ▾'"/></div>
                            <t t-if="state.presence.length">
                                <div class="fiq_hm_presence">
                                    <t t-foreach="state.presence" t-as="pr" t-key="pr.id">
                                        <div t-att-class="'fiq_hm_chip_p fiq_hm_chip_click fiq_hm_pres_' + (pr.farge || 'red')" t-att-title="pr.tekst + ' — chat med ' + pr.navn" t-on-click="() =&gt; this.openColleagueChat(pr)">
                                            <span class="fiq_hm_avatar">
                                                <span class="fiq_hm_ini" t-esc="pr.initialer"/>
                                                <img t-if="pr.has_photo" class="fiq_hm_photo" t-att-src="'/web/image/res.users/' + pr.id + '/avatar_128'" t-att-alt="pr.navn" t-on-error="(ev) =&gt; ev.target.style.display = 'none'"/>
                                                <span t-att-class="'fiq_hm_dot ' + (pr.farge || 'red')"/>
                                            </span>
                                            <span class="fiq_hm_pcol">
                                                <span class="fiq_hm_pnavn" t-esc="pr.navn"/>
                                                <span class="fiq_hm_pstat" t-esc="pr.tekst"/>
                                            </span>
                                        </div>
                                    </t>
                                </div>
                            </t>
                            <t t-else=""><div class="fiq_hm_empty">Ingen registrerte interne brukere.</div></t>
                        </div>

                        <!-- Statuslinje: KPI + krever-handling som klikkbare knapper -->
                        <div t-if="state.show.kpis" class="fiq_hm_statusrow">
                            <t t-foreach="state.kpis" t-as="k" t-key="k.key">
                                <div t-att-class="state.selectedKpi === k.key ? 'fiq_hm_kpi on' : 'fiq_hm_kpi'" t-on-click="() =&gt; this.selectKpi(k.key)">
                                    <div class="v" t-esc="k.v"/>
                                    <div class="l"><span t-att-class="'fiq_hm_kdot ' + (k.dot || '')"/><t t-esc="k.l"/><t t-if="k.sub"> · <t t-esc="k.sub"/></t></div>
                                </div>
                            </t>
                        </div>
                        <!-- Detaljlinjer for valgt knapp (frigjort plass) -->
                        <div t-if="state.show.kpis" class="fiq_hm_card fiq_hm_detail">
                            <t t-if="kpiDetailLines.length">
                                <t t-foreach="kpiDetailLines" t-as="dl" t-key="dl_index">
                                    <div class="fiq_hm_detail_l" t-on-click="() =&gt; this.openDetail(dl)">
                                        <span class="fiq_hm_detail_dot"/>
                                        <span class="fiq_hm_detail_t" t-esc="dl.text"/>
                                    </div>
                                </t>
                            </t>
                            <t t-else=""><div class="fiq_hm_empty">Ingen linjer å vise for valget.</div></t>
                        </div>

                        <!-- (4) Beslutningsstøtte: 4 kolonner tilpassbare knapper -->
                        <div t-att-class="'fiq_hm_card' + (state.collapsed.beslutning ? ' fiq_hm_collapsed' : '')">
                            <div class="fiq_hm_ch"><h4>Beslutningsstøtte</h4><button class="fiq_hm_coll" t-on-click="() =&gt; this.toggleCollapse('beslutning')" t-esc="state.collapsed.beslutning ? 'Vis ▸' : 'Skjul ▾'"/></div>
                            <div class="fiq_hm_bs">
                                <div class="fiq_hm_bs_col">
                                    <div class="fiq_hm_bs_h">Opprett</div>
                                    <button class="fiq_hm_bs_btn fiq_hm_bc_prj" t-on-click="() => this.runAction('nytt_prosjekt')">＋ Nytt prosjekt</button>
                                    <button class="fiq_hm_bs_btn fiq_hm_bc_sal" t-on-click="() => this.runAction('salgsordre')">＋ Salgsordre</button>
                                    <button class="fiq_hm_bs_btn fiq_hm_bc_prj" t-on-click="() => this.runAction('nytt_prosjekt')">＋ PRJ</button>
                                </div>
                                <div class="fiq_hm_bs_col">
                                    <div class="fiq_hm_bs_h">Salg</div>
                                    <button class="fiq_hm_bs_btn fiq_hm_bc_sal" t-on-click="() => this.runAction('nytt_leads')">＋ Nytt leads</button>
                                    <button class="fiq_hm_bs_btn fiq_hm_bc_sal" t-on-click="() => this.runAction('tilbud')">＋ Tilbud</button>
                                    <button class="fiq_hm_bs_btn fiq_hm_bc_sal" t-on-click="() => this.runAction('kunde')">＋ Kunde</button>
                                </div>
                                <div class="fiq_hm_bs_col">
                                    <div class="fiq_hm_bs_h">Hjelp</div>
                                    <button class="fiq_hm_bs_btn fiq_hm_bc_ai" t-on-click="() => this.askAi()">✨ Spør AI om hjelp</button>
                                    <button class="fiq_hm_bs_btn fiq_hm_bc_ai" t-on-click="() => this.askAi()">🗎 Ukesrapport</button>
                                    <button class="fiq_hm_bs_btn fiq_hm_bc_dok" t-on-click="() => this.runAction('dokument')">🗎 Dokument</button>
                                </div>
                                <div class="fiq_hm_bs_col">
                                    <div class="fiq_hm_bs_h">Tilpass</div>
                                    <button class="fiq_hm_bs_btn fiq_hm_bs_add" t-on-click="() => this.addButton()">＋ Legg til knapp</button>
                                </div>
                            </div>
                        </div>

                        <!-- Prosjekt-oversikt + Mine oppgaver (rapport-opp-detalj) -->
                        <!-- Lister: Prosjektoversikt + Mine oppgaver (side om side) -->
                        <div class="fiq_hm_lists">
                            <div t-if="state.show.projects" t-att-class="'fiq_hm_card' + (state.collapsed.prosjekt ? ' fiq_hm_collapsed' : '')">
                                <div class="fiq_hm_ch"><h4>Prosjektoversikt</h4><button class="fiq_hm_coll" t-on-click="() =&gt; this.toggleCollapse('prosjekt')" t-esc="state.collapsed.prosjekt ? 'Vis ▸' : 'Skjul ▾'"/></div>
                                <span class="fiq_hm_srch fiq_hm_srch_blk">
                                    <input class="fiq_hm_psok" placeholder="Søk i prosjekter (navn eller nr.) …" t-att-value="state.projQuery" t-on-input="(ev) =&gt; this.setProjQuery(ev.target.value)"/>
                                    <span t-if="state.projQuery" class="fiq_hm_srch_x" t-on-click="() =&gt; this.setProjQuery('')" title="Tøm søk">✕</span>
                                </span>
                                <!-- Periode (speiler topplinja) + datovelger: planlagt periode i vinduet; uten datoer vises alltid -->
                                <div class="fiq_hm_pperiod">
                                    <div class="fiq_hm_pseg">
                                        <button t-foreach="[['dag','Dag'],['uke','Uke'],['maaned','Måned'],['alle','Alle']]" t-as="pp" t-key="pp[0]"
                                                t-att-class="state.kommPeriod === pp[0] ? 'on' : ''"
                                                t-on-click="() =&gt; this.setKommPeriod(pp[0])" t-esc="pp[1]"/>
                                    </div>
                                    <input type="date" class="fiq_hm_din" t-att-value="state.anchorDate" t-on-change="(ev) =&gt; this.setAnchor(ev.target.value)" title="Referansedato for perioden (Dag/Uke/Måned regnes fra denne)"/>
                                </div>
                                <!-- Fagområde-filtre (rad 1 = toppområder fra prosjekt-treet; rad 2 = undergrupper) -->
                                <div class="fiq_hm_pfilter">
                                    <button t-att-class="!state.projArea ? 'fiq_hm_pfc on' : 'fiq_hm_pfc'" t-on-click="() =&gt; this.setProjArea('')">Alle</button>
                                    <t t-foreach="sideAreas" t-as="o" t-key="o.id || o.nr">
                                        <button t-att-class="(state.projArea === o.nr or chipParent === o.nr) ? 'fiq_hm_pfc on' : 'fiq_hm_pfc'" t-att-style="'--sp:' + o.color + ';'" t-on-click="() =&gt; this.setProjArea(o.nr, o.id)"><span class="fiq_hm_pfc_nr" t-esc="o.nr"/> <t t-esc="o.name"/></button>
                                    </t>
                                </div>
                                <!-- Undergruppe = nedtrekksmeny (variant C, Gjermund 2026-07-03) -->
                                <div t-if="chipSubs.length" class="fiq_hm_pfilter2">
                                    <select class="fiq_hm_subsel" t-on-change="(ev) =&gt; this.pickSub(ev.target.value)">
                                        <option value="" t-att-selected="!isSubActive ? 'selected' : undefined">Undergruppe: alle</option>
                                        <t t-foreach="chipSubs" t-as="s" t-key="s.id">
                                            <option t-att-value="s.id" t-att-selected="state.projAreaId === s.id ? 'selected' : undefined" t-esc="s.nr + ' ' + s.name"/>
                                        </t>
                                    </select>
                                </div>
                                <t t-if="state.projects.length">
                                    <table>
                                        <thead><tr><th>Nr.</th><th>Prosjekt</th><th>Fremdrift</th><th>Oppg</th><th></th></tr></thead>
                                        <tbody>
                                            <t t-foreach="visibleProjects" t-as="p" t-key="p.id">
                                                <tr t-att-class="((state.selected and state.selected.model === 'project.project' and state.selected.id === p.id) ? 'fiq_hm_selrow' : '') + (p.depth ? ' fiq_hm_childrow' : '')">
                                                    <td t-on-click="() =&gt; this.pickProject(p.id, p.name)" t-att-style="p.depth ? ('padding-left:' + (5 + p.depth * 16) + 'px') : ''">
                                                        <button t-if="p.hasLoadedKids" class="fiq_hm_exp" t-att-title="state.treeClosed[p.id] ? 'Vis underprosjekter' : 'Skjul underprosjekter'" t-on-click.stop="() =&gt; this.toggleTree(p.id)" t-esc="state.treeClosed[p.id] ? '▸' : '▾'"/>
                                                        <span t-if="p.depth and !p.hasLoadedKids" class="fiq_hm_childind">↳</span>
                                                        <button t-if="p.hasKids and !p.hasLoadedKids" class="fiq_hm_exp" t-on-click.stop="() =&gt; this.toggleExpand('project.project', p.id)" t-esc="state.expanded['project.project:' + p.id] ? '▾' : '▸'"/>
                                                        <span class="fiq_hm_no" t-esc="p.no"/>
                                                    </td>
                                                    <td t-on-click="() =&gt; this.pickProject(p.id, p.name)" t-esc="p.name"/>
                                                    <td t-on-click="() =&gt; this.pickProject(p.id, p.name)">
                                                        <t t-call="fiq_gui_control.ProgressMini"><t t-set="pct" t-value="p.progress"/><t t-set="shape" t-value="state.progressShape"/><t t-set="hrs" t-value="p.estH ? (p.logH + '/' + p.estH + ' t') : ''"/></t>
                                                    </td>
                                                    <td t-on-click="() =&gt; this.openProjectTasks(p.id)" t-esc="p.taskCount"/>
                                                    <td><span class="fiq_hm_gantt" t-on-click="() =&gt; this.openProjectTasks(p.id, 'gantt')" title="Åpne planlegging">🗓 Planlegging</span></td>
                                                </tr>
                                                <t t-if="state.expanded['project.project:' + p.id]">
                                                    <t t-foreach="state.children['project.project:' + p.id] or []" t-as="c" t-key="c.id">
                                                        <tr class="fiq_hm_childrow">
                                                            <td t-on-click="() =&gt; this.pickProject(c.id, c.name)"><span class="fiq_hm_childind">↳</span><span class="fiq_hm_no" t-esc="c.no"/></td>
                                                            <td t-on-click="() =&gt; this.pickProject(c.id, c.name)" t-esc="c.name"/>
                                                            <td/>
                                                            <td t-esc="c.taskCount"/>
                                                            <td/>
                                                        </tr>
                                                    </t>
                                                </t>
                                            </t>
                                        </tbody>
                                    </table>
                                </t>
                                <t t-else=""><div class="fiq_hm_empty" t-esc="state.projQuery ? 'Ingen prosjekter matcher søket.' : 'Ingen aktive prosjekter ennå.'"/></t>
                            </div>
                            <div t-if="state.show.tasks" t-att-class="'fiq_hm_card' + (state.collapsed.oppgaver ? ' fiq_hm_collapsed' : '')"><div class="fiq_hm_ch"><h4>Mine oppgaver</h4><button class="fiq_hm_coll" t-on-click="() =&gt; this.toggleCollapse('oppgaver')" t-esc="state.collapsed.oppgaver ? 'Vis ▸' : 'Skjul ▾'"/></div>
                                <!-- Oppgavesøk: nummer + fritekst (to felt, server-søk) -->
                                <div class="fiq_hm_tsok">
                                    <span class="fiq_hm_srch fiq_hm_tsok_no">
                                        <input class="fiq_hm_psok" placeholder="Oppg.nr …" t-att-value="state.taskNoQuery" t-on-input="(ev) =&gt; this.setTaskNoQuery(ev.target.value)"/>
                                        <span t-if="state.taskNoQuery" class="fiq_hm_srch_x" t-on-click="() =&gt; this.setTaskNoQuery('')" title="Tøm">✕</span>
                                    </span>
                                    <span class="fiq_hm_srch">
                                        <input class="fiq_hm_psok" placeholder="Søk i oppgaver (fritekst) …" t-att-value="state.taskTextQuery" t-on-input="(ev) =&gt; this.setTaskTextQuery(ev.target.value)"/>
                                        <span t-if="state.taskTextQuery" class="fiq_hm_srch_x" t-on-click="() =&gt; this.setTaskTextQuery('')" title="Tøm">✕</span>
                                    </span>
                                </div>
                                <!-- Filter: stadium + milepæl -->
                                <div t-if="taskStageChips.length or taskMileChips.length" class="fiq_hm_pfilter">
                                    <t t-foreach="taskStageChips" t-as="sc" t-key="sc.name">
                                        <button t-att-class="state.taskStage === sc.name ? 'fiq_hm_pfc on' : 'fiq_hm_pfc'" t-on-click="() =&gt; this.toggleTaskStage(sc.name)"><t t-esc="sc.name"/> <span class="fiq_hm_stchip_n" t-esc="sc.count"/></button>
                                    </t>
                                    <t t-foreach="taskMileChips" t-as="mc" t-key="mc.name">
                                        <button t-att-class="state.taskMile === mc.name ? 'fiq_hm_pfc on' : 'fiq_hm_pfc'" t-on-click="() =&gt; this.toggleTaskMile(mc.name)">🏁 <t t-esc="mc.name"/> <span class="fiq_hm_stchip_n" t-esc="mc.count"/></button>
                                    </t>
                                </div>
                                <!-- Kolonneoverskrifter -->
                                <div class="fiq_hm_th">
                                    <span class="h_no">Nr.</span>
                                    <span class="h_name">Oppgave</span>
                                    <span class="h_prj">Prosjekt</span>
                                    <span t-if="state.hasHours" class="h_est">Est.</span>
                                    <span class="h_prog">Fremdrift</span>
                                </div>
                                <t t-if="filteredMyTasks.length">
                                    <t t-foreach="filteredMyTasks" t-as="t" t-key="t.id">
                                        <div t-att-class="'fiq_hm_task' + ((state.selected and state.selected.model === 'project.task' and state.selected.id === t.id) ? ' fiq_hm_selrow' : '')">
                                            <button t-if="t.hasKids" class="fiq_hm_exp" t-on-click.stop="() =&gt; this.toggleExpand('project.task', t.id)" t-esc="state.expanded['project.task:' + t.id] ? '▾' : '▸'"/>
                                            <span class="fiq_hm_no" t-esc="t.no" t-on-click="() =&gt; this.selectEl('project.task', t.id, t.name)"/>
                                            <span class="fiq_hm_task_n" t-esc="t.name" t-on-click="() =&gt; this.selectEl('project.task', t.id, t.name)"/>
                                            <span class="fiq_hm_task_p" t-esc="t.project"/>
                                            <span t-if="state.hasHours" class="fiq_hm_est" title="Estimerte (antatte) timer – juster; fremdrift = førte ÷ estimerte">
                                                <input type="number" step="0.5" min="0" class="fiq_hm_esti" t-att-value="t.estH || ''" t-on-change="(ev) =&gt; this.setTaskEst(t.id, ev.target.value)"/><span class="fiq_hm_estu">t est.</span>
                                            </span>
                                            <t t-call="fiq_gui_control.ProgressMini"><t t-set="pct" t-value="t.progress"/><t t-set="shape" t-value="state.progressShape"/><t t-set="hrs" t-value="t.estH ? (t.logH + '/' + t.estH + ' t') : ''"/></t>
                                            <span t-if="t.overdue" class="fiq_hm_warn">⚠ forsinket</span>
                                        </div>
                                        <t t-if="state.expanded['project.task:' + t.id]">
                                            <t t-foreach="state.children['project.task:' + t.id] or []" t-as="c" t-key="c.id">
                                                <div class="fiq_hm_task fiq_hm_childrow" t-on-click="() =&gt; this.selectEl('project.task', c.id, c.name)">
                                                    <span class="fiq_hm_childind">↳</span>
                                                    <span class="fiq_hm_no" t-esc="c.no"/>
                                                    <span class="fiq_hm_task_n" t-esc="c.name"/>
                                                </div>
                                            </t>
                                        </t>
                                    </t>
                                </t>
                                <t t-else=""><div class="fiq_hm_empty">Ingen åpne oppgaver tildelt deg.</div></t>
                            </div>
                        </div>

                        <!-- Arbeidsflate: 80 % Gantt/Liste + 20 % inspektor -->
                        <div class="fiq_hm_work">
                            <div class="fiq_hm_work_main">
                                <div t-if="state.show.chart" class="fiq_hm_card">
                                    <div class="fiq_hm_rhead">
                                        <h4 t-esc="state.progLevel === 'oppgave' ? 'Oppgavefremdrift' : 'Prosjektfremdrift'"/>
                                        <div class="fiq_hm_rseg">
                                            <button t-att-class="state.rightView === 'liste' ? 'on' : ''" t-on-click="() =&gt; this.setRightView('liste')">Liste</button>
                                            <button t-att-class="state.rightView === 'gantt' ? 'on' : ''" t-on-click="() =&gt; this.setRightView('gantt')">Gantt</button>
                                        </div>
                                        <t t-if="state.progLevel === 'prosjekt'">
                                            <button class="fiq_hm_ext" t-on-click="() =&gt; this.showTasksSelected()" title="Vis oppgavefremdrift (valgt prosjekt, ellers første)">▸ Oppgaver</button>
                                        </t>
                                        <t t-else="">
                                            <button class="fiq_hm_ext" t-on-click="() =&gt; this.backToProjects()" title="Tilbake til prosjektfremdrift">◂ Prosjekter</button>
                                            <span class="fiq_hm_proglvl" t-att-title="state.progProjName" t-esc="state.progProjName"/>
                                        </t>
                                        <button class="fiq_hm_ext" t-on-click="() =&gt; this.openProsjektKontrollrom()" title="Åpne Prosjekt-kontrollrommet (utvidet)">⤢ Utvidet</button>
                                    </div>
                                    <!-- Stadie-velger (kun oppgave-drill): velg hvilke stadier som vises. AI-stadier først. -->
                                    <div t-if="state.progLevel === 'oppgave' and progStageChips.length" class="fiq_hm_stagesel">
                                        <span class="fiq_hm_stagesel_l">Vis stadier:</span>
                                        <t t-foreach="progStageChips" t-as="sc" t-key="sc.name">
                                            <button t-att-class="'fiq_hm_stchip' + (sc.hidden ? ' off' : '') + (sc.ai ? ' ai' : '')" t-on-click="() =&gt; this.toggleStage(sc.name)" t-att-title="(sc.ai ? 'AI-stadium · ' : '') + (sc.hidden ? 'skjult' : 'vises')">
                                                <span t-if="sc.ai" class="fiq_hm_stchip_ai">✦</span>
                                                <span class="fiq_hm_stchip_t" t-esc="sc.name"/>
                                                <span class="fiq_hm_stchip_n" t-esc="sc.count"/>
                                            </button>
                                        </t>
                                    </div>
                                    <t t-if="state.rightView === 'liste'">
                                        <t t-if="progRows.length">
                                            <t t-foreach="progRows" t-as="p" t-key="p.id">
                                                <div t-if="p.isHead" class="fiq_hm_ghead">👤 <t t-esc="p.name"/> <span class="fiq_hm_stchip_n" t-esc="p.count"/></div>
                                                <div t-else="" t-att-class="'fiq_hm_rrow' + ((state.selected and state.selected.model === progModel and state.selected.id === p.id) ? ' fiq_hm_selrow' : '')" t-on-click="() =&gt; this.pickRow(p)">
                                                    <span class="fiq_hm_no" t-esc="p.no"/>
                                                    <span class="fiq_hm_rname" t-esc="p.name"/>
                                                    <span t-if="state.progLevel === 'oppgave' and p.stage" class="fiq_hm_stagetag" t-esc="p.stage"/>
                                                    <input type="date" class="fiq_hm_din" t-att-value="p.start || ''" t-on-click.stop="() =&gt; {}" t-on-change="(ev) =&gt; this.setRowDate(p, 'from', ev.target.value)" title="Planlagt fra"/>
                                                    <input type="date" class="fiq_hm_din" t-att-value="p.end || ''" t-on-click.stop="() =&gt; {}" t-on-change="(ev) =&gt; this.setRowDate(p, 'to', ev.target.value)" title="Planlagt til"/>
                                                    <t t-call="fiq_gui_control.ProgressMini"><t t-set="pct" t-value="p.progress"/><t t-set="shape" t-value="state.progressShape"/><t t-set="hrs" t-value="p.estH ? (p.logH + '/' + p.estH + ' t') : ''"/></t>
                                                </div>
                                            </t>
                                        </t>
                                        <t t-else=""><div class="fiq_hm_empty" t-esc="state.progLevel === 'oppgave' ? 'Ingen oppgaver i prosjektet.' : 'Ingen prosjekter.'"/></t>
                                    </t>
                                    <div t-if="state.rightView === 'gantt'" class="fiq_hm_cgantt">
                                        <div class="fiq_hm_cg_head" t-esc="ganttHeader"/>
                                        <div class="fiq_hm_cg_axis">
                                            <t t-foreach="ganttTicks" t-as="tk" t-key="tk_index">
                                                <span class="fiq_hm_cg_tick" t-att-style="'left:' + tk.left + '%'" t-esc="tk.label"/>
                                            </t>
                                        </div>
                                        <t t-if="ganttRows.length">
                                            <t t-foreach="ganttRows" t-as="g" t-key="g.id">
                                                <div t-if="g.isHead" class="fiq_hm_ghead">👤 <t t-esc="g.name"/> <span class="fiq_hm_stchip_n" t-esc="g.count"/></div>
                                                <div t-else="" t-att-class="'fiq_hm_cg_row' + ((state.selected and state.selected.model === progModel and state.selected.id === g.id) ? ' fiq_hm_selrow' : '')" t-on-click="() =&gt; this.pickRow(g)">
                                                    <span class="fiq_hm_cg_lbl">
                                                        <span class="fiq_hm_cg_name" t-att-title="g.name" t-esc="g.name"/>
                                                        <span class="fiq_hm_cg_dates">
                                                            <input type="date" class="fiq_hm_din_g" t-att-value="g.start || ''" t-on-click.stop="() =&gt; {}" t-on-change="(ev) =&gt; this.setRowDate(g, 'from', ev.target.value)" title="Planlagt fra"/>
                                                            <input type="date" class="fiq_hm_din_g" t-att-value="g.end || ''" t-on-click.stop="() =&gt; {}" t-on-change="(ev) =&gt; this.setRowDate(g, 'to', ev.target.value)" title="Planlagt til"/>
                                                        </span>
                                                    </span>
                                                    <span class="fiq_hm_cg_track">
                                                        <span t-if="g.hasDates" class="fiq_hm_cg_bar" t-att-style="'left:' + g.leftPct + '%; width:' + g.widthPct + '%'"
                                                              t-att-title="g.name + ' — ' + g.progress + ' % (' + (g.farge === 'red' ? 'over frist' : g.farge === 'yellow' ? 'i fare' : g.farge === 'done' ? 'utført' : 'i rute') + ')'">
                                                            <span t-att-class="'fiq_hm_cg_fill ' + g.farge" t-att-style="'width:' + g.progress + '%'"/>
                                                        </span>
                                                        <span t-if="g.hasDates" t-att-class="'fiq_hm_cg_pct ' + g.farge" t-att-style="'left: calc(' + g.pctLeft + '% + 5px)'" t-esc="g.progress + '%'"/>
                                                        <span t-if="!g.hasDates" class="fiq_hm_cg_nodate">ingen datoer</span>
                                                    </span>
                                                </div>
                                            </t>
                                        </t>
                                        <t t-else=""><div class="fiq_hm_empty" t-esc="state.progLevel === 'oppgave' ? 'Ingen oppgaver i prosjektet.' : 'Ingen prosjekter.'"/></t>
                                    </div>
                                </div>
                            </div>
                            <aside class="fiq_hm_inspector">
                                <div class="fiq_hm_card fiq_hm_insp">
                                    <div class="fiq_hm_ch"><h4>Detaljer</h4><button t-if="state.selected" class="fiq_hm_coll" t-on-click="() =&gt; this.openRecord(state.selected.model, state.selected.id)" title="Åpne posten">⤢</button></div>
                                    <t t-if="state.selected">
                                        <div class="fiq_hm_insp_sel" t-esc="state.selected.name"/>
                                        <div class="fiq_hm_insp_tabs">
                                            <button t-foreach="[['beskrivelse','Beskrivelse'],['logg','Logg'],['chat','Chat'],['epost','E-post'],['dok','Dokumenter']]" t-as="tb" t-key="tb[0]" t-att-class="state.inspTab === tb[0] ? 'on' : ''" t-on-click="() =&gt; this.setInspTab(tb[0])" t-esc="tb[1]"/>
                                        </div>
                                        <div class="fiq_hm_insp_body">
                                            <t t-if="state.inspTab === 'beskrivelse'">
                                                <span t-if="state.selDet.beskrivelse" t-esc="state.selDet.beskrivelse"/>
                                                <span t-else="" class="fiq_hm_insp_mut">Ingen beskrivelse på posten.</span>
                                            </t>
                                            <t t-elif="state.inspTab === 'logg'">
                                                <t t-if="state.selDet.logg.length">
                                                    <div t-foreach="state.selDet.logg" t-as="l" t-key="l.id" class="fiq_hm_insp_l">
                                                        <span class="fiq_hm_insp_la"><t t-esc="l.author"/> · <t t-esc="l.date"/></span>
                                                        <span class="fiq_hm_insp_lt" t-esc="l.text"/>
                                                    </div>
                                                </t>
                                                <t t-else=""><span class="fiq_hm_insp_mut">Ingen logg på posten.</span></t>
                                            </t>
                                            <t t-elif="state.inspTab === 'epost'">
                                                <t t-if="state.selDet.epost.length">
                                                    <div t-foreach="state.selDet.epost" t-as="e" t-key="e.id" class="fiq_hm_insp_l">
                                                        <span class="fiq_hm_insp_la"><t t-esc="e.author"/> · <t t-esc="e.date"/></span>
                                                        <span class="fiq_hm_insp_lt"><strong t-esc="e.subject"/> <t t-esc="e.text"/></span>
                                                    </div>
                                                </t>
                                                <t t-else=""><span class="fiq_hm_insp_mut">Ingen e-post på posten.</span></t>
                                            </t>
                                            <t t-elif="state.inspTab === 'dok'">
                                                <t t-if="state.selDet.dok.length">
                                                    <!-- KUN forhåndsvisning — aldri åpne/laste ned (versjonskontroll) -->
                                                    <button t-foreach="state.selDet.dok" t-as="d" t-key="d.id" class="fiq_hm_insp_dok fiq_hm_dokbtn"
                                                            t-att-title="'Forhåndsvis ' + d.name" t-on-click="() =&gt; this.openDok(d)">
                                                        <span class="fiq_hm_dokico">👁</span> <t t-esc="d.name"/>
                                                    </button>
                                                </t>
                                                <t t-else=""><span class="fiq_hm_insp_mut">Ingen dokumenter på posten.</span></t>
                                            </t>
                                            <t t-else="">
                                                <span class="fiq_hm_insp_mut">Full chat/samtale: åpne posten i Odoo med ⤢.</span>
                                            </t>
                                        </div>
                                    </t>
                                    <t t-else=""><div class="fiq_hm_empty">Velg en oppgave eller et prosjekt for å se detaljer her.</div></t>
                                </div>
                            </aside>
                        </div>

                    </t>

                    <!-- =================== KOMMUNIKASJON (uendret flate) =================== -->
                    <div t-if="!state.loading and state.show.kommunikasjon and state.view === 'kommunikasjon'" class="fiq_hm_card">
                        <h4>Kommunikasjon</h4>
                        <div class="fiq_hm_komm_bar">
                            <div class="fiq_hm_pseg">
                                <button t-foreach="[['dag','Dag'],['uke','Uke'],['maaned','Måned'],['alle','Alle']]" t-as="pp" t-key="pp[0]"
                                        t-att-class="state.kommPeriod === pp[0] ? 'on' : ''"
                                        t-on-click="() => this.setKommPeriod(pp[0])" t-esc="pp[1]"/>
                            </div>
                            <div class="fiq_hm_pseg fiq_hm_dseg">
                                <button t-foreach="[['alle','Alle'],['mottatt','Mottatt'],['sendt','Sendt']]" t-as="dd" t-key="dd[0]"
                                        t-att-class="state.kommDir === dd[0] ? 'on' : ''"
                                        t-on-click="() => this.setKommDir(dd[0])" t-esc="dd[1]"/>
                            </div>
                            <span class="fiq_hm_srch">
                                <input class="fiq_hm_ksearch" placeholder="Søk i firma, person, prosjekt, oppgave …"
                                       t-att-value="state.kommQuery" t-on-input="(ev) => state.kommQuery = ev.target.value"/>
                                <span t-if="state.kommQuery" class="fiq_hm_srch_x" t-on-click="() => state.kommQuery = ''" title="Tøm søk">✕</span>
                            </span>
                        </div>
                        <div t-if="state.kommSender" class="fiq_hm_chip">
                            Avsender: <strong t-esc="state.kommSender.name"/>
                            <span class="fiq_hm_chip_x" t-on-click="() => this.clearSender()" title="Fjern avsender-filter">✕</span>
                        </div>
                        <t t-if="filteredKomm.length">
                            <t t-foreach="filteredKomm" t-as="k" t-key="k.id">
                                <div class="fiq_hm_komm">
                                    <span t-att-class="'fiq_hm_kk ' + k.ktype" t-esc="k.kind"/>
                                    <span t-att-class="'fiq_hm_dir ' + k.direction" t-att-title="k.direction === 'sendt' ? 'Sendt fra oss' : 'Mottatt'" t-esc="k.direction === 'sendt' ? '↑ Sendt' : '↓ Mottatt'"/>
                                    <span class="fiq_hm_komm_a" t-on-click="() => this.filterSender(k)" title="Filtrer på denne avsenderen" t-esc="k.author"/>
                                    <span class="fiq_hm_komm_s" t-on-click="() => this.openRecord(k.model, k.res_id)" t-esc="k.subject"/>
                                    <span class="fiq_hm_komm_e" t-on-click="() => this.openRecord(k.model, k.res_id)" t-esc="k.element"/>
                                    <span class="fiq_hm_komm_d" t-esc="k.date"/>
                                    <span class="fiq_hm_kbtn" t-on-click="() => this.replyTo(k.id, false)" title="Svar">↩</span>
                                    <span class="fiq_hm_kbtn" t-on-click="() => this.replyTo(k.id, true)" title="Svar alle (CC/BCC i komposer)">↩↩</span>
                                </div>
                            </t>
                        </t>
                        <t t-else=""><div class="fiq_hm_empty">Ingen kommunikasjon i valgt periode.</div></t>
                    </div>

                    <div class="fiq_hm_foot">Drevet av <img class="fiq_hm_footlogo" src="/fiq_gui_control/static/img/fiq_logo.png" alt="FIQ"/> <strong>FIQ</strong> · Kontrollrom</div>
                </section>
            </div>
        </div>
    </t>
</templates>
