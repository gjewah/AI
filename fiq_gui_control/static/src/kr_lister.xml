<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- KR-LISTER: fire seksjoner fra utkast 15. Eier: B-sporet.
         Radstrukturen er fasitens fire kolonner:
         kilde-etikett · dokumentnr · beskrivelse · alder/tid (høyre). -->
    <t t-name="fiq_gui_control.KrLister">
        <div class="fiq_krl">

            <div t-if="state.laster" class="fiq_krl_info" t-esc="tr('Loading…')"/>

            <!-- En feilet henting SIER fra. En tom liste og en feilet liste ser
                 like ut, men betyr stikk motsatt ting for den som leser. -->
            <div t-elif="state.feil" class="fiq_krl_feil"
                 t-esc="tr('The lists could not be loaded. Nothing is lost — try refreshing.')"/>

            <t t-else="">

                <!-- 1: Krever handling, på tvers av rom. Én rad per sak. -->
                <div class="fiq_krl_blokk">
                    <div class="fiq_krl_h" t-on-click="() => this.toggle('krever')">
                        <span class="fiq_krl_chev" t-esc="erFoldet('krever') ? '▶' : '▼'"/>
                        <b t-esc="tr('Needs action — across rooms')"/>
                        <span class="fiq_krl_mini" t-esc="state.krever.totalt"/>
                    </div>
                    <t t-if="!erFoldet('krever')">
                        <div t-foreach="state.krever.rader" t-as="rad" t-key="rad_index"
                             class="fiq_krl_lin" t-att-class="{ fiq_krl_klikk: rad.model }"
                             t-on-click="() => this.aapne(rad)">
                            <span class="fiq_krl_kilde" t-esc="rad.kilde"/>
                            <span class="fiq_krl_kode" t-esc="rad.kode"/>
                            <span class="fiq_krl_tekst" t-esc="rad.tekst"/>
                            <span class="fiq_krl_naar" t-esc="rad.naar"/>
                        </div>
                        <div t-if="!state.krever.rader.length" class="fiq_krl_tom"
                             t-esc="tr('Nothing needs action right now.')"/>
                    </t>
                </div>

                <!-- 2: Siste aktivitet. -->
                <div class="fiq_krl_blokk">
                    <div class="fiq_krl_h" t-on-click="() => this.toggle('siste')">
                        <span class="fiq_krl_chev" t-esc="erFoldet('siste') ? '▶' : '▼'"/>
                        <b t-esc="tr('Latest activity')"/>
                        <span class="fiq_krl_mini" t-esc="state.siste.totalt"/>
                    </div>
                    <t t-if="!erFoldet('siste')">
                        <div t-foreach="state.siste.rader" t-as="rad" t-key="rad_index"
                             class="fiq_krl_lin" t-att-class="{ fiq_krl_klikk: rad.model }"
                             t-on-click="() => this.aapne(rad)">
                            <span class="fiq_krl_kilde" t-esc="rad.kilde"/>
                            <span class="fiq_krl_kode" t-esc="rad.kode"/>
                            <span class="fiq_krl_tekst" t-esc="rad.tekst"/>
                            <span class="fiq_krl_naar" t-esc="rad.naar"/>
                        </div>
                        <div t-if="!state.siste.rader.length" class="fiq_krl_tom"
                             t-esc="tr('No activity registered yet.')"/>
                    </t>
                </div>

                <!-- 3: Åpne oppgaver. Overskriften bærer det AKTIVE søkefilteret,
                     slik at man ser hva som faktisk ble filtrert på. -->
                <div class="fiq_krl_blokk">
                    <div class="fiq_krl_h" t-on-click="() => this.toggle('oppgaver')">
                        <span class="fiq_krl_chev" t-esc="erFoldet('oppgaver') ? '▶' : '▼'"/>
                        <b t-esc="state.oppgaver.filter ? tr('Open tasks') + ' — ' + state.oppgaver.filter : tr('Open tasks')"/>
                        <span class="fiq_krl_mini" t-esc="state.oppgaver.totalt"/>
                    </div>
                    <t t-if="!erFoldet('oppgaver')">
                        <div t-foreach="state.oppgaver.rader" t-as="rad" t-key="rad_index"
                             class="fiq_krl_lin fiq_krl_klikk"
                             t-on-click="() => this.aapne(rad)">
                            <span class="fiq_krl_kilde" t-esc="rad.kilde"/>
                            <span class="fiq_krl_kode" t-esc="rad.kode"/>
                            <span class="fiq_krl_tekst" t-esc="rad.tekst"/>
                            <span class="fiq_krl_naar" t-esc="rad.naar"/>
                        </div>
                        <div t-if="!state.oppgaver.rader.length" class="fiq_krl_tom"
                             t-esc="tr('No open tasks.')"/>
                    </t>
                </div>

                <!-- 4: Periode-bøttene for grupperte aktiviteter. Bare bøttene med
                     tall; selve foldingen av aktiviteter eies av Kontrollrommet. -->
                <div class="fiq_krl_blokk" t-if="state.perioder.botter.length">
                    <div class="fiq_krl_h" t-on-click="() => this.toggle('perioder')">
                        <span class="fiq_krl_chev" t-esc="erFoldet('perioder') ? '▶' : '▼'"/>
                        <b t-esc="tr('Activities by period')"/>
                        <span class="fiq_krl_mini" t-esc="state.perioder.totalt"/>
                    </div>
                    <t t-if="!erFoldet('perioder')">
                        <div t-foreach="state.perioder.botter" t-as="b" t-key="b.key"
                             class="fiq_krl_periode">
                            <span class="fiq_krl_pnavn" t-esc="b.navn"/>
                            <span class="fiq_krl_pn" t-esc="b.antall"/>
                        </div>
                    </t>
                </div>

            </t>
        </div>
    </t>
</templates>
