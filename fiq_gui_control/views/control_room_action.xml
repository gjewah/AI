<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Client action: the OWL Control room shell -->
    <record id="action_fiq_gui_control" model="ir.actions.client">
        <field name="name">Control room</field>
        <field name="tag">fiq_gui_control_dashboard</field>
        <!-- path gir Kontrollrommet en EGEN URL (/odoo/kontrollrom) i historikken -->
        <field name="path">kontrollrom</field>
    </record>

    <!-- Top menu that opens the Control room – only Control room users -->
    <menuitem id="menu_fiq_gui_control_root"
              name="Control room"
              action="action_fiq_gui_control"
              web_icon="fiq_gui_control,static/description/icon.png"
              groups="fiq_gui_control.group_user"
              sequence="1"/>

    <!-- On install AND upgrade: set the start page to the Control room per company flag -->
    <function model="fiq.gui.control.config" name="_action_set_home_all"/>
</odoo>
