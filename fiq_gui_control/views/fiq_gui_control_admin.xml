<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- User setup (config) – list + form -->
    <record id="view_fiq_gui_control_config_list" model="ir.ui.view">
        <field name="name">fiq.gui.control.config.list</field>
        <field name="model">fiq.gui.control.config</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="user_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="level"/>
                <field name="show_kpis"/>
                <field name="show_projects"/>
                <field name="show_chart"/>
                <field name="show_copilot"/>
            </list>
        </field>
    </record>

    <record id="view_fiq_gui_control_config_form" model="ir.ui.view">
        <field name="name">fiq.gui.control.config.form</field>
        <field name="model">fiq.gui.control.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="level"/>
                        </group>
                        <group string="Visible widgets">
                            <field name="show_kpis"/>
                            <field name="show_projects"/>
                            <field name="show_activity"/>
                            <field name="show_tasks"/>
                            <field name="show_chart"/>
                            <field name="show_copilot"/>
                            <field name="show_quick"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fiq_gui_control_config" model="ir.actions.act_window">
        <field name="name">User setup (Control room)</field>
        <field name="res_model">fiq.gui.control.config</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Company branding (accent/logo) -->
    <record id="action_fiq_gui_control_branding" model="ir.actions.act_window">
        <field name="name">Company branding</field>
        <field name="res_model">res.company</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- CONTROL ROOM ADMIN: own root, only for the Control room administrator -->
    <menuitem id="menu_fiq_gui_control_admin_root"
              name="Control room Admin"
              web_icon="fiq_gui_control,static/description/icon.png"
              groups="fiq_gui_control.group_admin"
              sequence="2"/>
    <menuitem id="menu_fiq_gui_control_admin_config"
              name="User setup"
              parent="menu_fiq_gui_control_admin_root"
              action="action_fiq_gui_control_config"
              groups="fiq_gui_control.group_admin"
              sequence="10"/>
    <menuitem id="menu_fiq_gui_control_admin_branding"
              name="Company branding"
              parent="menu_fiq_gui_control_admin_root"
              action="action_fiq_gui_control_branding"
              groups="fiq_gui_control.group_admin"
              sequence="20"/>
    <menuitem id="menu_fiq_gui_control_admin_users"
              name="Users &amp; access"
              parent="menu_fiq_gui_control_admin_root"
              action="base.action_res_users"
              groups="fiq_gui_control.group_admin"
              sequence="30"/>
</odoo>
