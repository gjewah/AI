<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- AI Stage-toggle på oppgave-stadiene (project.task.type). Form + liste. -->
    <record id="task_type_edit_fiq_ai" model="ir.ui.view">
        <field name="name">project.task.type.form.fiq.ai.stage</field>
        <field name="model">project.task.type</field>
        <field name="inherit_id" ref="project.task_type_edit"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="fiq_ai_stage" widget="boolean_toggle"/>
            </field>
        </field>
    </record>

    <record id="task_type_tree_fiq_ai" model="ir.ui.view">
        <field name="name">project.task.type.list.fiq.ai.stage</field>
        <field name="model">project.task.type</field>
        <field name="inherit_id" ref="project.task_type_tree"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="fiq_ai_stage" widget="boolean_toggle" optional="show"/>
            </field>
        </field>
    </record>
</odoo>
