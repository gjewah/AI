<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FIQ access groups for the Control room (Odoo 19: only name + implied_ids).
         Hierarchy: User < Manager < Administrator. Admin governs setup + access. -->
    <record id="group_user" model="res.groups">
        <field name="name">Control room / User</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_manager" model="res.groups">
        <field name="name">Control room / Manager</field>
        <field name="implied_ids" eval="[(4, ref('fiq_gui_control.group_user'))]"/>
    </record>

    <record id="group_admin" model="res.groups">
        <field name="name">Control room / Administrator</field>
        <field name="implied_ids" eval="[(4, ref('fiq_gui_control.group_manager'))]"/>
    </record>

    <!-- Odoo system admin automatically gets Control room admin -->
    <record id="base.group_system" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('fiq_gui_control.group_admin'))]"/>
    </record>

    <!-- ALL internal users get Control room / User (so everyone can start in the Control room) -->
    <record id="base.group_user" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('fiq_gui_control.group_user'))]"/>
    </record>

    <!-- Access rules: a user sees/edits ONLY their own setup; admin sees all.
         (Tenant isolation: the company_id filter is inherited by Odoo's multi-company rules.) -->
    <record id="rule_config_own" model="ir.rule">
        <field name="name">Control room setup: own</field>
        <field name="model_id" ref="model_fiq_gui_control_config"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('fiq_gui_control.group_user'))]"/>
    </record>
    <record id="rule_config_admin" model="ir.rule">
        <field name="name">Control room setup: admin all</field>
        <field name="model_id" ref="model_fiq_gui_control_config"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('fiq_gui_control.group_admin'))]"/>
    </record>
</odoo>
