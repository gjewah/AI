<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
      Selvregistrering av FIQ-flater i kontrollrom-menyen.

      Disse modulene var ferdige, installerte og hadde fungerende handlinger — men menyen
      i control_room.js var en HARDKODET liste, så de var usynlige i kontrollrommet.
      Her meldes de inn. get_fiq_flater() dropper automatisk enhver linje der modulen (og
      dermed handlingen) ikke finnes i basen, så fila er trygg i alle tenanter.

      En NY modul trenger ikke røre denne fila heller — den kan sende med sin egen
      ir.config_parameter «fiq_gui_control.flate.<key>» fra sitt eget data/.
      Format: {"label": …, "xmlid": …, "sequence": …, "icon": …}
    -->
    <data noupdate="0">

        <record id="flate_befaring" model="ir.config_parameter">
            <field name="key">fiq_gui_control.flate.befaring</field>
            <field name="value">{"label": "Inspections", "xmlid": "fiq_befaring.action_fiq_befaring", "sequence": 60}</field>
        </record>

        <record id="flate_mgmtsystem" model="ir.config_parameter">
            <field name="key">fiq_gui_control.flate.mgmtsystem</field>
            <field name="value">{"label": "Deviations", "xmlid": "fiq_mgmtsystem.action_fiq_mgmtsystem_avvik", "sequence": 35}</field>
        </record>

        <record id="flate_gantt" model="ir.config_parameter">
            <field name="key">fiq_gui_control.flate.gantt</field>
            <field name="value">{"label": "Timeline", "xmlid": "fiq_gui_gantt.action_project_task_gantt_fiq", "sequence": 45}</field>
        </record>

        <record id="flate_ai_rolle" model="ir.config_parameter">
            <field name="key">fiq_gui_control.flate.ai_rolle</field>
            <field name="value">{"label": "AI roles", "xmlid": "fiq_ai_rolle.action_fiq_ai_rolle", "sequence": 85}</field>
        </record>

        <record id="flate_komm_ruting" model="ir.config_parameter">
            <field name="key">fiq_gui_control.flate.komm_ruting</field>
            <field name="value">{"label": "Message routing", "xmlid": "fiq_komm_ruting.action_fiq_komm_profil", "sequence": 90}</field>
        </record>

    </data>
</odoo>
