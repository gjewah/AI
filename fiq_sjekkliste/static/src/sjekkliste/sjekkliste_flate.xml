<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="fiq_sjekkliste.SjekklisteFlate">
        <div class="fiq_sjl">

            <!-- HODE ────────────────────────────────────────────────────── -->
            <div class="fiq_sjl_top">
                <span class="fiq_sjl_mark">✓</span>
                <select class="fiq_sjl_valg" t-on-change="(ev) => this.velgListe(parseInt(ev.target.value))">
                    <t t-if="!state.lister.length">
                        <option>Ingen sjekklister i dette området</option>
                    </t>
                    <t t-foreach="state.lister" t-as="l" t-key="l.id">
                        <option t-att-value="l.id" t-att-selected="l.id === state.valgtId">
                            <t t-esc="l.name"/> · <t t-esc="l.antall_ok"/>/<t t-esc="l.antall_punkt"/>
                        </option>
                    </t>
                </select>
                <span class="fiq_sjl_sp"/>
                <!-- Modus-toggle: bygg (eier) vs kvitter (arbeider) -->
                <div class="fiq_sjl_modus">
                    <button class="fiq_sjl_mbtn" t-att-class="{ akt: state.modus === 'kvitter' }"
                            t-on-click="() => this.settModus('kvitter')">Kvitter</button>
                    <button class="fiq_sjl_mbtn" t-att-class="{ akt: state.modus === 'bygg' }"
                            t-on-click="() => this.settModus('bygg')">Bygg</button>
                </div>
            </div>

            <!-- FREMDRIFT ────────────────────────────────────────────────── -->
            <t t-if="valgtListe">
                <div class="fiq_sjl_frem">
                    <div class="fiq_sjl_bar">
                        <div class="fiq_sjl_fill" t-att-style="'width:' + (valgtListe.fremdrift || 0) + '%'"/>
                    </div>
                    <span class="fiq_sjl_pct"><t t-esc="Math.round(valgtListe.fremdrift || 0)"/>%</span>
                    <span class="fiq_sjl_ver">v<t t-esc="valgtListe.versjon"/></span>
                </div>
            </t>

            <!-- LASTER / TOM ─────────────────────────────────────────────── -->
            <t t-if="state.laster">
                <div class="fiq_sjl_tom">Laster …</div>
            </t>
            <t t-elif="!valgtListe">
                <div class="fiq_sjl_tom">Ingen sjekkliste å vise her ennå.</div>
            </t>

            <!-- PUNKTER ──────────────────────────────────────────────────── -->
            <t t-else="">
                <div class="fiq_sjl_liste">
                    <t t-foreach="state.punkter" t-as="p" t-key="p.id">
                        <div class="fiq_sjl_rad" t-att-class="{ ferdig: p.utfoert, sperret: !p.kan_kvitteres and !p.utfoert }">

                            <!-- Avhuking (kvitter-modus) -->
                            <t t-if="state.modus === 'kvitter'">
                                <button class="fiq_sjl_hake" t-att-class="{ på: p.utfoert }"
                                        t-att-disabled="!p.kan_kvitteres and !p.utfoert"
                                        t-on-click="() => this.vekslUtfoert(p)">
                                    <t t-if="p.utfoert">✓</t>
                                </button>
                            </t>

                            <!-- Punkt-tekst -->
                            <div class="fiq_sjl_tekst">
                                <div class="fiq_sjl_navn">
                                    <span t-esc="p.name"/>
                                    <span class="fiq_sjl_krav" t-esc="kravIkon(p)"/>
                                </div>
                                <div class="fiq_sjl_besk" t-if="p.beskrivelse" t-esc="p.beskrivelse"/>
                                <!-- «Venter på» — aldri skjul hvorfor et punkt ikke kan lukkes -->
                                <div class="fiq_sjl_mangler" t-if="p.mangler and !p.utfoert">
                                    Venter på: <t t-esc="p.mangler"/>
                                </div>
                                <div class="fiq_sjl_kvitt" t-if="p.utfoert and p.kvitt_av">
                                    Kvittert av <t t-esc="p.kvitt_av"/>
                                </div>
                            </div>

                            <!-- KVITTER-modus: last opp / signér -->
                            <t t-if="state.modus === 'kvitter'">
                                <div class="fiq_sjl_handl">
                                    <t t-if="p.krav_foto">
                                        <span class="fiq_sjl_up" t-att-class="{ levert: p.kvitt_foto_id }"
                                              t-on-click="() => this.forberedOpplasting(p.id)">
                                            <FileInput
                                                resModel="'fiq.sjekkliste.punkt'"
                                                resId="p.id"
                                                acceptedFileExtensions="'image/*'"
                                                onUpload="(d) => this.etterOpplasting('kvitt_foto_id', d)">
                                                <span class="fiq_sjl_upbtn">📷 <t t-esc="p.kvitt_foto_id ? 'Bytt' : 'Foto'"/></span>
                                            </FileInput>
                                        </span>
                                    </t>
                                    <t t-if="p.krav_dok">
                                        <span class="fiq_sjl_up" t-att-class="{ levert: p.kvitt_dok_id }"
                                              t-on-click="() => this.forberedOpplasting(p.id)">
                                            <FileInput
                                                resModel="'fiq.sjekkliste.punkt'"
                                                resId="p.id"
                                                onUpload="(d) => this.etterOpplasting('kvitt_dok_id', d)">
                                                <span class="fiq_sjl_upbtn">📄 <t t-esc="p.kvitt_dok_id ? 'Bytt' : 'Dokument'"/></span>
                                            </FileInput>
                                        </span>
                                    </t>
                                    <t t-if="p.krav_sign">
                                        <button class="fiq_sjl_upbtn" t-att-class="{ levert: p.kvitt_sign_dato }"
                                                t-on-click="() => this.signer(p)">
                                            ✍ <t t-esc="p.kvitt_sign_dato ? 'Signert' : 'Signér'"/>
                                        </button>
                                    </t>
                                </div>
                            </t>

                            <!-- BYGG-modus: krav-brytere + slett -->
                            <t t-if="state.modus === 'bygg'">
                                <div class="fiq_sjl_handl">
                                    <button class="fiq_sjl_kravbtn" t-att-class="{ på: p.krav_dok }"
                                            title="Krever dokument"
                                            t-on-click="() => this.vekslKrav(p, 'krav_dok')">📄</button>
                                    <button class="fiq_sjl_kravbtn" t-att-class="{ på: p.krav_foto }"
                                            title="Krever foto"
                                            t-on-click="() => this.vekslKrav(p, 'krav_foto')">📷</button>
                                    <button class="fiq_sjl_kravbtn" t-att-class="{ på: p.krav_sign }"
                                            title="Krever signatur"
                                            t-on-click="() => this.vekslKrav(p, 'krav_sign')">✍</button>
                                    <button class="fiq_sjl_slett" title="Slett punkt"
                                            t-on-click="() => this.slettPunkt(p)">✕</button>
                                </div>
                            </t>

                        </div>
                    </t>
                </div>

                <!-- BYGG-modus: legg til nytt punkt -->
                <t t-if="state.modus === 'bygg'">
                    <div class="fiq_sjl_nytt">
                        <input type="text" class="fiq_sjl_input" placeholder="Nytt punkt (ett steg) …"
                               t-model="state.nyPunktNavn"
                               t-on-keydown="(ev) => ev.key === 'Enter' ? this.leggTilPunkt() : null"/>
                        <button class="fiq_sjl_leggtil" t-on-click="() => this.leggTilPunkt()">+ Legg til</button>
                    </div>
                </t>
            </t>

            <div class="fiq_sjl_foot">Drevet av <strong>FIQ</strong> · Sjekkliste</div>
        </div>
    </t>

</templates>
