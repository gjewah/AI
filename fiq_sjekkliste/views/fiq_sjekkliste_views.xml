<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
      KANON «Odoo-native først»: sjekklista skal VIRKE i native Odoo uten KR.
      GUI-flaten er en penere inngang til de SAMME dataene — ikke lagringen.
    -->

    <!-- Sjekkliste: skjema -->
    <record id="view_fiq_sjekkliste_form" model="ir.ui.view">
        <field name="name">fiq.sjekkliste.form</field>
        <field name="model">fiq.sjekkliste</field>
        <field name="arch" type="xml">
            <form string="Sjekkliste">
                <header>
                    <field name="fremdrift" widget="progressbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="F.eks. FDV — produktdokumentasjon"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="nivaa"/>
                            <field name="type_liste"/>
                            <field name="er_mal"/>
                        </group>
                        <group>
                            <!-- Generisk kobling: lista kan henge på hva som helst.
                                 Maler henger ikke på noe — de kopieres til en post. -->
                            <field name="res_model" invisible="er_mal"
                                   placeholder="project.task, helpdesk.ticket, crm.lead …"/>
                            <field name="res_navn" invisible="er_mal or not res_model"/>
                            <field name="task_id" invisible="er_mal"/>
                            <field name="project_id" invisible="er_mal"/>
                            <field name="mal_id" invisible="not mal_id" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="versjon"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Punkter (steg for steg)">
                            <field name="punkt_ids">
                                <list editable="bottom" decoration-muted="utfoert">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="beskrivelse" optional="show"/>
                                    <field name="krav_dok" string="📄"/>
                                    <field name="krav_foto" string="📷"/>
                                    <field name="krav_sign" string="✍"/>
                                    <field name="mangler" optional="show"/>
                                    <field name="kan_kvitteres" column_invisible="True"/>
                                    <field name="utfoert" widget="boolean_toggle"/>
                                    <field name="kvitt_av" optional="hide"/>
                                    <field name="kvitt_dato" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Sjekkliste: liste -->
    <record id="view_fiq_sjekkliste_list" model="ir.ui.view">
        <field name="name">fiq.sjekkliste.list</field>
        <field name="model">fiq.sjekkliste</field>
        <field name="arch" type="xml">
            <list string="Sjekklister" decoration-success="fremdrift == 100">
                <field name="name"/>
                <field name="nivaa"/>
                <field name="type_liste"/>
                <field name="task_id" optional="show"/>
                <field name="project_id" optional="show"/>
                <field name="antall_ok" string="Utført"/>
                <field name="antall_punkt" string="Av"/>
                <field name="fremdrift" widget="progressbar"/>
                <field name="versjon"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Sjekkliste: søk + gruppering på nivå/type -->
    <record id="view_fiq_sjekkliste_search" model="ir.ui.view">
        <field name="name">fiq.sjekkliste.search</field>
        <field name="model">fiq.sjekkliste</field>
        <field name="arch" type="xml">
            <search string="Sjekklister">
                <field name="name"/>
                <field name="task_id"/>
                <field name="project_id"/>
                <field name="res_model"/>
                <filter name="ikke_ferdig" string="Ikke ferdig" domain="[('fremdrift','&lt;',100)]"/>
                <filter name="ferdig" string="Ferdig" domain="[('fremdrift','=',100)]"/>
                <separator/>
                <!-- Maler vs. lister i bruk. Standard er å SKJULE maler i lista, ellers
                     drukner de ekte listene slik 0.90-malprosjektene gjorde i oversikten. -->
                <filter name="kun_maler" string="Kun maler" domain="[('er_mal','=',True)]"/>
                <filter name="ikke_maler" string="Skjul maler" domain="[('er_mal','=',False)]"/>
                <!-- Odoo 19: <group> i søkevisning tar hverken expand= eller string=. -->
                <group>
                    <filter name="g_nivaa" string="Nivå" context="{'group_by':'nivaa'}"/>
                    <filter name="g_type" string="Type" context="{'group_by':'type_liste'}"/>
                    <filter name="g_prosjekt" string="Prosjekt" context="{'group_by':'project_id'}"/>
                    <filter name="g_res_model" string="Knyttet til" context="{'group_by':'res_model'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_fiq_sjekkliste" model="ir.actions.act_window">
        <field name="name">Sjekklister</field>
        <field name="res_model">fiq.sjekkliste</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Ingen sjekklister ennå</p>
            <p>Punktene ER stegene — én oppgave med flere punkter i stedet for mange oppgaver.</p>
        </field>
    </record>


    <!--
      EGEN ROTMENY (utskilt modul, 24.07.2026). FOER utskillingen hang begge
      menypunktene under `menu_fiq_prj_root` i FIQ Prosjekt. Motoren skal virke
      ALENE — en modul som avhenger av et menypunkt i en annen modul, er ikke
      utskilt, bare flyttet.
      `web_icon` laaner Odoos eget project-ikon; modulen har ingen egen icon.png.
    -->
    <menuitem id="menu_fiq_sjekkliste_root"
              name="Sjekklister"
              web_icon="project,static/description/icon.png"
              sequence="46"/>

    <!-- Native menypunkt under FIQ Prosjekt (AI PK-avgjørelse 2026-07-17: hver flate-eier
         legger egen dør; KR-sidemenyen kommer i tillegg, ikke som forutsetning). -->
    <menuitem id="menu_fiq_sjekkliste"
              name="Sjekklister"
              parent="menu_fiq_sjekkliste_root"
              action="action_fiq_sjekkliste"
              sequence="20"/>

    <!--
      OWL-FLATEN (sprettopp) — «penere inngang» til de SAMME dataene (KANON Odoo-native først).
      To moduser i én komponent: bygg (eier lager punkter/krav) · kvitter (arbeider huker av
      m/ foto/dok/signatur). Modus defaulter fra user.isInternalUser. Rettighetsnøytral —
      ingen ny res.groups (rolle-motoren 00.03gew eier tilgang; meldt i koordineringsfila).
    -->
    <record id="action_fiq_sjekkliste_flate" model="ir.actions.client">
        <field name="name">Sjekkliste-flate</field>
        <field name="tag">fiq_sjekkliste_flate</field>
    </record>

    <menuitem id="menu_fiq_sjekkliste_flate"
              name="Sjekkliste-flate"
              parent="menu_fiq_sjekkliste_root"
              action="action_fiq_sjekkliste_flate"
              sequence="25"/>

    <!-- Knapp i sjekkliste-skjemaet: åpne DENNE lista i flaten -->
    <record id="view_fiq_sjekkliste_form_flateknapp" model="ir.ui.view">
        <field name="name">fiq.sjekkliste.form.flateknapp</field>
        <field name="model">fiq.sjekkliste</field>
        <field name="inherit_id" ref="view_fiq_sjekkliste_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="apne_flate" type="object" string="Åpne flate"
                        class="btn-primary" icon="fa-check-square-o"
                        invisible="not id"/>
            </xpath>
        </field>
    </record>
</odoo>
