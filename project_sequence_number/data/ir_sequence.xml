<?xml version="1.0" encoding="utf-8" ?>
<odoo noupdate="1">
    <record id="project_sequence" model="ir.sequence">
        <field name="name">Project sequence</field>
        <field name="code">project.sequence</field>
        <field name="prefix">%(y)s_</field>
        <field name="use_date_range">True</field>
        <field name="padding">3</field>
        <field name="company_id" eval="False" />
    </record>
    <record id="task_sequence" model="ir.sequence">
        <field name="name">Task sequence</field>
        <field name="code">project.task</field>
        <field name="padding">6</field>
        <field name="prefix"></field>
        <field name="number_next_actual">100000</field>
        <field name="company_id" eval="False" />
    </record>
</odoo>
