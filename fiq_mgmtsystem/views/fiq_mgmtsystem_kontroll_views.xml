<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_fiq_mgmtsystem_kontroll_list" model="ir.ui.view">
        <field name="name">fiq.mgmtsystem.kontroll.list</field>
        <field name="model">fiq.mgmtsystem.kontroll</field>
        <field name="arch" type="xml">
            <list string="Kontroller">
                <field name="kode"/>
                <field name="name"/>
                <field name="ansvarlig_id"/>
                <field name="frekvens"/>
                <field name="neste_dato"/>
                <field name="status"/>
                <field name="company_id" optional="show"/>
                <field name="aktiv" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_fiq_mgmtsystem_kontroll_form" model="ir.ui.view">
        <field name="name">fiq.mgmtsystem.kontroll.form</field>
        <field name="model">fiq.mgmtsystem.kontroll</field>
        <field name="arch" type="xml">
            <form string="Kontroll">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Kontroll — menneskelesbar tittel"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="kode"/>
                            <field name="ansvarlig_id"/>
                            <field name="company_id"/>
                            <field name="aktiv"/>
                        </group>
                        <group>
                            <field name="frekvens"/>
                            <field name="neste_dato"/>
                            <field name="status"/>
                        </group>
                    </group>
                    <group>
                        <field name="beskrivelse"/>
                    </group>
                    <notebook>
                        <page string="Dekker krav">
                            <field name="krav_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Avvik">
                            <field name="avvik_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="alvorlighet"/>
                                    <field name="status"/>
                                    <field name="frist"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fiq_mgmtsystem_kontroll_search" model="ir.ui.view">
        <field name="name">fiq.mgmtsystem.kontroll.search</field>
        <field name="model">fiq.mgmtsystem.kontroll</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="kode"/>
                <field name="ansvarlig_id"/>
                <filter name="aktiv" string="Aktive" domain="[('aktiv','=',True)]"/>
                <separator/>
                <filter name="f_aktiv_status" string="Aktiv status" domain="[('status','=','aktiv')]"/>
                <filter name="f_planlagt" string="Planlagt" domain="[('status','=','planlagt')]"/>
                <group expand="0" string="Grupper">
                    <filter name="g_frekvens" string="Frekvens" context="{'group_by':'frekvens'}"/>
                    <filter name="g_ansvarlig" string="Ansvarlig" context="{'group_by':'ansvarlig_id'}"/>
                    <filter name="g_firma" string="Firma" context="{'group_by':'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_fiq_mgmtsystem_kontroll" model="ir.actions.act_window">
        <field name="name">Kontroller</field>
        <field name="res_model">fiq.mgmtsystem.kontroll</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_aktiv': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiley_face">Opprett den første kontrollen</p>
            <p>Kontroller som demonstrerer at krav etterleves (frekvens, ansvarlig, status).</p>
        </field>
    </record>

</odoo>
