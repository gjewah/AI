<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_fiq_mgmtsystem_sjekkliste_list" model="ir.ui.view">
        <field name="name">fiq.mgmtsystem.sjekkliste.list</field>
        <field name="model">fiq.mgmtsystem.sjekkliste</field>
        <field name="arch" type="xml">
            <list string="Sjekklister">
                <field name="name"/>
                <field name="krav_id"/>
                <field name="er_mal"/>
                <field name="antall_punkt"/>
                <field name="antall_utfort"/>
                <field name="fremdrift" widget="percentage"/>
                <field name="company_id" optional="show"/>
                <field name="aktiv" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_fiq_mgmtsystem_sjekkliste_form" model="ir.ui.view">
        <field name="name">fiq.mgmtsystem.sjekkliste.form</field>
        <field name="model">fiq.mgmtsystem.sjekkliste</field>
        <field name="arch" type="xml">
            <form string="Sjekkliste">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Sjekkliste — tittel"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="krav_id"/>
                            <field name="er_mal"/>
                            <field name="company_id"/>
                            <field name="aktiv"/>
                        </group>
                        <group>
                            <field name="antall_punkt"/>
                            <field name="antall_utfort"/>
                            <field name="fremdrift" widget="percentage"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Punkter">
                            <field name="punkt_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="ansvarlig"/>
                                    <field name="oppgave_ref"/>
                                    <field name="utfort"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fiq_mgmtsystem_sjekkliste_search" model="ir.ui.view">
        <field name="name">fiq.mgmtsystem.sjekkliste.search</field>
        <field name="model">fiq.mgmtsystem.sjekkliste</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="krav_id"/>
                <filter name="aktiv" string="Aktive" domain="[('aktiv','=',True)]"/>
                <separator/>
                <filter name="f_mal" string="Maler" domain="[('er_mal','=',True)]"/>
                <filter name="f_instans" string="Instanser" domain="[('er_mal','=',False)]"/>
                <group expand="0" string="Grupper">
                    <filter name="g_krav" string="Krav" context="{'group_by':'krav_id'}"/>
                    <filter name="g_firma" string="Firma" context="{'group_by':'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_fiq_mgmtsystem_sjekkliste" model="ir.actions.act_window">
        <field name="name">Sjekklister</field>
        <field name="res_model">fiq.mgmtsystem.sjekkliste</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_aktiv': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiley_face">Opprett den første sjekklisten</p>
            <p>Sjekklister (maler eller instanser) knyttet til krav — med fremdrift per punkt.</p>
        </field>
    </record>

</odoo>
