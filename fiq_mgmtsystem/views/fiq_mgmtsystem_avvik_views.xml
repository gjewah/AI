<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_fiq_mgmtsystem_avvik_list" model="ir.ui.view">
        <field name="name">fiq.mgmtsystem.avvik.list</field>
        <field name="model">fiq.mgmtsystem.avvik</field>
        <field name="arch" type="xml">
            <list string="Avvik" decoration-danger="alvorlighet == 'kritisk'"
                  decoration-warning="alvorlighet == 'hoy'">
                <field name="oppdaget_dato"/>
                <field name="name"/>
                <field name="krav_id"/>
                <field name="kontroll_id"/>
                <field name="alvorlighet"/>
                <field name="status"/>
                <field name="ansvarlig_id"/>
                <field name="frist"/>
                <field name="company_id" optional="show"/>
                <field name="aktiv" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_fiq_mgmtsystem_avvik_form" model="ir.ui.view">
        <field name="name">fiq.mgmtsystem.avvik.form</field>
        <field name="model">fiq.mgmtsystem.avvik</field>
        <field name="arch" type="xml">
            <form string="Avvik">
                <header>
                    <button name="action_lukk" type="object" string="Lukk avvik"
                            class="btn-primary" invisible="status == 'lukket'"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="aapen,under_tiltak,lukket"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Avvik — kort tittel"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="krav_id"/>
                            <field name="kontroll_id"/>
                            <field name="alvorlighet"/>
                            <field name="ansvarlig_id"/>
                        </group>
                        <group>
                            <field name="oppdaget_dato"/>
                            <field name="frist"/>
                            <field name="lukket_dato"/>
                            <field name="company_id"/>
                            <field name="aktiv"/>
                        </group>
                    </group>
                    <group>
                        <field name="beskrivelse"/>
                        <field name="rotarsak"/>
                        <field name="tiltak"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_fiq_mgmtsystem_avvik_search" model="ir.ui.view">
        <field name="name">fiq.mgmtsystem.avvik.search</field>
        <field name="model">fiq.mgmtsystem.avvik</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="krav_id"/>
                <field name="kontroll_id"/>
                <field name="ansvarlig_id"/>
                <filter name="f_aapne" string="Åpne" domain="[('status','!=','lukket')]"/>
                <filter name="f_kritisk" string="Kritiske" domain="[('alvorlighet','=','kritisk')]"/>
                <separator/>
                <filter name="aktiv" string="Aktive" domain="[('aktiv','=',True)]"/>
                <separator/>
                    <filter name="g_status" string="Status" context="{'group_by':'status'}"/>
                    <filter name="g_alvorlighet" string="Alvorlighet" context="{'group_by':'alvorlighet'}"/>
                    <filter name="g_ansvarlig" string="Ansvarlig" context="{'group_by':'ansvarlig_id'}"/>
                    <filter name="g_firma" string="Firma" context="{'group_by':'company_id'}"/>
                
            </search>
        </field>
    </record>

    <record id="action_fiq_mgmtsystem_avvik" model="ir.actions.act_window">
        <field name="name">Avvik</field>
        <field name="res_model">fiq.mgmtsystem.avvik</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_f_aapne': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiley_face">Ingen registrerte avvik</p>
            <p>Avvik (nonconformity) med rotårsak, korrigerende tiltak, alvorlighet og status.</p>
        </field>
    </record>

</odoo>
