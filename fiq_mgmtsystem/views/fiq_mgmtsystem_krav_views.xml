<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_fiq_mgmtsystem_krav_list" model="ir.ui.view">
        <field name="name">fiq.mgmtsystem.krav.list</field>
        <field name="model">fiq.mgmtsystem.krav</field>
        <field name="arch" type="xml">
            <list string="Krav">
                <field name="standard"/>
                <field name="klausul"/>
                <field name="name"/>
                <field name="taksonomi_kode"/>
                <field name="kontroll_antall"/>
                <field name="avvik_aapne"/>
                <field name="company_id" optional="show"/>
                <field name="aktiv" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_fiq_mgmtsystem_krav_form" model="ir.ui.view">
        <field name="name">fiq.mgmtsystem.krav.form</field>
        <field name="model">fiq.mgmtsystem.krav</field>
        <field name="arch" type="xml">
            <form string="Krav">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Krav — menneskelesbar tittel"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="standard"/>
                            <field name="klausul" placeholder="f.eks. 7.5"/>
                            <field name="company_id"/>
                            <field name="aktiv"/>
                        </group>
                        <group>
                            <field name="taksonomi_kode" placeholder="f.eks. 2.40.01"/>
                            <field name="dokumentetikett"/>
                            <field name="kontroll_antall"/>
                            <field name="avvik_aapne"/>
                        </group>
                    </group>
                    <group>
                        <field name="beskrivelse" placeholder="Beskrivelse av kravet / klausulen"/>
                    </group>
                    <notebook>
                        <page string="Kontroller">
                            <field name="kontroll_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Sjekklister">
                            <field name="sjekkliste_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="er_mal"/>
                                    <field name="fremdrift" widget="percentage"/>
                                </list>
                            </field>
                        </page>
                        <page string="Avvik">
                            <field name="avvik_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="alvorlighet"/>
                                    <field name="status"/>
                                    <field name="frist"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fiq_mgmtsystem_krav_search" model="ir.ui.view">
        <field name="name">fiq.mgmtsystem.krav.search</field>
        <field name="model">fiq.mgmtsystem.krav</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="klausul"/>
                <field name="taksonomi_kode"/>
                <filter name="aktiv" string="Aktive" domain="[('aktiv','=',True)]"/>
                <separator/>
                <filter name="f_iso9001" string="ISO 9001" domain="[('standard','=','iso9001')]"/>
                <filter name="f_iso14001" string="ISO 14001" domain="[('standard','=','iso14001')]"/>
                <filter name="f_iso27001" string="ISO 27001" domain="[('standard','=','iso27001')]"/>
                <group expand="0" string="Grupper">
                    <filter name="g_standard" string="Standard" context="{'group_by':'standard'}"/>
                    <filter name="g_firma" string="Firma" context="{'group_by':'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_fiq_mgmtsystem_krav" model="ir.actions.act_window">
        <field name="name">Krav</field>
        <field name="res_model">fiq.mgmtsystem.krav</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_aktiv': 1, 'search_default_g_standard': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiley_face">Registrer det første kravet</p>
            <p>Krav / klausuler i styringssystemet (ISO 9001 m.fl.), koblet til FIQ-taksonomien.</p>
        </field>
    </record>

</odoo>
