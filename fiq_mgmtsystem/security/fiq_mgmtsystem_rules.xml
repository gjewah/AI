<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
      Multi-selskap record rules (UFRAVIKELIG — Gjermund-direktiv).
      Globale regler per firma: en post er synlig for firmaets brukere ELLER
      hvis den er en generisk mal (company_id = False, delt på tvers).
      Tenant-isolert: ingen kunde ser en annen kundes styringssystem-poster.
    -->

    <record id="rule_fiq_mgmtsystem_krav_company" model="ir.rule">
        <field name="name">Styringssystem-krav: multi-selskap</field>
        <field name="model_id" ref="model_fiq_mgmtsystem_krav"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id','in',company_ids)]</field>
    </record>

    <record id="rule_fiq_mgmtsystem_kontroll_company" model="ir.rule">
        <field name="name">Styringssystem-kontroll: multi-selskap</field>
        <field name="model_id" ref="model_fiq_mgmtsystem_kontroll"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id','in',company_ids)]</field>
    </record>

    <record id="rule_fiq_mgmtsystem_sjekkliste_company" model="ir.rule">
        <field name="name">Styringssystem-sjekkliste: multi-selskap</field>
        <field name="model_id" ref="model_fiq_mgmtsystem_sjekkliste"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id','in',company_ids)]</field>
    </record>

    <record id="rule_fiq_mgmtsystem_sjekkliste_punkt_company" model="ir.rule">
        <field name="name">Sjekklistepunkt: multi-selskap</field>
        <field name="model_id" ref="model_fiq_mgmtsystem_sjekkliste_punkt"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id','in',company_ids)]</field>
    </record>

    <record id="rule_fiq_mgmtsystem_avvik_company" model="ir.rule">
        <field name="name">Styringssystem-avvik: multi-selskap</field>
        <field name="model_id" ref="model_fiq_mgmtsystem_avvik"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id','in',company_ids)]</field>
    </record>

</odoo>
