<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fiq_pos_rapport_list" model="ir.ui.view">
        <field name="name">fiq.pos.rapport.list</field>
        <field name="model">fiq.pos.rapport</field>
        <field name="arch" type="xml">
            <list string="Kassarapporter">
                <field name="name"/>
                <field name="type"/>
                <field name="nummer" optional="show"/>
                <field name="config_id"/>
                <field name="dato"/>
                <field name="grand_total_netto" sum="Grand total netto"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_fiq_pos_rapport_form" model="ir.ui.view">
        <field name="name">fiq.pos.rapport.form</field>
        <field name="model">fiq.pos.rapport</field>
        <field name="arch" type="xml">
            <form string="Kassarapport">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Identifikasjon">
                            <field name="type"/>
                            <field name="nummer" invisible="type != 'z'"/>
                            <field name="firma_navn"/>
                            <field name="organisasjonsnummer"/>
                            <field name="kassapunkt_id_nummer"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Periode">
                            <field name="fra_tidspunkt"/>
                            <field name="dato"/>
                            <field name="session_id"/>
                            <field name="config_id"/>
                        </group>
                    </group>
                    <group string="Summer">
                        <group>
                            <field name="totalt_kontantsalg"/>
                            <field name="antall_salg"/>
                            <field name="antall_salgskvitteringer"/>
                            <field name="inngaende_vekselkasse"/>
                            <field name="antall_kassaskuff_apninger"/>
                        </group>
                        <group>
                            <field name="grand_total_salg"/>
                            <field name="grand_total_retur"/>
                            <field name="grand_total_netto"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Spesifikasjon" name="spesifikasjon">
                            <field name="linje_ids">
                                <list>
                                    <field name="kategori"/>
                                    <field name="navn"/>
                                    <field name="antall"/>
                                    <field name="belop"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </list>
                            </field>
                        </page>
                        <page string="Korreksjoner og kvitteringer" name="korreksjoner">
                            <group>
                                <group>
                                    <field name="antall_returkvitteringer"/>
                                    <field name="belop_returkvitteringer"/>
                                    <field name="antall_kopikvitteringer"/>
                                    <field name="antall_forelopige"/>
                                    <field name="antall_treningskvitteringer"/>
                                    <field name="antall_utleveringskvitteringer"/>
                                </group>
                                <group>
                                    <field name="antall_rabatter"/>
                                    <field name="belop_rabatter"/>
                                    <field name="antall_avbrutte_salg"/>
                                    <field name="antall_linjekorreksjoner"/>
                                    <field name="antall_prisundersokelser"/>
                                    <field name="antall_andre_korreksjoner"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fiq_pos_rapport_search" model="ir.ui.view">
        <field name="name">fiq.pos.rapport.search</field>
        <field name="model">fiq.pos.rapport</field>
        <field name="arch" type="xml">
            <search string="Søk kassarapport">
                <field name="name"/>
                <field name="nummer"/>
                <field name="config_id"/>
                <separator/>
                <filter name="filter_z" string="Z-rapporter" domain="[('type','=','z')]"/>
                <filter name="filter_x" string="X-rapporter" domain="[('type','=','x')]"/>
                <group>
                    <filter name="group_config" string="Kassapunkt" context="{'group_by':'config_id'}"/>
                    <filter name="group_type" string="Rapporttype" context="{'group_by':'type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_fiq_pos_rapport" model="ir.actions.act_window">
        <field name="name">Kassarapporter (X/Z)</field>
        <field name="res_model">fiq.pos.rapport</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_z': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Ingen kassarapporter ennå</p>
            <p>
                X- og Z-rapporter etter kassasystemforskrifta § 2-8-2 og § 2-8-3.
                Z-rapporten nummereres fortløpende og kan ikke slettes.
            </p>
        </field>
    </record>

    <menuitem id="menu_fiq_pos_rapport"
              name="Kassarapporter (X/Z)"
              parent="point_of_sale.menu_point_rep"
              action="action_fiq_pos_rapport"
              sequence="25"/>

</odoo>
