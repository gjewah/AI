<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
      Selvregistrering i Kontrollrom-menyen (mekanisme innført i KR v6.82).

      fiq.gui.control.config.get_fiq_flater() leser ALLE ir.config_parameter med prefikset
      «fiq_gui_control.flate.» — uansett hvilken modul de kommer fra. Derfor melder denne
      modulen seg selv inn, og fiq_gui_control røres ALDRI herfra. KR-fila sier det selv:
      «En NY modul trenger ikke røre denne fila heller.»

      Sikring i KR: env.ref(xmlid, raise_if_not_found=False) dropper linja hvis handlingen
      ikke finnes i databasen → aldri dødt menypunkt i en tenant uten modulen.

      ⚠️ MALFORMERT JSON DROPPES STILLE (except (ValueError, TypeError): continue) — en
      skrivefeil gir INGEN feilmelding, bare en usynlig flate. Verdien under er derfor
      validert maskinelt med json.loads() før push, ikke bare XML-velformet.
      (Advarsel mottatt fra AI KR-sporet 18.07.2026 — de gjorde samme validering.)

      label på ENGELSK i kilden, som de fem eksisterende oppføringene; norsk kommer via .po.
      sequence 40: etter AI KR (30) og avvik (35), før tidslinje (45) — Prosjektoversikt
      hører naturlig sammen med tidslinje/Gantt.
    -->
    <record id="flate_prj" model="ir.config_parameter">
        <field name="key">fiq_gui_control.flate.prj</field>
        <field name="value">{"label": "Project overview", "xmlid": "fiq_gui_prj.action_fiq_gui_prj", "sequence": 40}</field>
    </record>
</odoo>
