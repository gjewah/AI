<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
      Sjekklister på PROSJEKTET (native) — Gjermund 19.07.2026: «på oppgaver, helst også
      på prosjekter og på HD og Feltservice og Salgsmuligheter osv.»
      Feltene kommer fra `fiq.sjekkliste.mixin`; en ny modul får det samme med ÉN linje
      (_inherit = [..., "fiq.sjekkliste.mixin"]) uten endring i sjekkliste-motoren.
    -->
    <record id="view_project_form_fiq_sjekkliste" model="ir.ui.view">
        <field name="name">project.project.form.fiq.sjekkliste</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Sjekklister" name="fiq_sjekklister">
                    <div class="oe_button_box">
                        <button name="apne_sjekkliste_flate" type="object"
                                string="Åpne sjekkliste-flate" class="btn-primary"
                                icon="fa-check-square-o" invisible="not id"/>
                    </div>
                    <field name="fiq_sjekkliste_fremdrift" widget="progressbar" readonly="1"/>
                    <field name="fiq_sjekkliste_ids" nolabel="1"
                           context="{'default_res_model': 'project.project', 'default_res_id': id}">
                        <list>
                            <field name="name"/>
                            <field name="type_liste"/>
                            <field name="antall_ok" string="Utført"/>
                            <field name="antall_punkt" string="Av"/>
                            <field name="fremdrift" widget="progressbar"/>
                            <field name="versjon"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Sjekklister som egen fane på oppgaven (native) -->
    <record id="view_task_form_fiq_sjekkliste" model="ir.ui.view">
        <field name="name">project.task.form.fiq.sjekkliste</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Sjekklister" name="fiq_sjekklister">
                    <div class="oe_button_box">
                        <button name="apne_sjekkliste_flate" type="object"
                                string="Åpne sjekkliste-flate" class="btn-primary"
                                icon="fa-check-square-o" invisible="not id"/>
                    </div>
                    <field name="fiq_sjekkliste_fremdrift" widget="progressbar" readonly="1"/>
                    <field name="fiq_sjekkliste_ids" nolabel="1">
                        <list>
                            <field name="name"/>
                            <field name="type_liste"/>
                            <field name="antall_ok" string="Utført"/>
                            <field name="antall_punkt" string="Av"/>
                            <field name="fremdrift" widget="progressbar"/>
                            <field name="versjon"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
