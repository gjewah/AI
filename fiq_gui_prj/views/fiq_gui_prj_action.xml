<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Klient-handling: OWL-flaten -->
    <record id="action_fiq_gui_prj" model="ir.actions.client">
        <field name="name">FIQ Prosjekt</field>
        <field name="tag">fiq_gui_prj_dashboard</field>
    </record>

    <!--
      NATIVE MENYPUNKT — AI PK-avgjørelse 2026-07-17 (sak: «flatene er uåpnelige»).

      Sto tidligere: «Ingen topp-meny: flaten åpnes fra FIQ Hovedmeny sin sidemeny
      (samlende skall).» -> men skallet lenket ikke til noe (grep: 0 treff), og modulen
      hadde ingen menypunkter. Resultat: flaten var UÅPNELIG.

      AI PK: «Er KR et LAG, kan det ikke være eneste dør inn — da blir KR et
      single-point-of-failure for tilgjengelighet.» Følger KANON «Odoo-native først».
      KR-sidemenyen kommer i TILLEGG (06.74), ikke som forutsetning.
    -->
    <!--
      APP-IKON: låner Odoos EGET project-ikon (samme grep som fiq_gui_gantt).
      Gjermund 2026-07-17: «beste løsning at du bruker Odoo native logo.»

      Hvorfor ikke egen logofil: `web_icon` er fields.Char = en FILSTI i en modul (verifisert i
      base/models/ir_ui_menu.py) — den kan IKKE lese et databasefelt. En egen PNG i modulen måtte
      derfor bygges+pushes hver gang logoen endres, og en HELT NY logoserie er på vei
      (visjon: Futures IQ). Native ikon nå = ingen død vekt å rydde senere.

      Firma-logoen leses derimot NATIVE i flatene: `res.company.logo` via `fiq_brand_logo`
      (fiq_partner_relasjon, 06.74) — company-logo som kilde, KR-variant kun ved bevisst
      overstyring. Det er databasedrevet og endres i Odoo-innstillingene, uten kode.

      NB: `web_icon` (app-ikon i menyen) ≠ `favicon` (nettleserfanens ikon, Binary-felt på
      website-modellen). Verifisert i Odoo 19s kildekode — favicon er ikke et menuitem-attributt.
    -->
    <menuitem id="menu_fiq_prj_root"
              name="FIQ Prosjekt"
              web_icon="project,static/description/icon.png"
              sequence="46"/>

    <menuitem id="menu_fiq_prj_flate"
              name="Prosjektoversikt"
              parent="menu_fiq_prj_root"
              action="action_fiq_gui_prj"
              sequence="10"/>
</odoo>
