<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Klient-handling: OWL-flaten -->
    <record id="action_fiq_gui_prj" model="ir.actions.client">
        <field name="name">FIQ Prosjekt</field>
        <field name="tag">fiq_gui_prj_dashboard</field>
    </record>

    <!--
      NATIVE MENYPUNKT — AI PK-avgjørelse 2026-07-17 (sak: «flatene er uåpnelige»).

      Sto tidligere: «Ingen topp-meny: flaten åpnes fra FIQ Hovedmeny sin sidemeny
      (samlende skall).» -> men skallet lenket ikke til noe (grep: 0 treff), og modulen
      hadde ingen menypunkter. Resultat: flaten var UÅPNELIG.

      AI PK: «Er KR et LAG, kan det ikke være eneste dør inn — da blir KR et
      single-point-of-failure for tilgjengelighet.» Følger KANON «Odoo-native først».
      KR-sidemenyen kommer i TILLEGG (06.74), ikke som forutsetning.
    -->
    <!-- FIQ-logo som app-ikon (Gjermund 2026-07-17: «Logo_Svart_Sølv Elipse.png» fra
         012 5 MAR MedBib). Original 519x446 er IKKE kvadratisk -> skalert til 140x140 med
         bevart proporsjon, sentrert på transparent bunn (samme størrelse som
         fiq_gui_control/static/description/icon.png — verifisert).
         NB: `web_icon` er riktig attributt for menypunkt (Odoos egne: project, sale_management,
         account bruker samme form). `favicon` er noe annet — nettleserfanens ikon på
         website-modellen, ikke et menuitem-attributt. Verifisert i Odoo 19s kildekode. -->
    <menuitem id="menu_fiq_prj_root"
              name="FIQ Prosjekt"
              web_icon="fiq_gui_prj,static/description/icon.png"
              sequence="46"/>

    <menuitem id="menu_fiq_prj_flate"
              name="Prosjektoversikt"
              parent="menu_fiq_prj_root"
              action="action_fiq_gui_prj"
              sequence="10"/>
</odoo>
