<odoo>
    <data noupdate="1">
        <record id="mail_config_by_user__name" model="ir.config_parameter">
            <field name="key">mail_config_by_user.name</field>
            <field name="value">Odoo Email Integration - {name}</field>
        </record>
        <record id="mail_config_by_user__smtp_host" model="ir.config_parameter">
            <field name="key">mail_config_by_user.smtp_host</field>
            <field name="value">smtp.office365.com</field>
        </record>
        <record id="mail_config_by_user__smtp_authentication" model="ir.config_parameter">
            <field name="key">mail_config_by_user.smtp_authentication</field>
            <field name="value">outlook</field>
        </record>
        <record id="mail_config_by_user__smtp_encryption" model="ir.config_parameter">
            <field name="key">mail_config_by_user.smtp_encryption</field>
            <field name="value">starttls</field>
        </record>
        <record id="mail_config_by_user__smtp_port" model="ir.config_parameter">
            <field name="key">mail_config_by_user.smtp_port</field>
            <field name="value">587</field>
        </record>
        <record id="mail_config_by_user__sequence" model="ir.config_parameter">
            <field name="key">mail_config_by_user.sequence</field>
            <field name="value">2</field>
        </record>
    </data>
</odoo>
