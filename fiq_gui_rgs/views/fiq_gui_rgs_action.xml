<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Klient-handling: OWL-skjelettet -->
    <record id="action_fiq_gui_rgs" model="ir.actions.client">
        <field name="name">FIQ Regnskap</field>
        <field name="tag">fiq_gui_rgs_dashboard</field>
    </record>
    <!-- Regnskap (2.80) er UNDERMENY under Finans (2.70) — Gjermund 18.07.2026:
         «Finans skal være hoved, Regnskap skal vises som en undermeny til Finans.»
         Tidligere lå de som TO sidestilte toppmenyer. Det var feil: det speilet ikke
         rollehierarkiet (2.80 rapporterer til 2.70 CFO) og ga to innganger til samme fag.

         Native menypunkt beholdes (AI PK 17.07): hver flate SKAL ha egen vei inn —
         KR/skallet som eneste dør = single-point-of-failure. Skallets sidemeny kommer
         I TILLEGG. Jf. «Odoo-native først — KR er et LAG».

         Egen menyrot for Regnskap er FJERNET — den ville gitt dobbel inngang igjen. -->
    <menuitem id="menu_fiq_gui_rgs_flate"
              name="Regnskap"
              parent="fiq_gui_fin.menu_fiq_gui_fin_root"
              action="action_fiq_gui_rgs"
              sequence="20"
              groups="fiq_gui_rgs.group_user"/>
</odoo>
