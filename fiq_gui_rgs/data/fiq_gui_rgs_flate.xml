<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
      Selvregistrering i Kontrollrom-menyen (KR v6.82-mekanismen).

      Uten denne har flaten INGEN dør inn fra KR-menyen — den virker, men vises uten
      sidemeny. Det var nøyaktig symptomet Gjermund meldte 18.07.2026.

      MODULEN MELDER SEG INN SELV — `fiq_gui_control` røres aldri. `get_fiq_flater()`
      leser alle nøkler med prefikset `fiq_gui_control.flate.` uansett hvilken modul de
      kommer fra.

      ⚠️ TO ULIKE MEKANISMER — ikke bland dem:
        * DENNE (server-side): `ir.config_parameter` → KR-menyen.
        * `static/src/rgs.js` (nettleser): `registry.category("fiq_gui_flates")` → skallets
          innmat-slot. Begge trengs; de gjør forskjellige ting.

      Språk: `label` er ENGELSK i kilden (som de seks eksisterende oppføringene) — norsk
      kommer via i18n/*.po. Aldri hardkod norsk i modulkilde.

      Sekvens 75 holder finans-familien samlet (fin 70, rgs 75), etter befaring (60) og
      før ai_rolle (85).
    -->
    <data noupdate="0">

        <record id="flate_rgs" model="ir.config_parameter">
            <field name="key">fiq_gui_control.flate.rgs</field>
            <field name="value">{"label": {"en_US": "Accounting", "nb_NO": "Regnskap"}, "xmlid": "fiq_gui_rgs.action_fiq_gui_rgs", "sequence": 75}</field>
        </record>

    </data>
