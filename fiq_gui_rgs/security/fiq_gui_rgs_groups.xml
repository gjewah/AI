<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Odoo 19: en gruppe UTEN privilege_id er USYNLIG i Innstillinger.
         res.groups har ingen category_id-kolonne i 19 — den går via
         res.groups.privilege → category_id. Samme mønster som fiq_gui_control v6.77. -->
    <record id="res_groups_privilege_rgs" model="res.groups.privilege">
        <field name="name">FIQ Regnskap</field>
        <field name="category_id" ref="base.module_category_productivity"/>
        <field name="sequence">80</field>
    </record>

    <!-- 2.80 Bruker: ser likviditetsbildet. -->
    <record id="group_user" model="res.groups">
        <field name="name">FIQ Regnskap / Bruker</field>
        <field name="privilege_id" ref="fiq_gui_rgs.res_groups_privilege_rgs"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- 2.80 Regnskapsansvarlig: full flate.
         MERK: skjelettet ga tidligere ALLE interne brukere tilgang via
         base.group_user → implied. Det er FJERNET: regnskap tildeles bevisst. -->
    <record id="group_manager" model="res.groups">
        <field name="name">FIQ Regnskap / Regnskapsansvarlig</field>
        <field name="privilege_id" ref="fiq_gui_rgs.res_groups_privilege_rgs"/>
        <field name="implied_ids" eval="[(4, ref('fiq_gui_rgs.group_user'))]"/>
    </record>
</odoo>
