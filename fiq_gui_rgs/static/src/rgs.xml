<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="fiq_gui_rgs.Flate">
    <div class="fiqr">
        <div class="fiqr-topp">
            <div>
                <h2 class="fiqr-tittel">Regnskap</h2>
                <div class="fiqr-und">
                    AI Regnskap-Rådgiver (2.80) · firma <b t-esc="firma"/>
                </div>
            </div>
            <div class="fiqr-merke">Rådgiver — ikke beslutter</div>
        </div>

        <div class="fiqr-utkast">
            <b>UTKAST 01 — rammeverk.</b> Datakildene er ikke koblet ennå. Tallfelt står tomme
            med kilde-merknad; ingenting her er bokførte tall.
        </div>

        <!-- 1. LIKVIDITETS-OVERSIKT -->
        <section class="fiqr-kort">
            <h3>Oversikt</h3>
            <div class="fiqr-botter">
                <div t-foreach="botter" t-as="b" t-key="b.key"
                     class="fiqr-botte"
                     t-att-class="{
                        'fiqr-botte-haster': b.key === 'haster',
                        'fiqr-botte-kritisk': b.key === 'kritisk'
                     }">
                    <div class="fiqr-botte-navn" t-esc="b.label"/>
                    <div class="fiqr-botte-tall">—</div>
                    <div class="fiqr-botte-kilde" t-esc="b.kilde"/>
                </div>
            </div>
        </section>

        <!-- 2. CASHFLOW + KRITISKE DATOER -->
        <section class="fiqr-kort">
            <h3>Cashflow og kritiske datoer</h3>
            <p class="fiqr-hjelp">Når blir det tight? Framskrivning av likviditeten.</p>
            <div class="fiqr-scenario-merke">FRAMSKRIVNING — ikke bokførte tall</div>
            <div class="fiqr-tom">Kurve + kritiske datoer — ikke koblet i UTKAST 01.</div>
        </section>

        <!-- 3. MÅ TA HØYDE FOR — ellers lyver cashflow-en -->
        <section class="fiqr-kort">
            <h3>Må tas høyde for</h3>
            <p class="fiqr-hjelp">
                Uten disse lyver cashflow-en. Lønn har <b>egen gate</b>: flaten viser
                aggregater, aldri individuell lønns-PII.
            </p>
            <div class="fiqr-forp">
                <div t-foreach="forpliktelser" t-as="f" t-key="f.key" class="fiqr-forp-rad">
                    <span class="fiqr-forp-navn" t-esc="f.label"/>
                    <span t-if="f.gate" class="fiqr-gate">Egen gate — aggregat</span>
                    <span class="fiqr-tom fiqr-tom-liten">Ikke koblet</span>
                </div>
            </div>
        </section>

        <!-- 4. TIDLIG KORRIGERING — det proaktive -->
        <section class="fiqr-kort">
            <h3>Tidlig korrigering</h3>
            <p class="fiqr-hjelp">Grep FØR det brenner — for å verne likviditeten.</p>
            <div class="fiqr-forslag">
                <div class="fiqr-forslag-rad">
                    <span class="fiqr-forslag-navn">Kortere frister</span>
                    <span class="fiqr-tom fiqr-tom-liten">Forslag fra rådgiveren — ikke koblet</span>
                </div>
                <div class="fiqr-forslag-rad">
                    <span class="fiqr-forslag-navn">Tidligere fakturering</span>
                    <span class="fiqr-tom fiqr-tom-liten">Forslag fra rådgiveren — ikke koblet</span>
                </div>
            </div>
            <div class="fiqr-note">
                Forslag — ingen automatiske finansielle handlinger. Mennesket bestemmer.
            </div>
        </section>
    </div>
</t>

</templates>
