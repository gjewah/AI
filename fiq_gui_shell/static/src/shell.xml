<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="fiq_gui_shell.Shell">
        <div class="fiqs" t-att-data-fiq-theme="state.theme">

            <!-- FAST: presence-linje (ekte data fra KR: get_presence) -->
            <div class="fiqs-presence">
                <span class="fiqs-pl">Til stede nå</span>
                <div class="fiqs-chips">
                    <t t-foreach="state.presence" t-as="p" t-key="p.id">
                        <span t-attf-class="fiqs-pc {{p.farge}}" t-att-title="p.tekst">
                            <img t-if="p.avatar" class="fiqs-pi"
                                 t-attf-src="data:image/png;base64,{{p.avatar}}" alt=""/>
                            <span t-else="" class="fiqs-pa" t-esc="p.initialer"/>
                            <span t-esc="p.navn"/>
                        </span>
                    </t>
                </div>
            </div>

            <!-- FAST: firma-band + tema -->
            <div class="fiqs-top">
                <div class="fiqs-brand">
                    <img t-if="currentFirm.logo" class="fiqs-logoimg"
                         t-att-src="currentFirm.logo" t-att-alt="currentFirm.navn"/>
                    <div t-else="" class="fiqs-logo" t-attf-style="background:{{currentFirm.color}}">
                        <t t-esc="currentFirm.code"/>
                    </div>
                    <div>
                        <div class="fiqs-eb">FIQ KONTROLLROM · 8.50 GUI</div>
                        <h1 t-esc="currentFlate and currentFlate.label or 'Kontrollrom'"/>
                    </div>
                </div>
                <div class="fiqs-sp"/>
                <!-- Firmavelger: KUN firmaene brukeren lovlig kan se (tillatte_firmaer,
                     fail-closed server-side). Ingen «Alle»-knapp uten 000-rettighet. -->
                <div class="fiqs-switch">
                    <t t-foreach="state.firms" t-as="f" t-key="f.id">
                        <button t-attf-class="fiqs-swb {{f.id === state.firm ? 'on' : ''}}"
                                t-attf-style="{{f.id === state.firm ? 'background:'+f.color+';border-color:'+f.color+';color:#fff' : ''}}"
                                t-on-click="() => this.selectFirm(f.id)">
                            <span t-esc="f.navn"/>
                        </button>
                    </t>
                    <span t-if="state.error" class="fiqs-err" t-esc="state.error"/>
                </div>
                <button class="fiqs-theme" t-on-click="toggleTheme">◐ Tema</button>
            </div>

            <!-- Wrap: FAST sidemeny + INNMAT-slot -->
            <div class="fiqs-wrap">
                <aside class="fiqs-side">
                    <div class="fiqs-sh">Kontrollrom</div>
                    <nav class="fiqs-nav">
                        <t t-foreach="flates" t-as="fl" t-key="fl.key">
                            <button t-attf-class="fiqs-navb {{fl.key === state.current ? 'on' : ''}}"
                                    t-on-click="() => this.selectFlate(fl.key)">
                                <span class="fiqs-dot" t-attf-style="background:{{fl.color or '#4C63D2'}}"/>
                                <span t-esc="fl.label"/>
                            </button>
                        </t>
                    </nav>
                </aside>
                <main class="fiqs-main">
                    <t t-if="currentComponent">
                        <!-- Kontrakt til flatene: firm = res.company-ID (ekte, brukbar rett
                             i domener). har000 = plattform-nivå. Var demo-kode («012») før. -->
                        <t t-component="currentComponent"
                           t-props="{ firm: state.firm, har000: state.har000, label: currentFlate.label }"/>
                    </t>
                    <t t-else="">
                        <div class="fiqs-empty">Ingen flater registrert ennå.</div>
                    </t>
                </main>
            </div>
        </div>
    </t>
</templates>
