<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="fiq_gui_shell.Shell">
        <div class="fiqs" t-att-data-fiq-theme="state.theme">

            <!-- FAST: presence-linje -->
            <div class="fiqs-presence">
                <span class="fiqs-pl">Til stede nå</span>
                <div class="fiqs-chips">
                    <t t-foreach="presence" t-as="p" t-key="p.init">
                        <span t-attf-class="fiqs-pc {{p.status}}">
                            <span class="fiqs-pa" t-esc="p.init"/>
                            <span t-esc="p.navn"/>
                        </span>
                    </t>
                </div>
            </div>

            <!-- FAST: firma-band + tema -->
            <div class="fiqs-top">
                <div class="fiqs-brand">
                    <div class="fiqs-logo" t-attf-style="background:{{currentFirm.color}}">
                        <t t-esc="currentFirm.code"/>
                    </div>
                    <div>
                        <div class="fiqs-eb">FIQ KONTROLLROM · 8.50 GUI</div>
                        <h1 t-esc="currentFlate and currentFlate.label or 'Kontrollrom'"/>
                    </div>
                </div>
                <div class="fiqs-sp"/>
                <div class="fiqs-switch">
                    <t t-foreach="firms" t-as="f" t-key="f.code">
                        <button t-attf-class="fiqs-swb {{f.code === state.firm ? 'on' : ''}}"
                                t-attf-style="{{f.code === state.firm ? 'background:'+f.color+';border-color:'+f.color+';color:#fff' : ''}}"
                                t-on-click="() => this.selectFirm(f.code)">
                            <b t-esc="f.code"/> <span t-esc="f.navn"/>
                        </button>
                    </t>
                </div>
                <button class="fiqs-theme" t-on-click="toggleTheme">◐ Tema</button>
            </div>

            <!-- Wrap: FAST sidemeny + INNMAT-slot -->
            <div class="fiqs-wrap">
                <aside class="fiqs-side">
                    <div class="fiqs-sh">Kontrollrom</div>
                    <nav class="fiqs-nav">
                        <t t-foreach="flates" t-as="fl" t-key="fl.key">
                            <button t-attf-class="fiqs-navb {{fl.key === state.current ? 'on' : ''}}"
                                    t-on-click="() => this.selectFlate(fl.key)">
                                <span class="fiqs-dot" t-attf-style="background:{{fl.color or '#4C63D2'}}"/>
                                <span t-esc="fl.label"/>
                            </button>
                        </t>
                    </nav>
                </aside>
                <main class="fiqs-main">
                    <t t-if="currentComponent">
                        <t t-component="currentComponent"
                           t-props="{ firm: state.firm, label: currentFlate.label }"/>
                    </t>
                    <t t-else="">
                        <div class="fiqs-empty">Ingen flater registrert ennå.</div>
                    </t>
                </main>
            </div>
        </div>
    </t>
</templates>
