<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_fiq_ai_rolle_form" model="ir.ui.view">
        <field name="name">fiq.ai.rolle.form</field>
        <field name="model">fiq.ai.rolle</field>
        <field name="arch" type="xml">
            <form string="AI-rolle">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="f.eks. 2.90 IT-Ansvarlig"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="rolletype"/>
                            <field name="omraade_kode"/>
                            <field name="company_id"/>
                            <field name="aktiv"/>
                        </group>
                        <group>
                            <field name="skill_ref"/>
                            <field name="kpi"/>
                            <field name="membran_scope"/>
                            <field name="oppdater_kadens"/>
                            <field name="ansvarlig_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="ansvar_maal" placeholder="Stillingsbeskrivelse — ansvar og mål"/>
                        <field name="radgivere_ids" widget="many2many_tags"/>
                    </group>
                    <notebook>
                        <page string="Spørsmål &amp; svar (driver prompten)">
                            <field name="qa_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="sporsmal"/>
                                    <field name="svar"/>
                                </list>
                            </field>
                        </page>
                        <page string="System-prompt (auto)">
                            <field name="prompt" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fiq_ai_rolle_list" model="ir.ui.view">
        <field name="name">fiq.ai.rolle.list</field>
        <field name="model">fiq.ai.rolle</field>
        <field name="arch" type="xml">
            <list string="AI-roller">
                <field name="omraade_kode"/>
                <field name="name"/>
                <field name="rolletype"/>
                <field name="company_id"/>
                <field name="skill_ref"/>
                <field name="aktiv"/>
            </list>
        </field>
    </record>

    <record id="view_fiq_ai_rolle_search" model="ir.ui.view">
        <field name="name">fiq.ai.rolle.search</field>
        <field name="model">fiq.ai.rolle</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="omraade_kode"/>
                <field name="skill_ref"/>
                <filter name="aktiv" string="Aktive" domain="[('aktiv','=',True)]"/>
                <filter name="ledere" string="Ledere" domain="[('rolletype','=','leder')]"/>
                <filter name="radgivere" string="Rådgivere" domain="[('rolletype','=','radgiver')]"/>
                <group expand="0" string="Grupper">
                    <filter name="g_firma" string="Firma" context="{'group_by':'company_id'}"/>
                    <filter name="g_type" string="Rolletype" context="{'group_by':'rolletype'}"/>
                    <filter name="g_omrade" string="Område" context="{'group_by':'omraade_kode'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_fiq_ai_rolle" model="ir.actions.act_window">
        <field name="name">AI-roller</field>
        <field name="res_model">fiq.ai.rolle</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_aktiv': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiley_face">Opprett den første AI-rollen</p>
            <p>Roller (Leder/Rådgiver) i AI-organisasjonen. AI-ansvarlig svarer på spørsmål —
               prompten komponeres automatisk.</p>
        </field>
    </record>

    <menuitem id="menu_fiq_ai_org_root" name="AI-organisasjon" sequence="90"/>
    <menuitem id="menu_fiq_ai_rolle" name="Roller"
              parent="menu_fiq_ai_org_root" action="action_fiq_ai_rolle" sequence="10"/>

</odoo>
