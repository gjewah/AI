<odoo>
  <report id="vidir_suite_report_dpp_labels_avery" model="vidir.dpp.passport" string="DPP QR‑etiketter (Avery 3x7)" report_type="qweb-pdf" name="vidir_suite.dpp_labels_avery" file="vidir_suite.dpp_labels_avery"/>
  <template id="dpp_labels_avery">
    <t t-call="web.external_layout">
      <t t-foreach="docs" t-as="o">
        <div class="page">
          <div style="display:grid; grid-template-columns: repeat(3, 1fr); grid-gap:6mm;">
            <t t-foreach="range(21)" t-as="i">
              <div style="width:63.5mm; height:38.1mm; border:0.2pt solid #ddd; padding:2mm; overflow:hidden;">
                <div style="display:flex; gap:2mm;">
                  <img t-att-src="'/report/barcode/?type=QR&amp;value=%s&amp;width=120&amp;height=120' % (o.dpp_url or '')" style="width:18mm;height:18mm;"/>
                  <div><div style="font-size:9pt"><t t-esc="o.product_tmpl_id.name"/></div>
                    <div style="font-size:7pt">GTIN: <t t-esc="o.gtin or '-'"/></div>
                    <div style="font-size:7pt">DPP: <t t-esc="o.uuid"/></div>
                  </div>
                </div>
              </div>
            </t>
          </div>
        </div>
      </t>
    </t>
  </template>
</odoo>