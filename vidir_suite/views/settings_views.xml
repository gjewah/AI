<odoo>
  <record id="view_vidir_co2_settings" model="ir.ui.view">
    <field name="name">vidir.suite.settings</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="base.res_config_settings_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//div[@id='settings']" position="inside">
        <div class="app_settings_block" data-string="Vidir Suite" string="Vidir Suite">
          <h2>Vidir Suite – Kalkulator &amp; DPP</h2>
          <group>
            <field name="co2_grid_factors" widget="text"/>
            <field name="co2_transport_factors" widget="text"/>
            <field name="co2_flight_factors" widget="text"/>
            <field name="co2_screening_intensity"/>
          </group>
        </div>
      </xpath>
    </field>
  </record>
</odoo>