<odoo>
  <template id="portal_my_dpps" name="Mine DPP‑er">
    <t t-call="portal.portal_layout">
      <div class="o_portal_my_doc">
        <h3>Mine DPP‑er</h3>
        <table class="table table-striped">
          <thead><tr><th>Produkt</th><th>GTIN</th><th>Lot/Serial</th><th>DPP</th><th/></tr></thead>
          <tbody>
            <t t-foreach="records" t-as="r">
              <tr>
                <td><t t-esc="r.product_tmpl_id.name"/></td>
                <td><t t-esc="r.gtin or '-'"/></td>
                <td><t t-esc="r.lot or '-'"/></td>
                <td><a t-att-href="r.dpp_url" target="_blank"><t t-esc="r.uuid"/></a></td>
                <td class="text-end">
                  <a class="btn btn-sm btn-outline-primary" t-att-href="'/dpp/' + r.uuid" target="_blank">Åpne</a>
                  <a class="btn btn-sm btn-outline-secondary" t-att-href="'/report/pdf/vidir_suite.dpp_label_pdf/' + str(r.id)">Etikett</a>
                </td>
              </tr>
            </t>
          </tbody>
        </table>
      </div>
    </t>
  </template>
</odoo>