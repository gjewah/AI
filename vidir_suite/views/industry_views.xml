<odoo>
  <record id="view_vidir_industry_tree" model="ir.ui.view">
    <field name="name">vidir.industry.tree</field>
    <field name="model">vidir.industry</field>
    <field name="arch" type="xml"><list><field name="name"/><field name="code"/><field name="active"/></list></field>
  </record>
  <record id="view_vidir_industry_form" model="ir.ui.view">
    <field name="name">vidir.industry.form</field>
    <field name="model">vidir.industry</field>
    <field name="arch" type="xml"><form><sheet><group><field name="name"/><field name="code"/><field name="active"/></group></sheet></form></field>
  </record>
  <record id="view_vidir_industry_profile_tree" model="ir.ui.view">
    <field name="name">vidir.industry.profile.tree</field>
    <field name="model">vidir.industry.profile</field>
    <field name="arch" type="xml"><list><field name="name"/><field name="industry_id"/><field name="country"/><field name="year"/><field name="company_id"/></list></field>
  </record>
  <record id="view_vidir_industry_profile_form" model="ir.ui.view">
    <field name="name">vidir.industry.profile.form</field>
    <field name="model">vidir.industry.profile</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="%(action_vidir_industry_factor_import_wizard)d" type="action" string="Importer faktorer (XLSX)" class="btn-secondary"/>
        </header>
        <sheet><group>
          <field name="name"/>
          <field name="industry_id"/>
          <field name="country"/>
          <field name="year"/>
          <field name="valid_from"/>
          <field name="valid_to"/>
          <field name="company_id"/>
        </group></sheet>
      </form>
    </field>
  </record>
  <record id="view_vidir_industry_factor_tree" model="ir.ui.view">
    <field name="name">vidir.industry.factor.set.tree</field>
    <field name="model">vidir.industry.factor.set</field>
    <field name="arch" type="xml"><list editable="bottom"><field name="profile_id"/><field name="code"/><field name="unit"/><field name="value"/><field name="source_ref"/><field name="company_id"/></list></field>
  </record>
  <record id="action_vidir_industry" model="ir.actions.act_window">
    <field name="name">Bransjer</field>
    <field name="res_model">vidir.industry</field>
    <field name="view_mode">list,form</field>
  </record>
  <record id="action_vidir_industry_profile" model="ir.actions.act_window">
    <field name="name">Profiler</field>
    <field name="res_model">vidir.industry.profile</field>
    <field name="view_mode">list,form</field>
  </record>
  <record id="action_vidir_industry_factors" model="ir.actions.act_window">
    <field name="name">Faktorer</field>
    <field name="res_model">vidir.industry.factor.set</field>
    <field name="view_mode">list</field>
  </record>

  <menuitem id="menu_vidir_industry_root" name="Vidir Faktorprofiler" parent="base.menu_custom" sequence="40"/>
  <menuitem id="menu_vidir_industry" name="Bransjer" parent="menu_vidir_industry_root" action="action_vidir_industry"/>
  <menuitem id="menu_vidir_profiles" name="Profiler" parent="menu_vidir_industry_root" action="action_vidir_industry_profile"/>
  <menuitem id="menu_vidir_factors" name="Faktorer" parent="menu_vidir_industry_root" action="action_vidir_industry_factors"/>

  <record id="view_vidir_industry_factor_import_wizard" model="ir.ui.view">
    <field name="name">vidir.industry.factor.import.wizard.form</field>
    <field name="model">vidir.industry.factor.import.wizard</field>
    <field name="arch" type="xml">
      <form string="Importer faktorer (XLSX)">
        <group>
          <field name="company_id"/>
          <field name="industry_id"/>
          <field name="profile_id"/>
          <field name="file_name"/>
          <field name="file_data" filename="file_name"/>
        </group>
        <footer>
          <button name="action_import" type="object" string="Importer" class="btn-primary"/>
          <button string="Avbryt" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>
  <record id="action_vidir_industry_factor_import_wizard" model="ir.actions.act_window">
    <field name="name">Importer faktorer</field>
    <field name="res_model">vidir.industry.factor.import.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>
</odoo>