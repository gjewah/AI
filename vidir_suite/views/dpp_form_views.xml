<odoo>
  <record id="view_vidir_dpp_form" model="ir.ui.view">
    <field name="name">vidir.dpp.passport.form</field>
    <field name="model">vidir.dpp.passport</field>
    <field name="arch" type="xml">
      <form string="Digital Product Passport">
        <header>
          <button name="action_open_pdf" type="object" string="PDF‑rapport" class="btn-primary"/>
          <button name="action_export_esg" type="object" string="Eksporter ESG (Excel)"/>
        </header>
        <sheet>
          <group>
            <group>
              <field name="name"/>
              <field name="uuid" readonly="1"/>
              <field name="product_tmpl_id"/>
              <field name="partner_id"/>
              <field name="gtin"/>
              <field name="lot"/>
              <field name="country_of_origin"/>
              <field name="company_id"/>
            </group>
            <group>
              <field name="industry_id"/>
              <field name="industry_profile_id"/>
              <field name="default_marine_fuel_type"/>
              <field name="default_marine_fuel_ton"/>
            </group>
          </group>
          <notebook>
            <page string="Komposisjon"><field name="composition" widget="text"/></page>
            <page string="Tilleggsdata"><field name="extras_json" widget="text"/></page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>
</odoo>