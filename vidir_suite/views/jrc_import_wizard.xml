<odoo>
  <record id="view_vidir_jrc_import_wizard" model="ir.ui.view">
    <field name="name">vidir.jrc.import.wizard.form</field>
    <field name="model">vidir.jrc.import.wizard</field>
    <field name="arch" type="xml">
      <form string="Importer JRC/NEEFE Excel">
        <group>
          <field name="file_name"/>
          <field name="file_data" filename="file_name"/>
          <field name="sheet_name"/>
          <field name="country_col"/>
          <field name="factor_col"/>
        </group>
        <footer>
          <button name="action_import" string="Importer" class="btn-primary" type="object"/>
          <button string="Avbryt" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>