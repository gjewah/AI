<odoo>
  <template id="dpp_landing_page" name="DPP – Landingsside">
    <t t-call="website.layout">
      <div class="container mt-4 mb-5">
        <div class="row g-3">
          <div class="col-lg-8">
            <h2><t t-esc="dpp.product_tmpl_id.name or dpp.name"/></h2>
            <p class="text-muted"><t t-esc="dpp.product_tmpl_id.categ_id.complete_name or ''"/> · <a t-att-href="json_url" target="_blank">JSON‑LD</a></p>
            <div class="card p-3 mb-3">
              <h5>Oppsummering</h5>
              <ul class="list-unstyled mb-0">
                <li><strong>GTIN:</strong> <t t-esc="dpp.gtin or '-'"/></li>
                <li><strong>Lot/Serial:</strong> <t t-esc="dpp.lot or '-'"/></li>
                <li><strong>DPP‑URL:</strong> <a t-att-href="dpp.dpp_url"><t t-esc="dpp.dpp_url"/></a></li>
              </ul>
            </div>
            <div class="card p-3"><h5>Egenskaper</h5>
              <pre class="mb-0"><t t-esc="dpp.composition or '-'"/></pre>
            </div>
          </div>
          <div class="col-lg-4">
            <div class="card p-3"><h5>Handlinger</h5>
              <div class="d-grid gap-2">
                <a class="btn btn-primary" t-att-href="report_pdf_url" target="_blank">Last ned DPP‑rapport (PDF)</a>
                <a class="btn btn-outline-primary" t-att-href="export_xlsx_url" target="_blank">Eksporter ESG (Excel)</a>
                <a class="btn btn-outline-secondary" t-att-href="'/report/pdf/vidir_suite.dpp_label_pdf/' + str(dpp.id)">Skriv ut QR‑etikett</a>
              </div>
              <div class="mt-3">
                <img t-att-src="'/report/barcode/?type=QR&amp;value=%s&amp;width=200&amp;height=200' % dpp.dpp_url" style="width: 140px; height: 140px;" alt="QR"/>
              </div>
            </div>
          </div>
        </div>
      </div>
    </t>
  </template>
</odoo>