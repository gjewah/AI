<odoo>
  <report id="vidir_suite_report_dpp_label" model="vidir.dpp.passport" string="DPP QR‑etikett" report_type="qweb-pdf" name="vidir_suite.dpp_label_pdf" file="vidir_suite.dpp_label_pdf"/>
  <template id="dpp_label_pdf">
    <t t-call="web.external_layout">
      <t t-foreach="docs" t-as="o">
        <div class="page">
          <div style="display:flex; gap:16px; align-items:center;">
            <img t-att-src="'/report/barcode/?type=QR&amp;value=%s&amp;width=200&amp;height=200' % (o.dpp_url or '')" style="width:120px;height:120px;"/>
            <div><h3><t t-esc="o.product_tmpl_id.name"/></h3><p><strong>GTIN:</strong> <t t-esc="o.gtin or '-'"/></p><p><strong>DPP:</strong> <t t-esc="o.dpp_url"/></p></div>
          </div>
        </div>
      </t>
    </t>
  </template>
</odoo>