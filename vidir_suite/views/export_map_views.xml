<odoo>
  <record id="view_vidir_export_map_tree" model="ir.ui.view">
    <field name="name">vidir.export.map.tree</field>
    <field name="model">vidir.export.map</field>
    <field name="arch" type="xml">
      <list editable="bottom">
        <field name="company_id"/>
        <field name="target"/>
        <field name="category"/>
        <field name="account_code"/>
      </list>
    </field>
  </record>
  <record id="view_vidir_export_map_form" model="ir.ui.view">
    <field name="name">vidir.export.map.form</field>
    <field name="model">vidir.export.map</field>
    <field name="arch" type="xml">
      <form string="ERP‑mapping">
        <sheet>
          <group>
            <field name="company_id"/>
            <field name="target"/>
            <field name="category"/>
            <field name="account_code"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>
  <record id="action_vidir_export_map" model="ir.actions.act_window">
    <field name="name">ERP‑mapping</field>
    <field name="res_model">vidir.export.map</field>
    <field name="view_mode">list,form</field>
  </record>
  <menuitem id="menu_vidir_export_root" name="Vidir Eksport" parent="base.menu_custom" sequence="45"/>
  <menuitem id="menu_vidir_export_map" name="ERP‑mapping" parent="menu_vidir_export_root" action="action_vidir_export_map"/>
</odoo>