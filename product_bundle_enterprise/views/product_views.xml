<odoo>
    <record id="view_product_bundle_enterprise" model="ir.ui.view">
        <field name="name">product.template.bundle.enterprise</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Bundle Engine">
                    <field name="is_bundle"/>
                    <field name="bundle_line_ids">
                        <tree editable="bottom">
                            <field name="qty"/>
                            <field name="uom_id"/>
                            <field name="price_factor"/>
                        </tree>
                    </field>
                </group>
            </xpath>
        </field>
    </record>
</odoo>