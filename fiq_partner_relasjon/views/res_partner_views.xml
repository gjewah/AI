<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_fiq_relation" model="ir.ui.view">
        <field name="name">res.partner.form.fiq.relation</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Anchor on the tags field in the main form group (next to VAT/website),
                 where a partner's commercial identity already lives. NB: category_id
                 appears in the list and search views too, so the xpath must be scoped
                 to the form's sheet — an unscoped //field[@name='category_id'] hits the
                 list view first and produces invalid XML. -->
            <xpath expr="//sheet//field[@name='category_id']" position="after">
                <field name="fiq_relation_type"/>
                <field name="fiq_relation_level"
                       invisible="fiq_relation_type != 'agreement_partner'"/>
            </xpath>
        </field>
    </record>

    <record id="view_partner_filter_fiq_relation" model="ir.ui.view">
        <field name="name">res.partner.search.fiq.relation</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='type_company']" position="after">
                <separator/>
                <filter name="fiq_agreement_partners"
                        string="Agreement partners"
                        domain="[('fiq_relation_type', '=', 'agreement_partner')]"/>
            </xpath>
        </field>
    </record>

</odoo>
