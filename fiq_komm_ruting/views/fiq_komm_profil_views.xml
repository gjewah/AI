<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_fiq_komm_profil_list" model="ir.ui.view">
        <field name="name">fiq.komm.profil.list</field>
        <field name="model">fiq.komm.profil</field>
        <field name="arch" type="xml">
            <list string="E-postprofiler → firma" editable="bottom">
                <field name="mailbox"/>
                <field name="company_id"/>
                <field name="owner_user_id"/>
                <field name="er_felles"/>
                <field name="fetchmail_ref"/>
                <field name="aktiv"/>
            </list>
        </field>
    </record>

    <record id="view_fiq_komm_profil_form" model="ir.ui.view">
        <field name="name">fiq.komm.profil.form</field>
        <field name="model">fiq.komm.profil</field>
        <field name="arch" type="xml">
            <form string="E-postprofil → firma">
                <sheet>
                    <group>
                        <group>
                            <field name="mailbox"/>
                            <field name="company_id"/>
                            <field name="aktiv"/>
                        </group>
                        <group>
                            <field name="er_felles"/>
                            <field name="owner_user_id"/>
                            <field name="fetchmail_ref"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fiq_komm_profil" model="ir.actions.act_window">
        <field name="name">E-postprofiler → firma</field>
        <field name="res_model">fiq.komm.profil</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiley_face">Legg til første e-postprofil</p>
            <p>Kanaliser innkommende post til riktig firma: knytt hver postkasse til et firma
               (+ eier for personlige, felles-flagg for delte). Generisk for alle kunder.</p>
        </field>
    </record>

    <menuitem id="menu_fiq_komm_ruting_root" name="E-post-ruting" sequence="91"/>
    <menuitem id="menu_fiq_komm_profil" name="Profiler → firma"
              parent="menu_fiq_komm_ruting_root" action="action_fiq_komm_profil" sequence="10"/>

</odoo>
