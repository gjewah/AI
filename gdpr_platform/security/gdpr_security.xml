<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_category_gdpr" model="ir.module.category">
            <field name="name">GDPR</field>
            <field name="sequence">100</field>
            <field name="visible" eval="True"/>
        </record>

        <record id="group_gdpr_user" model="res.groups">
            <field name="name">GDPR Bruker</field>
            <field name="category_id" ref="gdpr_platform.module_category_gdpr"/>
        </record>

        <record id="group_gdpr_manager" model="res.groups">
            <field name="name">GDPR Administrator</field>
            <field name="category_id" ref="gdpr_platform.module_category_gdpr"/>
            <field name="implied_ids" eval="[(4, ref('gdpr_platform.group_gdpr_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

    </data>
</odoo>
