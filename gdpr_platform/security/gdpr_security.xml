<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="group_gdpr_user" model="res.groups">
            <field name="name">GDPR Bruker</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_gdpr_manager" model="res.groups">
            <field name="name">GDPR Administrator</field>
            <field name="implied_ids" eval="[(4, ref('gdpr_platform.group_gdpr_user'))]"/>
        </record>

        <!-- Admin får automatisk GDPR Administrator via group_system -->
        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('gdpr_platform.group_gdpr_manager'))]"/>
        </record>

    </data>
</odoo>
