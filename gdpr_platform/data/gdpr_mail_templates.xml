<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="gdpr_email_footer_template" model="mail.template">
            <field name="name">GDPR E-post Footer</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="subject">Informasjon om dine personverninnstillinger</field>
            <field name="body_html"><![CDATA[
<div style="font-family:Arial,sans-serif;font-size:12px;color:#555;margin-top:24px;padding-top:12px;border-top:1px solid #ddd;">
  <p>
    <a href="{{ object._gdpr_unsubscribe_url() }}" style="color:#888;">Avregistrer deg fra e-postlisten</a>
    &nbsp;|&nbsp;
    <a href="{{ object._gdpr_block_url() }}" style="color:#888;">Blokker all kontakt (GDPR)</a>
  </p>
</div>
            ]]></field>
            <field name="auto_delete" eval="True"/>
        </record>

    </data>
</odoo>
