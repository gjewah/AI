<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_account_move_form_gdpr" model="ir.ui.view">
            <field name="name">account.move.form.gdpr</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="action_gdpr_block_partner" type="object"
                            string="GDPR: Blokker kontakt"
                            class="btn-warning"
                            invisible="not partner_id or partner_id.x_gdpr_blocked"
                            confirm="Blokker all kontakt med denne personen (GDPR)?"/>
                    <button name="action_gdpr_unblock_partner" type="object"
                            string="GDPR: Fjern blokkering"
                            class="btn-secondary"
                            invisible="not partner_id or not partner_id.x_gdpr_blocked"
                            confirm="Fjern GDPR-blokkeringen for denne kontakten?"/>
                </xpath>
                <xpath expr="//header" position="after">
                    <div class="alert alert-danger o_gdpr_block_banner" role="alert"
                         invisible="not partner_id or not partner_id.x_gdpr_blocked">
                        <i class="fa fa-ban me-2"/>
                        <strong>GDPR BLOKKERT: Faktura kan ikke sendes til denne kontakten</strong>
                    </div>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
