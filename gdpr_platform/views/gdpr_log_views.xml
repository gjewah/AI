<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_gdpr_log_tree" model="ir.ui.view">
            <field name="name">gdpr.log.tree</field>
            <field name="model">gdpr.log</field>
            <field name="arch" type="xml">
                <list string="GDPR Log" default_order="date desc" decoration-danger="action == 'block'" decoration-success="action == 'unblock'">
                    <field name="date"/>
                    <field name="partner_id"/>
                    <field name="partner_email"/>
                    <field name="action"/>
                    <field name="source"/>
                    <field name="user_id"/>
                    <field name="ip_address"/>
                    <field name="reason" optional="hide"/>
                    <field name="company_id" groups="base.group_multi_company" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_gdpr_log_form" model="ir.ui.view">
            <field name="name">gdpr.log.form</field>
            <field name="model">gdpr.log</field>
            <field name="arch" type="xml">
                <form string="GDPR Log Entry">
                    <sheet>
                        <group>
                            <group>
                                <field name="partner_id"/>
                                <field name="partner_name"/>
                                <field name="partner_email"/>
                                <field name="action"/>
                            </group>
                            <group>
                                <field name="date"/>
                                <field name="user_id"/>
                                <field name="source"/>
                                <field name="ip_address"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <group string="Detaljer">
                            <field name="reason"/>
                            <field name="note"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_gdpr_log_search" model="ir.ui.view">
            <field name="name">gdpr.log.search</field>
            <field name="model">gdpr.log</field>
            <field name="arch" type="xml">
                <search string="GDPR Log">
                    <field name="partner_id"/>
                    <field name="partner_email"/>
                    <field name="action"/>
                    <field name="source"/>
                    <field name="user_id"/>
                    <filter string="Siste 30 dager" name="last_30_days"
                            domain="[('date', '>=', (context_today() - relativedelta(days=30)).strftime('%Y-%m-%d'))]"/>
                    <filter string="Blokkert" name="blocked" domain="[('action', '=', 'block')]"/>
                    <filter string="Avmeldt" name="unsubscribed" domain="[('action', '=', 'unsubscribe')]"/>
                    <group expand="0" string="Grupper etter">
                        <filter string="Handling" name="group_action" context="{'group_by': 'action'}"/>
                        <filter string="Kilde" name="group_source" context="{'group_by': 'source'}"/>
                        <filter string="Dato" name="group_date" context="{'group_by': 'date:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="view_gdpr_log_pivot" model="ir.ui.view">
            <field name="name">gdpr.log.pivot</field>
            <field name="model">gdpr.log</field>
            <field name="arch" type="xml">
                <pivot string="GDPR Statistikk">
                    <field name="date" type="row" interval="month"/>
                    <field name="action" type="col"/>
                </pivot>
            </field>
        </record>

        <record id="view_gdpr_log_graph" model="ir.ui.view">
            <field name="name">gdpr.log.graph</field>
            <field name="model">gdpr.log</field>
            <field name="arch" type="xml">
                <graph string="GDPR Tidslinje" type="bar">
                    <field name="date" type="row" interval="month"/>
                    <field name="action" type="col"/>
                </graph>
            </field>
        </record>

        <record id="action_gdpr_log" model="ir.actions.act_window">
            <field name="name">GDPR Logg</field>
            <field name="res_model">gdpr.log</field>
            <field name="view_mode">list,form,pivot,graph</field>
            <field name="context">{'search_default_last_30_days': 1}</field>
        </record>

    </data>
</odoo>
