<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <template id="gdpr_base_layout" name="GDPR Base Layout">
            <t t-call="website.layout">
                <div class="container py-5 text-center">
                    <div class="row justify-content-center">
                        <div class="col-md-6">
                            <t t-raw="0"/>
                        </div>
                    </div>
                </div>
            </t>
        </template>

        <template id="gdpr_unsubscribe_success" name="GDPR Avmelding Bekreftet">
            <t t-call="gdpr_platform.gdpr_base_layout">
                <div class="card shadow-sm p-4">
                    <div class="text-success mb-3">
                        <i class="fa fa-check-circle fa-4x"/>
                    </div>
                    <h3>Du er nå avmeldt</h3>
                    <p class="text-muted">
                        <t t-if="partner_name">Hei <strong t-out="partner_name"/>,</t>
                        du er fjernet fra våre e-postlister og vil ikke motta markedsføring fra oss.
                    </p>
                    <p class="small text-muted">
                        En bekreftelse er sendt til din e-postadresse.
                    </p>
                    <a href="/" class="btn btn-outline-secondary mt-3">Tilbake til forsiden</a>
                </div>
            </t>
        </template>

        <template id="gdpr_block_success" name="GDPR Blokkering Bekreftet">
            <t t-call="gdpr_platform.gdpr_base_layout">
                <div class="card shadow-sm p-4">
                    <div class="text-danger mb-3">
                        <i class="fa fa-ban fa-4x"/>
                    </div>
                    <h3>All kommunikasjon blokkert</h3>
                    <p class="text-muted">
                        <t t-if="partner_name">Hei <strong t-out="partner_name"/>,</t>
                        vi har registrert at du ønsker at vi ikke kontakter deg.
                        All elektronisk kommunikasjon fra oss er nå blokkert i henhold til GDPR.
                    </p>
                    <p class="small text-muted">
                        En bekreftelse er sendt til din e-postadresse.
                        Kontakt oss skriftlig dersom du ønsker å endre dette.
                    </p>
                    <a href="/" class="btn btn-outline-secondary mt-3">Tilbake til forsiden</a>
                </div>
            </t>
        </template>

        <template id="gdpr_invalid_token" name="GDPR Ugyldig Token">
            <t t-call="gdpr_platform.gdpr_base_layout">
                <div class="card shadow-sm p-4">
                    <div class="text-warning mb-3">
                        <i class="fa fa-exclamation-triangle fa-4x"/>
                    </div>
                    <h3>Ugyldig eller utløpt lenke</h3>
                    <p class="text-muted">
                        Lenken du brukte er ikke gyldig. Det kan skyldes at lenken er utløpt,
                        allerede er brukt, eller at kontoen ikke finnes.
                    </p>
                    <p class="text-muted">
                        Kontakt oss direkte dersom du ønsker hjelp med dine personverninnstillinger.
                    </p>
                    <a href="/" class="btn btn-outline-secondary mt-3">Tilbake til forsiden</a>
                </div>
            </t>
        </template>

    </data>
</odoo>
