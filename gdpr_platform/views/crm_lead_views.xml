<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_crm_lead_form_gdpr" model="ir.ui.view">
            <field name="name">crm.lead.form.gdpr</field>
            <field name="model">crm.lead</field>
            <field name="inherit_id" ref="crm.crm_lead_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                    <button name="action_gdpr_block_partner" type="object"
                            class="oe_stat_button" icon="fa-ban"
                            invisible="not partner_id or x_gdpr_blocked"
                            confirm="Block all contact with this person (GDPR)?">
                        <div class="o_stat_info">
                            <span class="o_stat_text">GDPR</span>
                            <span class="o_stat_text">Block</span>
                        </div>
                    </button>
                    <button name="action_gdpr_unblock_partner" type="object"
                            class="oe_stat_button btn-danger" icon="fa-ban"
                            invisible="not partner_id or not x_gdpr_blocked"
                            confirm="Remove the GDPR block for this contact?">
                        <div class="o_stat_info">
                            <span class="o_stat_text text-danger">GDPR</span>
                            <span class="o_stat_text text-danger">Blocked</span>
                        </div>
                    </button>
                </xpath>
                <xpath expr="//sheet" position="before">
                    <div class="alert alert-danger o_gdpr_block_banner" role="alert"
                         invisible="not x_gdpr_blocked">
                        <i class="fa fa-ban me-2"/>
                        <strong>GDPR BLOCKED: This contact cannot be contacted</strong>
                    </div>
                </xpath>
            </field>
        </record>

        <record id="view_crm_lead_list_gdpr" model="ir.ui.view">
            <field name="name">crm.lead.list.gdpr</field>
            <field name="model">crm.lead</field>
            <field name="inherit_id" ref="crm.crm_case_tree_view_leads"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="attributes">
                    <attribute name="decoration-danger">x_gdpr_blocked == True</attribute>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
