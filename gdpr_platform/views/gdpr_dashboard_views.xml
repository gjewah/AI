<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_gdpr_dashboard" model="ir.ui.view">
            <field name="name">gdpr.dashboard</field>
            <field name="model">gdpr.log</field>
            <field name="arch" type="xml">
                <graph string="GDPR Tidslinje" type="bar">
                    <field name="date" type="row" interval="month"/>
                    <field name="action" type="col"/>
                </graph>
            </field>
        </record>

        <record id="action_gdpr_dashboard" model="ir.actions.act_window">
            <field name="name">GDPR Dashboard</field>
            <field name="res_model">gdpr.log</field>
            <field name="view_mode">graph,pivot,list</field>
            <field name="context">{'search_default_last_30_days': 1}</field>
        </record>

    </data>
</odoo>
