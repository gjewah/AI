<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_sale_order_form_gdpr" model="ir.ui.view">
            <field name="name">sale.order.form.gdpr</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="before">
                    <div class="alert alert-danger o_gdpr_block_banner" role="alert"
                         invisible="not partner_id or not partner_id.x_gdpr_blocked">
                        <i class="fa fa-ban me-2"/>
                        <strong>GDPR BLOKKERT: Denne kontakten kan ikke kontaktes</strong>
                    </div>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
