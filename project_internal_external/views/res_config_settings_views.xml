<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.project_sequence_pattern</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="project.res_config_settings_view_form" />
            <field name="arch" type="xml">
                <xpath expr="//app[@name='project']" position="inside">
                    <block name="project_sequence_pattern" title="Project No.">
                        <setting
                            string="Project No. Pattern"
                            documentation="https://github.com/loym-com/apps-sequence/blob/18.0/base_sequence_number/readme/CONFIGURE.md"
                        >
                            <field name="project_sequence_pattern" placeholder="{r.sequence_code}" class="w-100"/>
                        </setting>
                    </block>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
