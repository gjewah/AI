<?xml version="1.0" encoding="utf-8" ?>
<data>
    <record id="project_project_view_form" model="ir.ui.view">
        <field name="name">project.project.view.form.internal_external</field>
        <field name="model">project.project</field>
        <field name="priority">33</field> <!-- After industry_fsm -->
        <field name="inherit_id" ref="project.edit_project" />
        <field name="arch" type="xml">
            <data>
                <field name="date_start" position="after">
                    <field name="internal_external" required="1"/>
                </field>
                <xpath expr="sheet/group/group/field[@name='company_id']" position="attributes">
                    <attribute name="required">1</attribute>
                </xpath>
            </data>
        </field>
    </record>
    <record id="project_project_view_tree" model="ir.ui.view">
        <field name="name">project.project.view.tree.internal_external</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="before">
                <field name="internal_external" optional="hide" />
            </xpath>
        </field>
    </record>
</data>
