<?xml version="1.0" encoding="utf-8" ?>
<data>
    <record id="project_project_view_kanban" model="ir.ui.view">
        <field name="name">project.project.view.kanban.inherit</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_kanban" />
        <field name="arch" type="xml">
            <field name="activity_ids" position="after">
                <button
                    name="action_open_share_project_wizard"
                    type="object"
                    icon="fa-share-alt"
                    title="Shared Project"
                    invisible="not shared"
                    class="me-2"
                />
            </field>
        </field>
    </record>
    <record id="project_project_view_form" model="ir.ui.view">
        <field name="name">project.project.view.form.inherit.project_documents_tag</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="documents_project.edit_project_document_form_inherit" />
        <field name="arch" type="xml">
            <data>
                <field name="is_favorite" position="after">
                    <button
                        name="action_open_share_project_wizard"
                        type="object"
                        icon="fa-share-alt"
                        title="Shared Project"
                        invisible="not shared"
                        class="me-2"
                    />
                </field>
            </data>
        </field>
    </record>
    <record id="project_project_view_list" model="ir.ui.view">
        <field name="name">project.project.view.list.inherit.project_documents_tag</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project" />
        <field name="arch" type="xml">
            <field name="name" position="before">
                <button
                    name="action_open_share_project_wizard"
                    type="object"
                    icon="fa-share-alt"
                    title="Shared Project"
                    invisible="not shared"
                />
                <field name="shared" optional="hide" widget="boolean_toggle"/>
            </field>
        </field>
    </record>
</data>
