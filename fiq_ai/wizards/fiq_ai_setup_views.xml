<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fiq_ai_setup_wizard_form" model="ir.ui.view">
        <field name="name">fiq.ai.setup.wizard.form</field>
        <field name="model">fiq.ai.setup.wizard</field>
        <field name="arch" type="xml">
            <form string="Sett opp FIQ AI">
                <field name="state" invisible="1"/>
                <field name="key_is_set" invisible="1"/>

                <!-- STEG 1 — hent en Claude-nøkkel -->
                <div invisible="state != 'step1'">
                    <h2>Steg 1 av 2 — Hent en Claude-nøkkel</h2>
                    <p>
                        FIQ AI bruker <b>Claude (Anthropic)</b>. Du trenger en API-nøkkel derfra.
                        Klikk knappen under for å åpne Anthropic Console i en ny fane.
                    </p>
                    <button name="action_open_console" type="object" class="btn-primary"
                            string="Åpne Anthropic Console ↗"/>
                    <p class="text-muted mt-3">
                        I konsollen: logg inn → <b>API keys</b> → <b>Create key</b> →
                        gi den et navn (f.eks. <code>fiqas-staging-fiq-ai</code>) →
                        <b>kopier nøkkelen</b> (den vises bare én gang).
                        Har du alt en nøkkel klar, gå videre til steg 2.
                    </p>
                    <div class="alert alert-info" role="alert" invisible="not key_is_set">
                        En nøkkel er allerede satt i systemet. Du kan la den stå, eller lime inn en ny i steg 2.
                    </div>
                </div>

                <!-- STEG 2 — lim inn nøkkelen -->
                <div invisible="state != 'step2'">
                    <h2>Steg 2 av 2 — Lim inn nøkkelen</h2>
                    <p>Lim inn Claude-nøkkelen du kopierte. Den lagres trygt og vises aldri i klartekst igjen.</p>
                    <group>
                        <field name="anthropic_key" widget="password" nolabel="0"
                               placeholder="sk-ant-..." password="True"/>
                    </group>
                    <field name="test_result" readonly="1" nolabel="1" invisible="not test_result"/>
                </div>

                <footer>
                    <button name="action_next" type="object" string="Neste →"
                            class="btn-primary" invisible="state != 'step1'"/>
                    <button name="action_back" type="object" string="← Tilbake"
                            invisible="state != 'step2'"/>
                    <button name="action_save_and_test" type="object" string="Lagre og test"
                            class="btn-primary" invisible="state != 'step2'"/>
                    <button string="Lukk" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_fiq_ai_setup" model="ir.actions.act_window">
        <field name="name">Sett opp FIQ AI (Claude-nøkkel)</field>
        <field name="res_model">fiq.ai.setup.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_fiq_ai_setup"
              name="Sett opp FIQ AI"
              parent="base.menu_administration"
              action="action_fiq_ai_setup"
              sequence="90"/>
</odoo>
